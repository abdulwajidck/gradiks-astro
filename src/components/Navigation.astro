---
---

<nav id="navbar">
  <div class="nav-container">
    <a href="/" class="nav-logo" aria-label="Gradiks Global - Home">
      <img src="/gradiks-logo.png" alt="Gradiks Global" loading="eager" />
    </a>
    <div class="nav-links">
      <a href="/#why-section" class="nav-link">The Truth</a>
      <a href="/#countries" class="nav-link">Courses</a>
      <a href="/#how-it-works" class="nav-link">Process</a>
      <a href="/#testimonials" class="nav-link">Stories</a>
      <a href="/#faq" class="nav-link">FAQ</a>
    </div>
    <div class="nav-actions">
      <button onclick="document.getElementById('lead-form-container')?.scrollIntoView({ behavior: 'smooth', block: 'center' })" class="nav-cta">
        Your Roadmap
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </button>
    </div>
    <button class="nav-hamburger" id="nav-toggle" aria-label="Toggle menu">
      <span></span><span></span><span></span>
    </button>
  </div>
  <div class="nav-mobile-menu" id="nav-mobile-menu">
    <a href="/#why-section" class="mobile-link">The Truth</a>
    <a href="/#countries" class="mobile-link">Courses</a>
    <a href="/#how-it-works" class="mobile-link">Process</a>
    <a href="/#testimonials" class="mobile-link">Stories</a>
    <a href="/#faq" class="mobile-link">FAQ</a>
    <a href="/#lead-form-container" class="mobile-link cta">Your Roadmap</a>
  </div>
</nav>

<script>
  const navbar = document.getElementById('navbar');
  const toggle = document.getElementById('nav-toggle');
  const mobileMenu = document.getElementById('nav-mobile-menu');

  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      navbar.classList.add('scrolled');
    } else {
      navbar.classList.remove('scrolled');
    }
  });

  toggle?.addEventListener('click', () => {
    mobileMenu.classList.toggle('open');
    toggle.classList.toggle('active');
    document.body.style.overflow = mobileMenu.classList.contains('open') ? 'hidden' : '';
  });

  // Close mobile menu on link click
  mobileMenu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu.classList.remove('open');
      toggle.classList.remove('active');
      document.body.style.overflow = '';
    });
  });
</script>

<style>
  nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    background: rgba(241, 241, 241, 0.95);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-bottom: 1px solid #d1d5db;
    transition: all 0.3s ease;
  }
  nav.scrolled {
    box-shadow: 0 2px 8px rgba(0,0,0,0.06);
  }
  .nav-container {
    max-width: 80rem;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }
  .nav-logo img {
    height: 2.5rem;
    width: auto;
    display: block;
  }
  .nav-links {
    display: flex;
    align-items: center;
    gap: 2rem;
    flex: 1;
    justify-content: center;
  }
  @media (max-width: 900px) {
    .nav-links { display: none; }
  }
  .nav-link {
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 600;
    color: #000000;
    letter-spacing: 0.01em;
    transition: color 0.2s ease;
    white-space: nowrap;
    text-transform: uppercase;
  }
  .nav-link:hover { color: var(--color-brand-red); }
  .nav-actions {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }
  .nav-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background: var(--color-brand-red);
    color: #ffffff;
    font-family: var(--font-display);
    font-size: 0.8125rem;
    font-weight: 700;
    border: 1px solid #000000;
    border-radius: 2px;
    cursor: pointer;
    transition: all 0.2s ease;
    white-space: nowrap;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    box-shadow: var(--shadow-soft-md);
  }
  .nav-cta:hover {
    background: #991b1b;
    box-shadow: var(--shadow-soft-lg);
  }

  /* Hamburger */
  .nav-hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 2rem;
    height: 2rem;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.25rem;
  }
  @media (max-width: 900px) {
    .nav-hamburger { display: flex; }
    .nav-container {
      height: 4.25rem;
      padding: 0 1rem;
      gap: 0.75rem;
    }
    .nav-logo {
      flex: 0 1 auto;
      min-width: 0;
    }
    .nav-logo img {
      height: 1.55rem;
      max-width: 8.5rem;
    }
    .nav-actions {
      flex: 0 0 auto;
      margin-left: auto;
    }
    .nav-cta {
      padding: 0.62rem 0.95rem;
      border-radius: 10px;
      font-size: 0.75rem;
      line-height: 1;
      box-shadow: 0 8px 18px rgba(190,30,45,0.22);
    }
    .nav-hamburger {
      flex: 0 0 2rem;
      width: 2rem;
    }
    .nav-mobile-menu { top: 5rem; }
  }
  @media (max-width: 380px) {
    .nav-container { padding: 0 0.875rem; gap: 0.55rem; }
    .nav-logo img { max-width: 7.4rem; }
    .nav-cta { padding: 0.58rem 0.72rem; font-size: 0.7rem; }
  }
  .nav-hamburger span {
    display: block;
    width: 100%;
    height: 1.5px;
    background: #111827;
    border-radius: 2px;
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1),
                opacity 0.2s ease;
  }
  .nav-hamburger.active span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
  .nav-hamburger.active span:nth-child(2) { opacity: 0; }
  .nav-hamburger.active span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

  /* Mobile menu */
  .nav-mobile-menu {
    display: none;
    position: fixed;
    top: 4rem;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(255,255,255,0.98);
    backdrop-filter: saturate(180%) blur(20px);
    -webkit-backdrop-filter: saturate(180%) blur(20px);
    flex-direction: column;
    padding: 2rem 1.5rem;
    gap: 0.5rem;
    overflow-y: auto;
  }
  .nav-mobile-menu.open { display: flex; }
  .mobile-link {
    font-family: var(--font-body);
    font-size: 1.125rem;
    font-weight: 500;
    color: #4b5563;
    padding: 0.875rem 0;
    border-bottom: 1px solid #f1f1f1;
    transition: color 0.2s ease;
    text-decoration: none;
  }
  .mobile-link:hover { color: #111827; }
  .mobile-link.cta {
    border-bottom: none;
    color: var(--color-brand-red);
    font-weight: 600;
    font-size: 1.125rem;
    margin-top: 0.5rem;
  }
</style>
