        <h4 class="footer-col-title">MBBS Abroad</h4>
        <ul class="footer-col-list">
          <li><a href="/georgia-study">Georgia</a></li>
          <li><a href="/kazakhstan-study">Kazakhstan</a></li>
          <li><a href="/kyrgyzstan-study">Kyrgyzstan</a></li>
