          <li><a href="/uzbekistan-study">Uzbekistan</a></li>
          <li><a href="/uk-mbbs">United Kingdom</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h4 class="footer-col-title">Other Programs</h4>
        <ul class="footer-col-list">
          <li><a href="/germany-study">Study in Germany</a></li>
          <li><a href="/ireland-study">Study in Ireland</a></li>
          <li><a href="/uk-study">Study in UK</a></li>
