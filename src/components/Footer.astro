<footer style="border-top: 1px solid #1e3a5f; background: #0a1628;">
    <div class="max-w-[1400px] mx-auto px-6 lg:px-12 py-16 lg:py-24">
        <div class="grid lg:grid-cols-12 gap-12 lg:gap-8">
            <!-- Brand Column -->
            <div class="lg:col-span-4">
                <div class="flex items-center gap-3 mb-6">
                    <!-- Logo -->
                    <div class="relative w-14 h-14 flex items-center justify-center" style="font-family: var(--font-display);">
                        <div class="absolute inset-0 border-2" style="border-color: #c9a227; transform: rotate(45deg);"></div>
                        <div class="absolute inset-2" style="background: linear-gradient(135deg, #c9a227 0%, #b08d1f 100%);"></div>
                        <span class="relative z-10 text-2xl font-bold" style="color: #0a1628;">G</span>
                    </div>
                    
                    <div class="flex flex-col">
                        <span class="text-2xl font-semibold tracking-wide" style="font-family: var(--font-display); color: #ffffff;">
