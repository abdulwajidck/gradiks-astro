<footer style="border-top: 1px solid #e5e7eb; background: #ffffff;">
    <div class="max-w-[1400px] mx-auto px-6 lg:px-12 py-16 lg:py-24">
        <div class="grid lg:grid-cols-12 gap-12 lg:gap-8">
            <!-- Brand column -->
            <div class="lg:col-span-4">
                <div class="flex items-center gap-3 mb-6">
                    <img src="/gradiks-logo.png" alt="Gradiks Global" class="h-10 w-auto" />
