---
import MainLayout from '../layouts/MainLayout.astro';
import Footer from './Footer.astro';

export interface University {
  name: string;
  founded?: string;
  blurb: string;
  tuition: string;
  duration: string;
  total?: string;
}
export interface WhyReason { title: string; body: string; }
export interface Story { initial?: string; img?: string; name: string; loc: string; year?: string; uni: string; outcome?: string; quote: string; }
export interface Pathway { region: string; salary: string; detail: string; exam: string; }
export interface Faq { q: string; a: string; }

export interface Props {
  title: string;
  description: string;
  country: { name: string; slug: string; flag: string; tagline: string };
  heroImage?: string;
  trustBar: { duration: string; tuition: string; recognition: string; medium: string };
  universities: University[];
  whyReasons: WhyReason[];
  pathways?: Pathway[];
  stories: Story[];
  faqs?: Faq[];
  crmCampaign: string;
  formType: string;
  redirectTo?: string;
}

const {
  title, description, country,
  heroImage = `/hero/${country.slug}-hero.jpg`,
  trustBar, universities, whyReasons, pathways = [], stories,
  faqs = [],
  crmCampaign, formType,
  redirectTo = '/nursing-thank-you',
} = Astro.props;
---

<MainLayout title={title} description={description}>
  <style>
    :root { --color-accent: #be1e2d; }
    .lp-hero { background: #03070f; }
    .lp-hero-bg {
      position: absolute; inset: 0; z-index: 0;
      background-image: var(--hero-bg);
      background-size: cover;
      background-position: center 30%;
      background-repeat: no-repeat;
    }
    .lp-hero-overlay {
      position: absolute; inset: 0; z-index: 1; pointer-events: none;
      background:
        radial-gradient(circle at 78% 22%, rgba(190,30,45,0.22), transparent 28rem),
        linear-gradient(90deg, rgba(3,7,15,0.94) 0%, rgba(3,7,15,0.78) 38%, rgba(3,7,15,0.55) 70%, rgba(3,7,15,0.55) 100%),
        linear-gradient(180deg, rgba(3,7,15,0.55) 0%, rgba(3,7,15,0) 30%, rgba(3,7,15,0) 70%, rgba(3,7,15,0.65) 100%);
    }
    .lp-hero-grid {
      position: absolute; inset: 0; z-index: 2; pointer-events: none;
      background-image:
        linear-gradient(rgba(255,255,255,0.035) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.035) 1px, transparent 1px);
      background-size: 64px 64px;
      mask-image: radial-gradient(ellipse at 30% 40%, black 25%, transparent 70%);
    }
    @media (max-width: 1023px) {
      .lp-hero-bg {
        inset: 0 0 auto 0;
        height: 58vh;
        min-height: 420px;
        max-height: 560px;
        background-position: 50% 28%;
        -webkit-mask-image: linear-gradient(180deg, #000 0%, #000 60%, transparent 100%);
        mask-image: linear-gradient(180deg, #000 0%, #000 60%, transparent 100%);
      }
      .lp-hero-overlay {
        background:
          radial-gradient(circle at 80% 8%, rgba(190,30,45,0.18), transparent 16rem),
          linear-gradient(180deg,
            rgba(3,7,15,0.30) 0%, rgba(3,7,15,0.30) 30%,
            rgba(3,7,15,0.85) 55%, rgba(3,7,15,0.96) 75%,
            rgba(3,7,15,0.98) 100%);
      }
      .lp-hero-grid { mask-image: radial-gradient(ellipse at 50% 75%, black 30%, transparent 75%); }
    }
    .form-card {
      background: linear-gradient(180deg, rgba(255,255,255,0.10), rgba(255,255,255,0.04));
      border: 1px solid rgba(255,255,255,0.18);
      box-shadow: 0 34px 80px -32px rgba(0,0,0,0.55), inset 0 1px 0 rgba(255,255,255,0.10);
      backdrop-filter: blur(22px);
    }
    .form-card input, .form-card select {
      background: rgba(255,255,255,0.07);
      border: 1px solid rgba(255,255,255,0.16);
      color: #fff;
    }
    .form-card input::placeholder { color: rgba(255,255,255,0.5); }
    .form-card input:focus, .form-card select:focus {
      outline: none; border-color: rgba(255,255,255,0.4);
      background: rgba(255,255,255,0.10);
    }
    .form-card select option { color: #0d0d0d; }
    .why-card { transition: transform .3s cubic-bezier(.16,1,.3,1), border-color .3s; }
    .why-card:hover { transform: translateY(-3px); border-color: rgba(190,30,45,0.4); }
    .uni-tile { transition: all .3s cubic-bezier(.16,1,.3,1); }
    .uni-tile:hover { transform: translateY(-3px); border-color: rgba(190,30,45,0.5); box-shadow: 0 24px 48px -24px rgba(190,30,45,0.25); }
    .step-line { background: linear-gradient(180deg, #be1e2d 0%, rgba(190,30,45,0.15) 100%); }
  </style>

  <header class="absolute top-0 left-0 right-0 z-30">
    <div class="max-w-[1400px] mx-auto px-6 lg:px-12 py-5 flex items-center justify-between">
      <div class="flex items-center gap-2.5 px-4 py-2 rounded-full bg-white shadow-md">
        <img src="/gradiks-logo.png" alt="Gradiks" width="120" height="32" class="h-7 w-auto" />
      </div>
      <a href="tel:+919778130583" class="text-white/80 hover:text-white text-sm font-medium hidden sm:flex items-center gap-2">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.13.96.37 1.9.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.91.33 1.85.57 2.81.7A2 2 0 0122 16.92z"/></svg>
        +91 97781 30583
      </a>
    </div>
  </header>

  <!-- HERO -->
  <section class="lp-hero relative overflow-hidden pt-28 pb-16 lg:pt-32 lg:pb-24" style={`--hero-bg: url('${heroImage}')`}>
    <div class="lp-hero-bg" aria-hidden="true"></div>
    <div class="lp-hero-overlay" aria-hidden="true"></div>
    <div class="lp-hero-grid" aria-hidden="true"></div>
    <div class="max-w-[1400px] mx-auto px-6 lg:px-12 relative z-10">
      <div class="grid lg:grid-cols-[1.15fr_1fr] gap-10 lg:gap-16 items-center">
        <div>
          <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-white/15 bg-white/5 backdrop-blur mb-6">
            <span class="text-base">{country.flag}</span>
            <span class="text-[11px] tracking-[0.18em] uppercase text-white/80 font-medium">BSc Nursing in {country.name} · 2026 intake</span>
          </div>
          <h1 class="text-white font-semibold leading-[1.02] tracking-[-0.04em] text-4xl sm:text-5xl lg:text-[5.5rem]" style="font-family: var(--font-display);">
            BSc Nursing<br />
            <span style="background: linear-gradient(120deg, #fff 0%, #ffd2d6 50%, #be1e2d 100%); -webkit-background-clip: text; background-clip: text; color: transparent;">in {country.name}.</span>
          </h1>
          <p class="text-white/70 text-base lg:text-xl leading-relaxed mt-5 lg:mt-7 max-w-xl">{country.tagline}</p>

          <ul class="mt-7 lg:mt-9 grid grid-cols-2 gap-x-6 gap-y-3 max-w-xl">
            {[
              'No NEET required',
              'English-medium degree',
              'INC + global licensing roadmap',
              'Zero capitation, written cost sheet',
            ].map(t => (
              <li class="flex items-start gap-2.5 text-sm text-white/85">
                <svg class="w-4 h-4 text-[#be1e2d] mt-0.5 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                {t}
              </li>
            ))}
          </ul>
        </div>

        <div class="form-card rounded-2xl p-6 lg:p-8" id="lead-form-container">
          <div class="text-[11px] tracking-[0.2em] uppercase text-[#ffb1b8] font-semibold mb-1">Free · Limited slots</div>
          <h2 class="text-white text-2xl lg:text-[1.7rem] font-semibold mb-1.5 leading-tight" style="font-family: var(--font-display);">Get your free {country.name} plan</h2>
          <p class="text-white/60 text-sm mb-5">University shortlist + cost sheet + INC roadmap. Delivered in 24 hrs.</p>
          <form id="lead-form" class="space-y-3">
            <input type="text" name="name" required placeholder="Student's full name *" class="w-full px-4 py-3 rounded-lg text-sm" />
            <input type="tel" name="phone" required pattern="[0-9+\s\-]{8,}" placeholder="Phone (we'll WhatsApp the plan) *" class="w-full px-4 py-3 rounded-lg text-sm" />
            <input type="email" name="email" required placeholder="Email *" class="w-full px-4 py-3 rounded-lg text-sm" />
            <div class="grid grid-cols-2 gap-3">
              <input type="text" name="pcb_percent" placeholder="12th PCB %" class="w-full px-4 py-3 rounded-lg text-sm" />
              <select name="preferred_country" class="w-full px-4 py-3 rounded-lg text-sm">
                <option value={country.name} selected>{country.name}</option>
                <option value="Not sure">Not sure — recommend me</option>
                <option value="Georgia">Georgia</option>
                <option value="Albania">Albania</option>
                <option value="Bulgaria">Bulgaria</option>
                <option value="Malta">Malta</option>
                <option value="UK">United Kingdom</option>
              </select>
            </div>
            <button type="submit" class="w-full py-4 bg-[#be1e2d] hover:bg-[#a81826] text-white font-semibold rounded-lg transition-all flex items-center justify-center gap-2 mt-2">
              Send me my nursing plan
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </button>
            <p class="text-[11px] text-white/45 text-center pt-1">No spam. We never share your data. Talk to a counsellor in 24 hrs.</p>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- TRUST STRIP -->
  <section class="bg-[#0d1829] border-y border-white/5 py-6 overflow-hidden">
    <div class="max-w-[1400px] mx-auto px-6 lg:px-12">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-y-6 gap-x-8 items-center">
        {[
          { value: trustBar.duration, label: 'Duration' },
          { value: trustBar.tuition, label: 'Tuition / year' },
          { value: trustBar.recognition, label: 'Recognition' },
          { value: trustBar.medium, label: 'Medium' },
        ].map(s => (
          <div class="text-center lg:text-left lg:border-l lg:border-white/10 lg:pl-6 first:border-l-0 first:pl-0">
            <div class="text-2xl lg:text-3xl font-semibold text-white tabular-nums" style="font-family: var(--font-display);">{s.value}</div>
            <div class="text-[11px] tracking-[0.2em] uppercase text-white/50 mt-1">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- WHY -->
  <section class="py-20 lg:py-28 bg-[#fafaf9]">
    <div class="max-w-[1400px] mx-auto px-6 lg:px-12">
      <div class="max-w-3xl mb-14">
        <div class="text-[11px] tracking-[0.3em] uppercase text-[#be1e2d] font-semibold mb-4">Why {country.name}</div>
        <h2 class="text-4xl md:text-5xl lg:text-6xl font-semibold tracking-[-0.025em] leading-[1.05]" style="font-family: var(--font-display);">
          What makes {country.name}<br /><span class="text-[#be1e2d]">work for nursing.</span>
        </h2>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
        {whyReasons.map((r, i) => (
          <div class="why-card bg-white rounded-2xl p-7 lg:p-8 border border-[#ececec]">
            <div class="font-display font-semibold text-4xl text-[#be1e2d]/15 mb-4" style="font-family: var(--font-display);">{String(i + 1).padStart(2, '0')}</div>
            <h3 class="text-lg font-semibold mb-2.5 leading-tight" style="font-family: var(--font-display);">{r.title}</h3>
            <p class="text-text-secondary text-[0.92rem] leading-relaxed">{r.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- UNIVERSITIES -->
  <section class="py-20 lg:py-28 bg-[#0d1829] text-white relative overflow-hidden">
    <div class="absolute inset-0 opacity-30 pointer-events-none" style="background: radial-gradient(circle at 20% 0%, rgba(190,30,45,0.18), transparent 30rem);"></div>
    <div class="max-w-[1400px] mx-auto px-6 lg:px-12 relative">
      <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6 mb-12">
        <div class="max-w-2xl">
          <div class="text-[11px] tracking-[0.3em] uppercase text-[#ffb1b8] font-semibold mb-4">Top universities</div>
          <h2 class="text-4xl md:text-5xl lg:text-6xl font-semibold tracking-[-0.025em] leading-[1.05]" style="font-family: var(--font-display);">Nursing programs<br />in {country.name}.</h2>
        </div>
        <p class="text-white/60 max-w-md text-base">Tuition + total cost in writing. Click a university to lock in your shortlist.</p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
        {universities.map(u => (
          <div class="uni-tile bg-white/5 border border-white/10 rounded-2xl p-7 hover:bg-white/[0.07]">
            {u.founded && <div class="text-[10px] tracking-[0.2em] uppercase text-[#ffb1b8] font-semibold mb-3">{u.founded}</div>}
            <h3 class="text-xl lg:text-[1.35rem] font-semibold mb-3 leading-tight text-white" style="font-family: var(--font-display);">{u.name}</h3>
            <p class="text-white/65 text-sm leading-relaxed mb-6 min-h-[80px]">{u.blurb}</p>
            <div class="grid grid-cols-2 gap-1 border-t border-white/10 pt-5">
              <div>
                <div class="text-[10px] tracking-[0.15em] uppercase text-white/40 mb-1">Tuition</div>
                <div class="text-sm font-semibold text-white tabular-nums">{u.tuition}</div>
              </div>
              <div>
                <div class="text-[10px] tracking-[0.15em] uppercase text-white/40 mb-1">Duration</div>
                <div class="text-sm font-semibold text-white">{u.duration}</div>
              </div>
            </div>
            {u.total && (
              <div class="mt-4 pt-4 border-t border-white/10 flex items-baseline justify-between">
                <span class="text-[10px] tracking-[0.15em] uppercase text-white/40">Total all-in</span>
                <span class="text-sm font-semibold text-[#22c55e] tabular-nums">{u.total}</span>
              </div>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  {pathways.length > 0 && (
    <section class="py-20 lg:py-28 bg-white">
      <div class="max-w-[1400px] mx-auto px-6 lg:px-12">
        <div class="max-w-3xl mb-12">
          <div class="text-[11px] tracking-[0.3em] uppercase text-[#be1e2d] font-semibold mb-4">After graduation</div>
          <h2 class="text-4xl md:text-5xl lg:text-6xl font-semibold tracking-[-0.025em] leading-[1.05]" style="font-family: var(--font-display);">
            Where this degree<br />takes you.
          </h2>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
          {pathways.map(p => (
            <div class="bg-[#fafaf9] rounded-2xl p-7 border border-[#ececec]">
              <div class="text-[10px] tracking-[0.2em] uppercase text-[#be1e2d] font-semibold mb-3">{p.region}</div>
              <div class="text-3xl font-semibold mb-2 tabular-nums" style="font-family: var(--font-display);">{p.salary}</div>
              <p class="text-sm text-text-secondary mb-4">{p.detail}</p>
              <p class="text-xs text-text-tertiary border-t border-[#ececec] pt-3">{p.exam}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- STORIES -->
  <section class="py-20 lg:py-28 bg-[#fafaf9]">
    <div class="max-w-[1400px] mx-auto px-6 lg:px-12">
      <div class="max-w-3xl mb-12">
        <div class="text-[11px] tracking-[0.3em] uppercase text-[#be1e2d] font-semibold mb-4">Real students · Real outcomes</div>
        <h2 class="text-4xl md:text-5xl lg:text-6xl font-semibold tracking-[-0.025em] leading-[1.05]" style="font-family: var(--font-display);">
          From {country.name},<br />in their words.
        </h2>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {stories.map(s => (
          <article class="bg-white rounded-2xl p-7 border border-[#ececec] flex flex-col">
            {s.outcome && (
              <div class="inline-flex items-center gap-2 self-start text-[10px] tracking-[0.18em] uppercase font-semibold text-[#059669] bg-[#059669]/8 px-2.5 py-1 rounded-full mb-5">
                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
                {s.outcome}
              </div>
            )}
            <p class="text-[0.92rem] text-text-secondary leading-relaxed flex-1">"{s.quote}"</p>
            <div class="mt-5 pt-5 border-t border-[#ececec] flex items-center gap-3">
              {s.img
                ? <img src={s.img} alt={s.name} loading="lazy" decoding="async" class="w-10 h-10 rounded-full object-cover ring-1 ring-[#ececec] flex-shrink-0" />
                : <div class="w-10 h-10 rounded-full bg-[#be1e2d] text-white flex items-center justify-center font-semibold flex-shrink-0" style="font-family: var(--font-display);">{s.initial || s.name[0]}</div>
              }
              <div class="min-w-0">
                <div class="font-semibold text-sm" style="font-family: var(--font-display);">{s.name} <span class="text-text-tertiary font-normal">· {s.loc}</span></div>
                <div class="text-xs text-text-tertiary truncate">{s.uni}</div>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- PROCESS -->
  <section class="py-20 lg:py-28 bg-[#0d1829] text-white relative overflow-hidden">
    <div class="absolute inset-0 opacity-40 pointer-events-none" style="background: radial-gradient(circle at 80% 100%, rgba(190,30,45,0.15), transparent 30rem);"></div>
    <div class="max-w-[1100px] mx-auto px-6 lg:px-12 relative">
      <div class="max-w-3xl mb-14">
        <div class="text-[11px] tracking-[0.3em] uppercase text-[#ffb1b8] font-semibold mb-4">From form to flight</div>
        <h2 class="text-4xl md:text-5xl lg:text-6xl font-semibold tracking-[-0.025em] leading-[1.05]" style="font-family: var(--font-display);">
          5 steps.<br />Fully managed.
        </h2>
      </div>
      <div class="space-y-4">
        {[
          { n: '01', t: 'You fill the form', d: 'We get your 12th PCB %, budget, and country preference. Free.' },
          { n: '02', t: 'Counsellor + parent call', d: '45 minutes. Country match, written cost sheet, INC roadmap. No pressure, no upsell.' },
          { n: '03', t: 'You talk to a current student', d: `We connect you with a Gradiks-placed senior at one of your shortlisted ${country.name} universities. Real, unfiltered.` },
          { n: '04', t: 'Application + visa', d: 'We handle attestations, university application, embassy interview prep. Confirmation in 6–10 weeks.' },
          { n: '05', t: 'Pre-departure + on-ground pickup', d: 'Pre-departure call, flight booking guidance, airport pickup, and hostel handover.' },
        ].map((s, i) => (
          <div class="flex gap-5 items-start">
            <div class="flex flex-col items-center flex-shrink-0">
              <div class="w-12 h-12 rounded-full bg-[#be1e2d] flex items-center justify-center font-semibold text-white text-base" style="font-family: var(--font-display);">{s.n}</div>
              {i < 4 && <div class="w-px h-12 step-line mt-1"></div>}
            </div>
            <div class="pb-2 pt-2.5">
              <div class="font-semibold text-xl mb-1.5 text-white" style="font-family: var(--font-display);">{s.t}</div>
              <div class="text-white/60 text-[0.95rem] max-w-xl leading-relaxed">{s.d}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  {faqs.length > 0 && (
    <section class="py-20 lg:py-28 bg-[#fafaf9]">
      <div class="max-w-[900px] mx-auto px-6 lg:px-12">
        <div class="text-center mb-12">
          <div class="text-[11px] tracking-[0.3em] uppercase text-[#be1e2d] font-semibold mb-4">Questions parents always ask</div>
          <h2 class="text-4xl md:text-5xl font-semibold tracking-[-0.025em] leading-[1.07]" style="font-family: var(--font-display);">FAQ</h2>
        </div>
        <div class="space-y-3">
          {faqs.map(f => (
            <details class="group bg-white border border-[#ececec] rounded-xl overflow-hidden">
              <summary class="flex items-center justify-between gap-4 px-6 py-5 cursor-pointer list-none">
                <span class="font-semibold text-[0.98rem] text-text-primary pr-4" style="font-family: var(--font-display);">{f.q}</span>
                <svg class="w-5 h-5 flex-shrink-0 text-[#be1e2d] transition-transform group-open:rotate-45" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
              </summary>
              <div class="px-6 pb-6 -mt-1">
                <p class="text-text-secondary text-[0.92rem] leading-relaxed">{f.a}</p>
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- FINAL CTA -->
  <section class="py-20 lg:py-28 bg-gradient-to-br from-[#0d1829] via-[#0d1829] to-[#1a0a0e] text-white relative overflow-hidden">
    <div class="absolute inset-0 opacity-50 pointer-events-none" style="background: radial-gradient(circle at 50% 50%, rgba(190,30,45,0.25), transparent 30rem);"></div>
    <div class="max-w-[900px] mx-auto px-6 lg:px-12 relative text-center">
      <div class="text-[11px] tracking-[0.3em] uppercase text-[#ffb1b8] font-semibold mb-5">Sept 2026 intake — seats confirming now</div>
