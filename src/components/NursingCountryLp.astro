      <button onclick="document.getElementById('lead-form-container')?.scrollIntoView({behavior:'smooth',block:'center'})" class="inline-flex items-center gap-2 px-8 py-4 bg-[#be1e2d] hover:bg-[#a81826] text-white font-semibold rounded-full text-base shadow-[0_20px_50px_-12px_rgba(190,30,45,0.6)] transition-all">
        Get my free {country.name} plan
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
