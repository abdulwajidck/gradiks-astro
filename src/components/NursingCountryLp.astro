  <div class="fixed bottom-0 left-0 right-0 bg-white border-t border-[#ececec] p-3 lg:hidden z-50 shadow-[0_-8px_24px_rgba(0,0,0,0.08)]">
    <button onclick="document.getElementById('lead-form-container')?.scrollIntoView({behavior:'smooth',block:'center'})" class="w-full py-3.5 bg-[#be1e2d] text-white font-semibold rounded-full text-sm">
      Get my free {country.name} plan →
    </button>
