---
import MainLayout from '../layouts/MainLayout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
const title = "Gradiks — MBBS, BDS, Nursing & Allied Health in South India";
const description = "NEET counselling support for MBBS, BDS, Nursing, Pharmacy & Allied Health in Kerala, Karnataka & Tamil Nadu. Honest guidance — no admission guarantees.";
---
<MainLayout title={title} description={description}>
<Navigation />
<!-- TRUST BAR -->
<section class="bg-[#232d61] py-4 mt-20">
  <div class="max-w-[1400px] mx-auto px-6 lg:px-12">
    <div class="flex flex-wrap justify-center items-center gap-8 lg:gap-16 text-white text-sm">
      <span class="flex items-center gap-2">
        <span class="font-display font-semibold">3</span>
        <span class="text-white/70">States Covered</span>
      </span>
      <span class="text-white/30 hidden sm:block">•</span>
      <span class="flex items-center gap-2">
        <span class="font-display font-semibold">500+</span>
        <span class="text-white/70">Colleges</span>
      </span>
      <span class="text-white/30 hidden sm:block">•</span>
      <span class="flex items-center gap-2">
        <span class="font-display font-semibold">100%</span>
        <span class="text-white/70">Legal Process</span>
      </span>
    </div>
  </div>
</section>
<!-- HERO SECTION -->
<section class="min-h-screen flex items-center relative overflow-hidden py-20 lg:py-32">
  <div class="absolute inset-0 z-0">
    <div class="absolute top-1/3 right-0 w-[1000px] h-[1000px] bg-gradient-radial from-[rgba(190,30,45,0.06)] via-transparent to-transparent rounded-full blur-3xl"></div>
  </div>
  <div class="max-w-[1400px] mx-auto px-6 lg:px-12 py-20 lg:py-32 relative z-10 w-full">
    <div class="max-w-4xl">
      <!-- Badge -->
      <div class="inline-flex items-center gap-3 px-4 py-2 border border-white/20 bg-white/5 backdrop-blur-sm mb-8 animate-fade-in-up">
        <span class="text-2xl">🇮🇳</span>
        <span class="text-xs font-medium tracking-[0.15em] uppercase text-white/80">Domestic Medical Admissions</span>
      </div>
      <!-- Headline -->
      <h1 class="text-6xl md:text-7xl lg:text-8xl font-semibold leading-[1.04] tracking-[-0.02em] mb-8 animate-fade-in-up delay-100" style="font-family: var(--font-display);">
        MBBS in
        <br />
        <span class="text-[#be1e2d]">South India</span>
      </h1>
      <!-- Subheadline -->
      <p class="text-xl md:text-2xl text-white/70 max-w-2xl leading-relaxed mb-12 animate-fade-in-up delay-200">
        Expert NEET counselling support for Kerala, Karnataka, and Tamil Nadu. We guide you through the process — we don't guarantee admissions.
      </p>
      <!-- CTA Buttons -->
      <div class="flex flex-col sm:flex-row gap-4 animate-fade-in-up delay-300">
        <button onclick="document.getElementById('lead-form-container')?.scrollIntoView({ behavior: 'smooth', block: 'center' })" class="group relative px-8 py-4 bg-[#be1e2d] text-white font-semibold tracking-wide overflow-hidden transition-all duration-300 hover:shadow-[0_0_40px_rgba(190,30,45,0.3)]">
          <span class="relative z-10 flex items-center justify-center gap-2">
            Get Counselling Support
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-1"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </span>
        </button>
      </div>
    </div>
  </div>
</section>
<!-- DISCLAIMER -->
<section class="py-16 bg-[#f5f5f7]">
  <div class="max-w-[1400px] mx-auto px-6 lg:px-12">
    <div class="max-w-4xl mx-auto">
      <div class="bg-white rounded-xl p-8 lg:p-12 shadow-[0_4px_24px_rgba(0,0,0,0.06)] relative border-l-4 border-[#be1e2d]">
        <h3 class="text-xl font-semibold mb-6 text-[#be1e2d]" style="font-family: var(--font-display);">Important Disclaimer</h3>
        <ul class="space-y-4">
          <li class="flex gap-4 text-[#4b5563]">
            <span class="text-[#be1e2d]">→</span>
            <span>We do NOT guarantee admissions or have "management quota" seats.</span>
          </li>
          <li class="flex gap-4 text-[#4b5563]">
            <span class="text-[#be1e2d]">→</span>
            <span>NEET is mandatory for all medical admissions in India. No exceptions.</span>
          </li>
          <li class="flex gap-4 text-[#4b5563]">
            <span class="text-[#be1e2d]">→</span>
            <span>We only guide through official government counselling processes.</span>
          </li>
          <li class="flex gap-4 text-[#4b5563]">
            <span class="text-[#be1e2d]">→</span>
            <span>Beware of agents promising "direct admission" — it's illegal.</span>
          </li>
        </ul>
      </div>
    </div>
  </div>
</section>
<!-- STATES SECTION -->
<section class="py-24 lg:py-32 bg-[#1d1d1f]">
  <div class="max-w-[1400px] mx-auto px-6 lg:px-12">
    <div class="max-w-3xl mb-16">
      <div class="text-xs tracking-[0.3em] uppercase text-[#be1e2d] mb-4">States We Cover</div>
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-semibold tracking-tight leading-[1.07] letter-tight text-white" style="font-family: var(--font-display);">
        Kerala · Karnataka ·<br />Tamil Nadu
      </h2>
    </div>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-white/5 backdrop-blur-sm border border-white/10 p-8 lg:p-10 hover:border-[#be1e2d] transition-all duration-500">
        <div class="text-4xl font-light text-white mb-2" style="font-family: var(--font-display);">Kerala</div>
        <div class="text-xs tracking-[0.2em] uppercase text-white/50 mb-8">God's Own Country</div>
        <div class="space-y-3">
          <div class="flex gap-3 text-sm text-white/60">
            <span class="text-[#be1e2d]">→</span>
            <span>30+ Medical Colleges</span>
          </div>
          <div class="flex gap-3 text-sm text-white/60">
            <span class="text-[#be1e2d]">→</span>
            <span>State & NRI Quota</span>
          </div>
          <div class="flex gap-3 text-sm text-white/60">
            <span class="text-[#be1e2d]">→</span>
            <span>KEAM Counselling</span>
          </div>
          <div class="flex gap-3 text-sm text-white/60">
            <span class="text-[#be1e2d]">→</span>
            <span>Govt: ₹25K/year</span>
          </div>
        </div>
      </div>
      <div class="bg-white/5 backdrop-blur-sm border border-white/10 p-8 lg:p-10 hover:border-[#be1e2d] transition-all duration-500">
        <div class="text-4xl font-light text-white mb-2" style="font-family: var(--font-display);">Karnataka</div>
        <div class="text-xs tracking-[0.2em] uppercase text-white/50 mb-8">Silicon Valley of India</div>
        <div class="space-y-3">
          <div class="flex gap-3 text-sm text-white/60">
            <span class="text-[#be1e2d]">→</span>
            <span>60+ Medical Colleges</span>
          </div>
          <div class="flex gap-3 text-sm text-white/60">
            <span class="text-[#be1e2d]">→</span>
            <span>All India & State Quota</span>
          </div>
          <div class="flex gap-3 text-sm text-white/60">
            <span class="text-[#be1e2d]">→</span>
            <span>KEA Counselling</span>
          </div>
          <div class="flex gap-3 text-sm text-white/60">
            <span class="text-[#be1e2d]">→</span>
            <span>Govt: ₹50K/year</span>
          </div>
        </div>
      </div>
      <div class="bg-white/5 backdrop-blur-sm border border-white/10 p-8 lg:p-10 hover:border-[#be1e2d] transition-all duration-500">
        <div class="text-4xl font-light text-white mb-2" style="font-family: var(--font-display);">Tamil Nadu</div>
        <div class="text-xs tracking-[0.2em] uppercase text-white/50 mb-8">Land of Temples</div>
        <div class="space-y-3">
          <div class="flex gap-3 text-sm text-white/60">
            <span class="text-[#be1e2d]">→</span>
            <span>70+ Medical Colleges</span>
          </div>
          <div class="flex gap-3 text-sm text-white/60">
            <span class="text-[#be1e2d]">→</span>
            <span>State & Management Quota</span>
          </div>
          <div class="flex gap-3 text-sm text-white/60">
            <span class="text-[#be1e2d]">→</span>
            <span>TN DME Counselling</span>
          </div>
          <div class="flex gap-3 text-sm text-white/60">
            <span class="text-[#be1e2d]">→</span>
            <span>Govt: ₹13K-50K/year</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
<!-- PROGRAMS SECTION -->
<section class="py-24 lg:py-32 bg-[#f5f5f7]">
  <div class="max-w-[1400px] mx-auto px-6 lg:px-12">
    <div class="max-w-3xl mb-16">
      <div class="text-xs tracking-[0.3em] uppercase text-[#be1e2d] mb-4">Programs</div>
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-semibold tracking-tight leading-[1.07] letter-tight" style="font-family: var(--font-display);">
        Medical<br />Programs
      </h2>
    </div>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      <div class="bg-white p-8 hover:shadow-[0_4px_24px_rgba(0,0,0,0.08)] transition-all duration-500">
        <div class="flex items-center justify-between mb-4">
          <span class="text-xs tracking-[0.2em] uppercase text-[#be1e2d]">UG Medical</span>
          <span class="text-xs px-2 py-1 border border-[#be1e2d] text-[#be1e2d] rounded">NEET Required</span>
        </div>
        <h3 class="text-2xl font-semibold mb-4" style="font-family: var(--font-display);">MBBS</h3>
        <p class="text-sm text-[#4b5563]">Bachelor of Medicine & Bachelor of Surgery. 5.5 years including internship.</p>
      </div>
      <div class="bg-white p-8 hover:shadow-[0_4px_24px_rgba(0,0,0,0.08)] transition-all duration-500">
        <div class="flex items-center justify-between mb-4">
          <span class="text-xs tracking-[0.2em] uppercase text-[#be1e2d]">UG Dental</span>
          <span class="text-xs px-2 py-1 border border-[#be1e2d] text-[#be1e2d] rounded">NEET Required</span>
        </div>
        <h3 class="text-2xl font-semibold mb-4" style="font-family: var(--font-display);">BDS</h3>
        <p class="text-sm text-[#4b5563]">Bachelor of Dental Surgery. 5 years including internship. High demand in India.</p>
      </div>
      <div class="bg-white p-8 hover:shadow-[0_4px_24px_rgba(0,0,0,0.08)] transition-all duration-500">
        <div class="flex items-center justify-between mb-4">
          <span class="text-xs tracking-[0.2em] uppercase text-[#be1e2d]">UG Nursing</span>
          <span class="text-xs px-2 py-1 border border-[#6b7280] text-[#6b7280] rounded">NEET Not Required</span>
        </div>
        <h3 class="text-2xl font-semibold mb-4" style="font-family: var(--font-display);">B.Sc Nursing</h3>
        <p class="text-sm text-[#4b5563]">4-year degree program. Growing demand in India and abroad. Multiple entry pathways.</p>
      </div>
    </div>
  </div>
</section>
<!-- LEAD FORM -->
<section id="lead-form-container" class="py-24 lg:py-32">
  <div class="max-w-[1400px] mx-auto px-6 lg:px-12">
    <div class="max-w-2xl mx-auto">
      <div class="text-center mb-12">
        <div class="text-xs tracking-[0.3em] uppercase text-[#be1e2d] mb-4">Get Started</div>
        <h2 class="text-4xl md:text-5xl font-semibold tracking-tight mb-4 leading-[1.07] letter-tight" style="font-family: var(--font-display);">
          Get Counselling<br />Support
        </h2>
        <p class="text-[#4b5563]">
          Fill your details. Our experts will guide you through the NEET counselling process.
        </p>
      </div>
      <form id="lead-form" class="bg-white rounded-xl p-8 lg:p-12 shadow-[0_4px_24px_rgba(0,0,0,0.06)]">
        <div class="grid md:grid-cols-2 gap-6 mb-6">
          <div>
            <label class="form-label text-sm font-medium text-[#111827] mb-2 block">Student Name *</label>
            <input type="text" required class="w-full px-4 py-3 border border-[#e5e7eb] rounded-lg focus:outline-none focus:border-[#be1e2d] focus:ring-1 focus:ring-[#be1e2d] transition-all" placeholder="Full name">
          </div>
          <div>
            <label class="form-label text-sm font-medium text-[#111827] mb-2 block">Parent's Phone *</label>
            <input type="tel" required class="w-full px-4 py-3 border border-[#e5e7eb] rounded-lg focus:outline-none focus:border-[#be1e2d] focus:ring-1 focus:ring-[#be1e2d] transition-all" placeholder="+91...">
          </div>
        </div>
        <div class="mb-6">
          <label class="form-label text-sm font-medium text-[#111827] mb-2 block">NEET Score / AIR *</label>
          <input type="text" required class="w-full px-4 py-3 border border-[#e5e7eb] rounded-lg focus:outline-none focus:border-[#be1e2d] focus:ring-1 focus:ring-[#be1e2d] transition-all" placeholder="Enter NEET score or All India Rank">
        </div>
        <div class="grid md:grid-cols-2 gap-6 mb-6">
          <div>
            <label class="form-label text-sm font-medium text-[#111827] mb-2 block">Preferred State</label>
            <select class="w-full px-4 py-3 border border-[#e5e7eb] rounded-lg focus:outline-none focus:border-[#be1e2d] focus:ring-1 focus:ring-[#be1e2d] transition-all bg-white">
              <option value="">Select state</option>
              <option value="kerala">Kerala</option>
              <option value="karnataka">Karnataka</option>
              <option value="tamil-nadu">Tamil Nadu</option>
              <option value="any">Any / Open to All</option>
            </select>
          </div>
          <div>
            <label class="form-label text-sm font-medium text-[#111827] mb-2 block">Program</label>
            <select class="w-full px-4 py-3 border border-[#e5e7eb] rounded-lg focus:outline-none focus:border-[#be1e2d] focus:ring-1 focus:ring-[#be1e2d] transition-all bg-white">
              <option value="">Select program</option>
              <option value="mbbs">MBBS</option>
              <option value="bds">BDS</option>
              <option value="bsc-nursing">B.Sc Nursing</option>
              <option value="other">Other</option>
            </select>
          </div>
        </div>
        <div class="mb-8">
          <label class="form-label text-sm font-medium text-[#111827] mb-2 block">Budget Range (per year)</label>
          <select class="w-full px-4 py-3 border border-[#e5e7eb] rounded-lg focus:outline-none focus:border-[#be1e2d] focus:ring-1 focus:ring-[#be1e2d] transition-all bg-white">
            <option value="">Select budget range</option>
            <option value="govt">Govt College (₹10K-1L/year)</option>
            <option value="private-low">Private (₹5-10L/year)</option>
            <option value="private-high">Private (₹10-25L/year)</option>
            <option value="nri">NRI Quota ($20K-50K/year)</option>
          </select>
        </div>
        <button type="submit" class="w-full py-5 bg-[#be1e2d] text-white font-semibold tracking-wide hover:shadow-[0_0_40px_rgba(190,30,45,0.25)] transition-all duration-300 flex items-center justify-center gap-3">
          Get Counselling Support
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </button>
        <p class="text-xs text-center text-[#6b7280] mt-6">
          We only provide guidance through official counselling. No direct admissions.
        </p>
      </form>
    </div>
  </div>
</section>
<!-- MOBILE STICKY CTA -->
<div class="fixed bottom-0 left-0 right-0 bg-white border-t border-[#e5e7eb] p-4 lg:hidden z-50">
  <div class="flex gap-3">
    <button onclick="document.getElementById('lead-form-container')?.scrollIntoView({ behavior: 'smooth', block: 'center' })" class="flex-1 py-3 bg-[#be1e2d] text-white font-semibold text-center">
      Get Guidance
    </button>
  </div>
</div>
<Footer />
<script>
document.getElementById('lead-form')?.addEventListener('submit', async (e) => {
  e.preventDefault();
  const btn = e.target.querySelector('button[type="submit"]');
  btn.innerHTML = `
    <svg class="animate-spin" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12a9 9 0 11-6.219-8.56"/></svg>
    SUBMITTING...
  `;
  btn.disabled = true;

  const name = e.target.querySelector('input[type="text"]').value.trim();
  const phone = e.target.querySelector('input[type="tel"]').value.trim();
  const neetScore = e.target.querySelectorAll('input')[2]?.value.trim() || '';

  // Ensure phone has country code
  let formattedPhone = phone;
  if (!formattedPhone.startsWith('+')) {
    formattedPhone = '+91' + formattedPhone.replace(/^0+/, '');
  }

  const payload = {
    fields: {
      name: name,
      phone: formattedPhone,
      lead_source: 'Google Ads',
      facebook_campaign_name: 'MBBS Abroad - India Medical',
    }
  };

  const extraInfo = [];
  if (neetScore) extraInfo.push('NEET Score: ' + neetScore);
  const state = e.target.querySelector('select')?.value;
  if (state) extraInfo.push('State: ' + state);
  const program = e.target.querySelectorAll('select')[1]?.value;
  if (program) extraInfo.push('Program: ' + program);
  const budget = e.target.querySelectorAll('select')[2]?.value;
  if (budget) extraInfo.push('Budget: ' + budget);
  if (extraInfo.length > 0) {
    payload.fields.notes = extraInfo.join(' | ');
  }

  try {
    const response = await fetch(
      'https://next-api.telecrm.in/enterprise/69a16e9a4ce16643f28061a1/autoupdatelead',
      {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Authorization': 'Bearer bc0b7478-97ce-49b2-b96c-13ef444898311775379897519:***',
        },
        body: JSON.stringify(payload),
      }
    );
    if (!response.ok) {
      console.error('TeleCRM error:', response.status, await response.text());
    }
  } catch (err) {
    console.error('TeleCRM fetch error:', err);
  }

  btn.innerHTML = `
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
    REDIRECTING...
  `;
  btn.style.backgroundColor = '#22c55e';
  setTimeout(() => {
    window.location.href = '/mbbs-thank-you';
  }, 800);
});
</script>
</MainLayout>