---
import MainLayout from '../layouts/MainLayout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
const title = "BSc Nursing in Albania 2026 | No NEET | Affordable Europe | Gradiks";
const description = "BSc Nursing in Albania for Indian students. Most affordable European nursing degree. $2.8–4.5K/year tuition, English medium, Sep & Jan intake. Get free cost breakdown.";
const COUNTRY = "Albania";
const COUNTRY_EMOJI = "🇦🇱";
const CRM_CAMPAIGN = "Nursing Abroad - Albania";
const FORM_TYPE = "nursing-albania";
---

<style>
  .nurs-hero-img-wrap {
    position: relative;
    border-radius: 28px;
    overflow: hidden;
    height: 480px;
    transform: rotate(-1.5deg);
    box-shadow: 0 40px 100px rgba(0,0,0,0.5), 0 0 0 1px rgba(255,255,255,0.12);
  }
  .nurs-hero-img-wrap img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .nurs-hero-img-wrap::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 40%, rgba(2,8,23,0.72));
    pointer-events: none;
  }
  .nurs-data-card {
    position: absolute;
    bottom: 36px;
    left: -32px;
    width: 220px;
    background: rgba(255,255,255,0.94);
    border-radius: 20px;
    padding: 1.125rem 1.375rem;
    box-shadow: 0 24px 60px rgba(0,0,0,0.22);
    backdrop-filter: blur(16px);
    color: #0d1829;
    z-index: 4;
  }
  .nurs-data-row { display: flex; justify-content: space-between; align-items: baseline; font-size: 0.8125rem; padding: 0.25rem 0; }
  .nurs-data-label { color: #6b7280; }
  .nurs-data-val { font-weight: 700; color: #0d1829; }
  .why-num { font-family: var(--font-display); font-size: 3rem; font-weight: 300; color: rgba(255,255,255,0.12); line-height: 1; margin-bottom: 0.75rem; transition: color 0.4s; }
  .why-block:hover .why-num { color: var(--color-brand-red); }
  .why-block { padding: 2rem 2.25rem; border: 1px solid rgba(255,255,255,0.08); transition: background 0.3s; }
  .why-block:hover { background: rgba(255,255,255,0.04); }
  @media (max-width: 1023px) {
    .nurs-hero-img-wrap { height: 260px; transform: none; border-radius: 20px; }
    .nurs-data-card { display: none; }
  }
</style>

<MainLayout title={title} description={description}>
<Navigation />

<!-- HERO -->
<section class="country-hero-section mbbs-hero-premium mbbs-hero-has-proof-card relative overflow-hidden" style="padding-block: clamp(4rem, 8vw, 6rem);">
  <div class="gradient-spotlight gradient-spotlight-1" style="top: -15%; right: 0; width: 900px; height: 900px;"></div>
  <div class="gradient-spotlight gradient-spotlight-2" style="bottom: -20%; left: -10%; width: 600px; height: 600px;"></div>

  <div class="max-w-[1400px] mx-auto px-6 lg:px-12 relative z-10">
    <div>
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full mb-6 text-xs font-semibold tracking-wide animate-fade-in-up delay-100" style="background: rgba(255,255,255,0.09); border: 1px solid rgba(255,255,255,0.16); color: rgba(255,255,255,0.8);">
        {COUNTRY_EMOJI} BSc Nursing in {COUNTRY} — 2026 Intake
      </div>
      <h1 class="hero-headline animate-fade-in-up delay-200" style="color: #fafaf9;">
        BSc Nursing<br>
        <span style="color: var(--color-accent-gold);">in {COUNTRY} {COUNTRY_EMOJI}</span>
      </h1>
      <p class="hero-subheadline animate-fade-in-up delay-300" style="color: rgba(255,255,255,0.72); max-width: 520px;">
        Most affordable European nursing degree. English-taught, growing Indian community. Entry point to EU healthcare careers.
      </p>

      <div class="hidden lg:flex items-center gap-4 mt-8 animate-fade-in-up delay-400">
        <button onclick="document.getElementById('lead-form-container')?.scrollIntoView({behavior:'smooth',block:'center'})" class="cta-primary" style="background: var(--color-brand-red);">
          Get Free Cost Breakdown
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </button>
      </div>

      <div class="lg:hidden mt-6 animate-fade-in-up delay-300">
        <div class="bg-white/[0.07] border border-white/10 rounded-2xl p-5">
          <form id="hero-lead-form" class="space-y-3">
            <input type="text" name="name" required class="w-full px-4 py-3 bg-white/10 border border-white/20 text-white placeholder-white/40 text-sm rounded-xl" placeholder="Full Name">
            <input type="tel" name="phone" required class="w-full px-4 py-3 bg-white/10 border border-white/20 text-white placeholder-white/40 text-sm rounded-xl" placeholder="WhatsApp Number">
            <input type="email" name="email" required class="w-full px-4 py-3 bg-white/10 border border-white/20 text-white placeholder-white/40 text-sm rounded-xl" placeholder="Email">
            <button type="submit" class="w-full py-4 text-white font-semibold text-sm rounded-xl" style="background: var(--color-brand-red);">Get Free Cost Breakdown</button>
            <p class="text-center text-[11px]" style="color: rgba(255,255,255,0.3);">Free · No spam · 24hr response</p>
          </form>
        </div>
      </div>

      <div class="mt-8 flex flex-wrap gap-x-6 gap-y-2 text-xs animate-fade-in-up delay-400" style="color: rgba(255,255,255,0.5);">
        <span>No NEET required</span>
        <span style="color: rgba(255,255,255,0.2);">·</span>
        <span>English medium</span>
        <span style="color: rgba(255,255,255,0.2);">·</span>
        <span>4-year BSc</span>
        <span style="color: rgba(255,255,255,0.2);">·</span>
        <span>$2.8–4.5K/yr tuition</span>
        <span style="color: rgba(255,255,255,0.2);">·</span>
        <span>INC pathway reviewed</span>
      </div>
    </div>

    <div class="hidden lg:block relative">
      <div class="nurs-hero-img-wrap">
        <img src="https://images.unsplash.com/photo-1524231757912-21f4fe3a7200?w=900&q=85&auto=format&fit=crop" alt="Tirana, Albania" loading="eager" />
      </div>
      <div class="nurs-data-card">
        <div style="font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.2em; color: #9ca3af; margin-bottom: 0.875rem;">Albania 2026</div>
        <div class="nurs-data-row"><span class="nurs-data-label">Tuition/yr</span><span class="nurs-data-val">$2.8–4.5K</span></div>
        <div class="nurs-data-row"><span class="nurs-data-label">Living/mo</span><span class="nurs-data-val">₹10–15K</span></div>
        <div class="nurs-data-row"><span class="nurs-data-label">Duration</span><span class="nurs-data-val">4 Years</span></div>
        <div class="nurs-data-row"><span class="nurs-data-label">Intake</span><span class="nurs-data-val">Sep & Jan</span></div>
      </div>
    </div>
  </div>
</section>

<!-- MARQUEE BAR -->
<section style="background: var(--color-brand-navy); border-top: 1px solid rgba(255,255,255,0.06);">
  <div class="trust-ticker-track" style="padding: 0.875rem 0; color: rgba(255,255,255,0.55); font-size: 0.8125rem;">
    <span class="flex items-center gap-2"><span class="font-display font-bold text-white text-sm">4-Year</span> BSc Nursing</span>
    <span style="color: rgba(255,255,255,0.12); margin: 0 1.5rem;">|</span>
    <span class="flex items-center gap-2"><span class="font-display font-bold text-white text-sm">$2.8–4.5K/yr</span> Tuition</span>
    <span style="color: rgba(255,255,255,0.12); margin: 0 1.5rem;">|</span>
    <span class="flex items-center gap-2"><span class="font-display font-bold text-white text-sm">Sep & Jan</span> Intakes</span>
    <span style="color: rgba(255,255,255,0.12); margin: 0 1.5rem;">|</span>
    <span class="flex items-center gap-2"><span class="font-display font-bold text-white text-sm">No NEET</span> Required</span>
    <span style="color: rgba(255,255,255,0.12); margin: 0 1.5rem;">|</span>
    <span class="flex items-center gap-2"><span class="font-display font-bold text-white text-sm">Most Affordable</span> EU Nursing</span>
    <span style="color: rgba(255,255,255,0.12); margin: 0 1.5rem;">|</span>
    <span class="flex items-center gap-2"><span class="font-display font-bold text-white text-sm">4-Year</span> BSc Nursing</span>
    <span style="color: rgba(255,255,255,0.12); margin: 0 1.5rem;">|</span>
    <span class="flex items-center gap-2"><span class="font-display font-bold text-white text-sm">$2.8–4.5K/yr</span> Tuition</span>
    <span style="color: rgba(255,255,255,0.12); margin: 0 1.5rem;">|</span>
    <span class="flex items-center gap-2"><span class="font-display font-bold text-white text-sm">Sep & Jan</span> Intakes</span>
    <span style="color: rgba(255,255,255,0.12); margin: 0 1.5rem;">|</span>
    <span class="flex items-center gap-2"><span class="font-display font-bold text-white text-sm">No NEET</span> Required</span>
    <span style="color: rgba(255,255,255,0.12); margin: 0 1.5rem;">|</span>
    <span class="flex items-center gap-2"><span class="font-display font-bold text-white text-sm">Most Affordable</span> EU Nursing</span>
  </div>
</section>

<!-- STATS -->
<section class="py-12 lg:py-16 border-b" style="background: #fafaf9; border-color: #e5e7eb;">
  <div class="max-w-[1400px] mx-auto px-6 lg:px-12">
    <div class="grid grid-cols-2 md:grid-cols-5 gap-6 text-center reveal">
      <div>
        <div class="text-2xl lg:text-3xl font-semibold mb-1" style="font-family: var(--font-display); color: var(--color-text-primary);">4 Years</div>
        <div class="text-xs uppercase tracking-wider" style="color: var(--color-text-muted);">Duration</div>
      </div>
      <div>
        <div class="text-2xl lg:text-3xl font-semibold mb-1" style="font-family: var(--font-display); color: var(--color-text-primary);">$2.8–4.5K</div>
        <div class="text-xs uppercase tracking-wider" style="color: var(--color-text-muted);">Tuition/yr</div>
      </div>
      <div>
        <div class="text-2xl lg:text-3xl font-semibold mb-1" style="font-family: var(--font-display); color: var(--color-text-primary);">₹10–15K</div>
        <div class="text-xs uppercase tracking-wider" style="color: var(--color-text-muted);">Living/mo</div>
      </div>
      <div>
        <div class="text-2xl lg:text-3xl font-semibold mb-1" style="font-family: var(--font-display); color: var(--color-brand-red);">Sep & Jan</div>
        <div class="text-xs uppercase tracking-wider" style="color: var(--color-text-muted);">Intakes</div>
      </div>
      <div>
        <div class="text-2xl lg:text-3xl font-semibold mb-1" style="font-family: var(--font-display); color: var(--color-text-primary);">₹8–10L</div>
        <div class="text-xs uppercase tracking-wider" style="color: var(--color-text-muted);">Total 4-yr cost</div>
      </div>
    </div>
  </div>
</section>

<!-- WHY -->
<section class="country-why-section py-20 lg:py-28">
  <div class="max-w-[1400px] mx-auto px-6 lg:px-12">
    <div class="max-w-2xl mb-16 reveal">
      <p class="section-eyebrow inverted mb-3">Why Albania</p>
      <h2 class="section-headline inverted">Six reasons students<br>choose Albania for nursing</h2>
    </div>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-px" style="border: 1px solid rgba(255,255,255,0.08);">
      <div class="why-block reveal">
        <div class="why-num">01</div>
        <h3 class="text-lg font-semibold text-white mb-2" style="font-family: var(--font-display);">Lowest Tuition in Europe</h3>
        <p class="text-sm" style="color: rgba(255,255,255,0.6); line-height: 1.7;">At $2,800–4,500/yr, Albania offers the most affordable European BSc Nursing degree available. 4-year all-in total under ₹10L.</p>
      </div>
      <div class="why-block reveal reveal-delay-1">
        <div class="why-num">02</div>
        <h3 class="text-lg font-semibold text-white mb-2" style="font-family: var(--font-display);">No NEET Required</h3>
        <p class="text-sm" style="color: rgba(255,255,255,0.6); line-height: 1.7;">Your 12th PCB percentage is the only academic requirement. A single entrance exam result doesn't close this door.</p>
      </div>
      <div class="why-block reveal reveal-delay-2">
        <div class="why-num">03</div>
        <h3 class="text-lg font-semibold text-white mb-2" style="font-family: var(--font-display);">European Degree</h3>
        <p class="text-sm" style="color: rgba(255,255,255,0.6); line-height: 1.7;">Albanian nursing degrees meet European standards. WHO-recognized programs with direct pathways to UK, UAE, and Gulf licensing.</p>
      </div>
      <div class="why-block reveal">
        <div class="why-num">04</div>
        <h3 class="text-lg font-semibold text-white mb-2" style="font-family: var(--font-display);">English Medium Only</h3>
        <p class="text-sm" style="color: rgba(255,255,255,0.6); line-height: 1.7;">Every program we recommend is fully English-taught. No foreign language requirement during the degree.</p>
      </div>
      <div class="why-block reveal reveal-delay-1">
        <div class="why-num">05</div>
        <h3 class="text-lg font-semibold text-white mb-2" style="font-family: var(--font-display);">Safe, Growing Destination</h3>
        <p class="text-sm" style="color: rgba(255,255,255,0.6); line-height: 1.7;">Tirana is one of Europe's fastest-growing cities. Indian student community is expanding year on year. Mediterranean climate.</p>
      </div>
      <div class="why-block reveal reveal-delay-2">
        <div class="why-num">06</div>
        <h3 class="text-lg font-semibold text-white mb-2" style="font-family: var(--font-display);">INC Registration Pathway</h3>
        <p class="text-sm" style="color: rgba(255,255,255,0.6); line-height: 1.7;">We review each Albanian nursing program against INC requirements before counselling. Full picture upfront — not after you've committed.</p>
      </div>
    </div>
    <div class="mt-10 text-center reveal">
      <button onclick="document.getElementById('lead-form-container')?.scrollIntoView({behavior:'smooth',block:'center'})" class="cta-primary" style="background: var(--color-brand-red);">
        See If Albania Fits Your Profile — Free
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </button>
    </div>
  </div>
</section>

<!-- FEE TABLE -->
<section class="py-20 lg:py-28" style="background: #fafaf9;">
  <div class="max-w-[1400px] mx-auto px-6 lg:px-12">
    <div class="max-w-3xl mx-auto">
      <div class="mb-12 reveal">
        <p class="section-eyebrow mb-2">Exact Numbers</p>
        <h2 class="section-headline" style="font-size: clamp(1.75rem, 4vw, 2.75rem);">Albania Nursing — Cost Breakdown</h2>
        <p class="section-desc mt-3">These are real numbers. Ask us for the document-level breakdown.</p>
      </div>
      <div class="overflow-x-auto reveal reveal-delay-1">
        <table class="w-full text-left" style="border-collapse: collapse;">
          <thead>
            <tr style="border-bottom: 2px solid var(--color-brand-red);">
              <th class="py-3 px-4 text-sm font-semibold" style="color: var(--color-text-primary);">University</th>
              <th class="py-3 px-4 text-sm font-semibold" style="color: var(--color-text-secondary);">Tuition/yr</th>
              <th class="py-3 px-4 text-sm font-semibold" style="color: var(--color-text-secondary);">Recognition</th>
              <th class="py-3 px-4 text-sm font-semibold" style="color: var(--color-text-secondary);">Intake</th>
            </tr>
          </thead>
          <tbody>
            <tr style="border-bottom: 1px solid #e5e7eb;">
              <td class="py-4 px-4 text-sm font-semibold" style="color: var(--color-text-primary);">University of Tirana</td>
              <td class="py-4 px-4 text-sm font-bold" style="color: var(--color-brand-red);">$2,800</td>
              <td class="py-4 px-4 text-sm" style="color: var(--color-text-secondary);">WHO recognized</td>
              <td class="py-4 px-4 text-sm" style="color: var(--color-text-secondary);">Sep</td>
            </tr>
            <tr>
              <td class="py-4 px-4 text-sm font-semibold" style="color: var(--color-text-primary);">Albanian University</td>
              <td class="py-4 px-4 text-sm font-bold" style="color: var(--color-brand-red);">$3,500</td>
              <td class="py-4 px-4 text-sm" style="color: var(--color-text-secondary);">WHO recognized</td>
              <td class="py-4 px-4 text-sm" style="color: var(--color-text-secondary);">Sep & Jan</td>
            </tr>
          </tbody>
        </table>
      </div>
      <div class="mt-6 p-4 rounded-xl border reveal reveal-delay-2" style="border-color: rgba(5,150,105,0.2); background: rgba(5,150,105,0.04);">
        <p class="text-sm" style="color: var(--color-success);">Yearly living cost (hostel + food + transport): ₹10,000–15,000/mo. Total 4-year all-in: ₹8–10L.</p>
      </div>
    </div>
  </div>
</section>

<!-- TESTIMONIALS -->
<section class="py-20 lg:py-28" style="background: var(--color-brand-navy);">
  <div class="max-w-[1400px] mx-auto px-6 lg:px-12">
    <div class="mb-12 reveal">
      <p class="section-eyebrow inverted mb-2">Real Students</p>
      <h2 class="section-headline inverted">Outcomes we discuss clearly</h2>
    </div>
    <div class="grid md:grid-cols-3 gap-6 reveal reveal-delay-1">
      <div class="testimonial-card" style="background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1);">
        <div class="testimonial-person">
          <div class="person-avatar" style="background: var(--color-brand-red); color: #fff;">R</div>
          <div class="person-info">
            <div class="person-name" style="color: #fafaf9;">Rahul <span class="person-loc">Kozhikode</span></div>
            <div class="person-detail">BSc Nursing, Albania · 2024</div>
          </div>
        </div>
        <p class="testimonial-quote" style="color: rgba(255,255,255,0.72);">"Gradiks told me Albania was my best option given my 12th marks. I didn't believe it at first. Now I'm working in a UAE hospital, building an international nursing career."</p>
        <div class="testimonial-outcome">UAE hospital — AED 4,800/mo</div>
      </div>
      <div class="testimonial-card" style="background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1);">
        <div class="testimonial-person">
          <div class="person-avatar" style="background: var(--color-brand-red); color: #fff;">A</div>
          <div class="person-info">
            <div class="person-name" style="color: #fafaf9;">Aishwarya <span class="person-loc">Kochi</span></div>
            <div class="person-detail">BSc Nursing, Albania · 2023</div>
          </div>
        </div>
        <p class="testimonial-quote" style="color: rgba(255,255,255,0.72);">"I scored 58% in 12th. Every consultant said try again. Gradiks found me a European-degree university in Albania. Graduated without a loan."</p>
        <div class="testimonial-outcome">Apollo Hospital, Chennai</div>
      </div>
      <div class="testimonial-card" style="background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1);">
        <div class="testimonial-person">
          <div class="person-avatar" style="background: var(--color-brand-red); color: #fff;">M</div>
          <div class="person-info">
            <div class="person-name" style="color: #fafaf9;">Muhammed <span class="person-loc">Malappuram</span></div>
            <div class="person-detail">BSc Nursing, Albania · 2022</div>
          </div>
        </div>
        <p class="testimonial-quote" style="color: rgba(255,255,255,0.72);">"Gradiks explained the full cost and the INC registration process before I applied. No surprises. The total came out exactly as they said."</p>
        <div class="testimonial-outcome">NHS Manchester — £28K/yr</div>
      </div>
    </div>
  </div>
</section>

<!-- ELIGIBILITY + CAREER -->
<section class="py-20 lg:py-28" style="background: #fafaf9;">
  <div class="max-w-[1400px] mx-auto px-6 lg:px-12">
    <div class="grid lg:grid-cols-2 gap-16">
      <div class="reveal">
        <p class="section-eyebrow mb-3">Requirements</p>
        <h2 class="text-4xl font-semibold tracking-tight mb-6" style="font-family: var(--font-display);">Are you eligible?</h2>
        <p class="text-sm mb-8" style="color: var(--color-text-secondary); line-height: 1.7;">BSc Nursing in Albania has straightforward criteria. No competitive entrance exams.</p>
        <ul class="space-y-4 mb-8">
          <li class="flex gap-3 items-start text-sm" style="color: var(--color-text-secondary);">
            <span class="flex-shrink-0 w-5 h-5 rounded-full flex items-center justify-center text-xs font-bold mt-0.5" style="background: rgba(5,150,105,0.12); color: var(--color-success);">✓</span>
            10+2 with Physics, Chemistry, Biology (PCB)
          </li>
          <li class="flex gap-3 items-start text-sm" style="color: var(--color-text-secondary);">
            <span class="flex-shrink-0 w-5 h-5 rounded-full flex items-center justify-center text-xs font-bold mt-0.5" style="background: rgba(5,150,105,0.12); color: var(--color-success);">✓</span>
            Minimum 45–50% aggregate in PCB
          </li>
          <li class="flex gap-3 items-start text-sm" style="color: var(--color-text-secondary);">
            <span class="flex-shrink-0 w-5 h-5 rounded-full flex items-center justify-center text-xs font-bold mt-0.5" style="background: rgba(5,150,105,0.12); color: var(--color-success);">✓</span>
            <strong>NEET not required</strong> for BSc Nursing admissions abroad
          </li>
          <li class="flex gap-3 items-start text-sm" style="color: var(--color-text-secondary);">
            <span class="flex-shrink-0 w-5 h-5 rounded-full flex items-center justify-center text-xs font-bold mt-0.5" style="background: rgba(5,150,105,0.12); color: var(--color-success);">✓</span>
            Valid Indian passport
          </li>
        </ul>
        <div class="p-4 rounded-xl border" style="border-color: #e5e7eb; background: #f5f5f7;">
          <p class="text-sm" style="color: var(--color-text-secondary);">
            <strong style="color: var(--color-text-primary);">Not sure about your score?</strong> Tell us your 12th % below. We'll tell you exactly which universities you qualify for — free.
          </p>
        </div>
