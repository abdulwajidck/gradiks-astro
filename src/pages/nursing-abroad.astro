---
import MainLayout from '../layouts/MainLayout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
const title = "BSc Nursing Abroad 2026 | No NEET | Top Countries | Gradiks";
const description = "BSc Nursing abroad for Indian students. Georgia, Albania, Bulgaria, Malta, UK. No NEET required. English medium. Admissions open for 2026 batch. Get free cost breakdown.";
---

<MainLayout title={title} description={description}>
<Navigation />

<!-- TRUST BAR — Quick credibility metrics with India vs Abroad comparison -->
<div class="bg-[#232d61] text-white py-3 mt-20 lg:mt-24">
  <div class="max-w-[1400px] mx-auto px-6 lg:px-12">
    <div class="flex flex-wrap justify-center gap-6 lg:gap-12 text-sm">
      <div class="flex items-center gap-2">
        <span class="text-[#be1e2d] font-bold">350+</span>
        <span class="text-white/80">Students Placed</span>
      </div>
      <div class="flex items-center gap-2">
        <span class="text-[#be1e2d] font-bold">100%</span>
        <span class="text-white/80">Visa Success Rate</span>
      </div>
      <div class="flex items-center gap-2">
        <span class="text-white/50 line-through text-xs self-center">₹12K/mo India</span>
        <span class="text-[#059669] font-bold">₹80K/mo Abroad</span>
        <span class="text-white/80 text-xs">6x Salary</span>
      </div>
      <div class="hidden md:flex items-center gap-2">
        <span class="text-[#be1e2d] font-bold">5</span>
        <span class="text-white/80">Countries</span>
      </div>
      <div class="hidden lg:flex items-center gap-2">
        <span class="text-[#be1e2d] font-bold">Since 2015</span>
        <span class="text-white/80">10+ Years</span>
      </div>
    </div>
  </div>
</div>

<!-- HERO SECTION — Editorial split layout with asymmetric photo placement -->
<section class="min-h-screen flex items-center relative overflow-hidden pt-24 pb-16">
  <!-- Background accent strip -->
  <div class="absolute top-0 right-0 w-1/2 h-full bg-gradient-to-l from-[#be1e2d]/5 via-transparent to-transparent"></div>
  
  <!-- Floating geometric accents -->
  <div class="absolute top-32 right-[45%] w-20 h-20 border border-[#be1e2d]/20 rotate-45 animate-pulse"></div>
  <div class="absolute bottom-40 right-[38%] w-32 h-32 border border-[#be1e2d]/10 rotate-12"></div>
  <div class="absolute top-1/4 right-[52%] w-4 h-4 bg-[#be1e2d]/30 rounded-full"></div>
  
  <div class="max-w-[1400px] mx-auto px-6 lg:px-12 py-20 relative z-10 w-full">
    <div class="grid lg:grid-cols-12 gap-8 lg:gap-4 items-center">
      
      <!-- Left content column -->
      <div class="lg:col-span-7 relative">
        
        <!-- Urgency badge with accent -->
        <div class="inline-flex items-center gap-3 mb-8 animate-fade-in-up">
          <div class="flex items-center gap-2 px-4 py-2 bg-[#be1e2d] text-white">
            <span class="w-2 h-2 bg-white rounded-full animate-pulse"></span>
            <span class="text-xs font-semibold tracking-[0.2em] uppercase">Admissions Open 2026</span>
          </div>
          <div class="hidden sm:block w-16 h-px bg-[#d1d5db]"></div>
          <div class="hidden md:flex items-center gap-2 px-4 py-2 bg-[#232d61] text-white">
            <span class="text-xs font-semibold tracking-[0.1em]">Only 18 Seats Left</span>
          </div>
        </div>

        <!-- Headline stack — editorial style -->
        <div class="mb-8 animate-fade-in-up delay-100">
          <p class="text-xs tracking-[0.4em] uppercase text-[#be1e2d] mb-4 font-medium">For Indian Science Students</p>
          <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold leading-[0.88] tracking-tight" style="font-family: var(--font-display);">
            BSc NURSING
          </h1>
          <h1 class="text-6xl md:text-7xl lg:text-8xl font-bold leading-[0.88] tracking-tight -mt-2" style="font-family: var(--font-display);">
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#be1e2d] to-[#dc2626]">ABROAD</span>
          </h1>
        </div>

        <!-- Subheadline -->
        <p class="text-lg md:text-xl text-[#4b5563] max-w-xl leading-relaxed mb-10 animate-fade-in-up delay-200">
          Stop accepting ₹12K/month in India. BSc Nursing abroad pays ₹80K–₹2L/month after graduation — with the respect you deserve. No NEET required. Only your 12th marks needed.
        </p>

        <!-- Stats row — horizontal on desktop -->
        <div class="flex flex-wrap gap-6 lg:gap-10 mb-10 animate-fade-in-up delay-300">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-[#be1e2d]/10 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#be1e2d" stroke-width="2"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>
            </div>
            <div>
              <div class="text-xl font-semibold text-[#111827]" style="font-family: var(--font-display);">NMC Recognized</div>
              <div class="text-xs text-[#6b7280]">All universities</div>
            </div>
          </div>
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-[#be1e2d]/10 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#be1e2d" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
            </div>
            <div>
              <div class="text-xl font-semibold text-[#111827]" style="font-family: var(--font-display);">5 Countries</div>
              <div class="text-xs text-[#6b7280]">Georgia · Albania · Bulgaria · Malta · UK</div>
            </div>
          </div>
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-[#be1e2d]/10 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#be1e2d" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
            </div>
            <div>
              <div class="text-xl font-semibold text-[#111827]" style="font-family: var(--font-display);">From ₹4L/yr</div>
              <div class="text-xs text-[#6b7280]">Tuition + living</div>
            </div>
          </div>
        </div>

        <!-- Dual CTA -->
        <div class="flex flex-col sm:flex-row gap-4 animate-fade-in-up delay-400">
          <button onclick="document.getElementById('lead-form-container')?.scrollIntoView({ behavior: 'smooth', block: 'center' })" class="group relative px-8 py-4 bg-[#be1e2d] text-white font-semibold tracking-wide overflow-hidden transition-all duration-300 hover:shadow-[0_0_50px_rgba(190,30,45,0.35)]">
            <span class="relative z-10 flex items-center justify-center gap-2">
              GET FREE COST BREAKDOWN
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-1"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </span>
          </button>
          <a href="tel:+919****3210" class="group px-8 py-4 border-2 border-[#111827] text-[#111827] font-semibold tracking-wide flex items-center justify-center gap-3 hover:bg-[#111827] hover:text-white transition-all duration-300">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            CALL EXPERT — FREE
          </a>
        </div>

        <!-- Trust line -->
        <p class="text-sm text-[#9ca3af] mt-8 animate-fade-in-up delay-500">
          ✓ 350+ students placed &nbsp;|&nbsp; ✓ No NEET required &nbsp;|&nbsp; ✓ English medium &nbsp;|&nbsp; ✓ 2026 batch open
        </p>
      </div>

      <!-- Right photo column — asymmetric overlapping -->
      <div class="lg:col-span-5 relative mt-12 lg:mt-0">
        <!-- Main photo frame with geometric accent -->
        <div class="relative">
          <!-- Red accent bar -->
          <div class="absolute -left-4 top-8 bottom-8 w-1 bg-gradient-to-b from-[#be1e2d] via-[#dc2626] to-transparent"></div>
          
          <!-- Main image -->
          <div class="relative z-10 overflow-hidden">
            <img
              src="https://images.unsplash.com/photo-1559839734-2b71ea197ec2?w=900&q=85&auto=format&fit=crop"
              alt="South Asian female nurse in modern hospital setting"
              class="w-full aspect-[4/5] object-cover object-center"
              loading="eager"
            />
            <!-- Dark gradient overlay at bottom -->
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent"></div>
          </div>
          
          <!-- Floating info card -->
          <div class="absolute -bottom-6 -left-6 sm:-left-10 z-20 bg-white p-5 shadow-2xl border border-[#e5e7eb]">
            <div class="flex items-center gap-3">
              <div class="w-12 h-12 bg-[#059669] flex items-center justify-center text-white text-lg">✓</div>
              <div>
                <div class="text-sm font-semibold text-[#111827]">2026 Batch</div>
                <div class="text-xs text-[#6b7280]">Limited Seats Available</div>
              </div>
            </div>
          </div>
          
          <!-- Decorative corner element -->
          <div class="absolute top-4 right-4 z-20">
            <div class="px-3 py-1.5 bg-[#be1e2d] text-white text-xs font-semibold tracking-wider">NO NEET</div>
          </div>
        </div>
        
        <!-- Country flags floating -->
        <div class="absolute -top-4 -right-4 flex gap-2 z-30">
          <span class="text-2xl">🇬🇪</span>
          <span class="text-2xl">🇦🇱</span>
          <span class="text-2xl">🇧🇬</span>
          <span class="text-2xl">🇲🇹</span>
          <span class="text-2xl">🇬🇧</span>
        </div>
      </div>
      
    </div>
  </div>
</section>

<!-- DESTINATIONS — CRO: 4 country cards with ROI-focused data -->
<section class="py-24 lg:py-32 bg-[#f9fafb] border-y border-[#e5e7eb]">
  <div class="max-w-[1400px] mx-auto px-6 lg:px-12">
    <div class="max-w-3xl mb-16">
      <div class="text-xs tracking-[0.3em] uppercase text-[#be1e2d] mb-4">5 Destinations</div>
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-medium tracking-tight" style="font-family: var(--font-display);">
        STUDY NURSING
        <br />
        <span class="text-[#4b5563]">IN YOUR BUDGET</span>
      </h2>
      <p class="text-lg text-[#4b5563] mt-4">From ₹4L/year budget to ₹20L+ premium — there's a country for every mark sheet and bank balance.</p>
    </div>
    <div class="grid md:grid-cols-2 lg:grid-cols-5 gap-6">

      <!-- Georgia — European Budget -->
      <div class="group bg-[#ffffff] border border-[#e5e7eb] hover:border-[#be1e2d] transition-all duration-500 flex flex-col overflow-hidden">
        <div class="relative h-40 overflow-hidden">
          <img
            src="https://images.unsplash.com/photo-1565008576549-57569a49371d?w=600&q=80&auto=format&fit=crop"
            alt="Tbilisi, Georgia"
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
          <div class="absolute bottom-3 left-3 text-xs tracking-[0.2em] uppercase text-white/90">🇬🇪 Europe</div>
          <div class="absolute top-3 right-3 text-xs bg-[rgba(139,92,246,0.9)] text-white px-2 py-1">EUROPEAN DEGREE</div>
        </div>
        <div class="p-6 flex flex-col flex-grow">
        <h3 class="text-xl font-medium mb-2" style="font-family: var(--font-display);">Georgia</h3>
        <p class="text-xs text-[#4b5563] mb-4 flex-grow">European BSc Nursing degree at Asian cost. Safe country, warm climate, multiple intakes.</p>
        <div class="space-y-1 mb-4 text-xs">
          <div class="flex justify-between">
            <span class="text-[#6b7280]">Duration</span>
            <span class="text-[#111827] font-medium">4 Years</span>
          </div>
          <div class="flex justify-between">
            <span class="text-[#6b7280]">Tuition/yr</span>
            <span class="text-[#be1e2d] font-medium">$3,000–5,500</span>
          </div>
          <div class="flex justify-between">
            <span class="text-[#6b7280]">Living/mo</span>
            <span class="text-[#111827] font-medium">₹8,000–12,000</span>
          </div>
          <div class="flex justify-between pt-1 border-t border-[#e5e7eb]">
            <span class="text-[#6b7280]">Post-Grad Salary</span>
            <span class="text-[#059669] font-medium">€1,200–1,800/mo</span>
          </div>
        </div>
        <div class="pt-2 border-t border-[#e5e7eb] text-xs text-[#6b7280]">Intakes: Feb & Sep</div>
        </div>
      </div>

      <!-- Albania — New Destination -->
      <div class="group bg-[#ffffff] border border-[#e5e7eb] hover:border-[#be1e2d] transition-all duration-500 flex flex-col overflow-hidden">
        <div class="relative h-40 overflow-hidden">
          <img
            src="https://images.unsplash.com/photo-1524231757912-21f4fe3a7200?w=600&q=80&auto=format&fit=crop"
            alt="Skanderbeg Square, Tirana, Albania"
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
          <div class="absolute bottom-3 left-3 text-xs tracking-[0.2em] uppercase text-white/90">🇦🇱 New</div>
          <div class="absolute top-3 right-3 text-xs bg-[rgba(16,185,129,0.9)] text-white px-2 py-1">BUDGET FRIENDLY</div>
        </div>
        <div class="p-6 flex flex-col flex-grow">
        <h3 class="text-xl font-medium mb-2" style="font-family: var(--font-display);">Albania</h3>
        <p class="text-xs text-[#4b5563] mb-4 flex-grow">Affordable European nursing degree. English-taught programs. Growing destination for Indian students.</p>
        <div class="space-y-1 mb-4 text-xs">
          <div class="flex justify-between">
            <span class="text-[#6b7280]">Duration</span>
            <span class="text-[#111827] font-medium">4 Years</span>
          </div>
          <div class="flex justify-between">
            <span class="text-[#6b7280]">Tuition/yr</span>
            <span class="text-[#be1e2d] font-medium">$3,500–6,000</span>
          </div>
          <div class="flex justify-between">
            <span class="text-[#6b7280]">Living/mo</span>
            <span class="text-[#111827] font-medium">₹10,000–15,000</span>
          </div>
          <div class="flex justify-between pt-1 border-t border-[#e5e7eb]">
            <span class="text-[#6b7280]">Post-Grad Salary</span>
            <span class="text-[#059669] font-medium">€1,000–1,500/mo</span>
          </div>
        </div>
        <div class="pt-2 border-t border-[#e5e7eb] text-xs text-[#6b7280]">Intakes: Sep & Jan</div>
        </div>
      </div>

      <!-- Bulgaria — EU Member -->
      <div class="group bg-[#ffffff] border border-[#e5e7eb] hover:border-[#be1e2d] transition-all duration-500 flex flex-col overflow-hidden">
        <div class="relative h-40 overflow-hidden">
          <img
            src="https://images.unsplash.com/photo-1618666012174-83b441c0bc76?w=600&q=80&auto=format&fit=crop"
            alt="Sofia, Bulgaria"
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
          <div class="absolute bottom-3 left-3 text-xs tracking-[0.2em] uppercase text-white/90">🇧🇬 EU Member</div>
          <div class="absolute top-3 right-3 text-xs bg-[rgba(245,158,11,0.9)] text-white px-2 py-1">EU DEGREE</div>
        </div>
        <div class="p-6 flex flex-col flex-grow">
        <h3 class="text-xl font-medium mb-2" style="font-family: var(--font-display);">Bulgaria</h3>
        <p class="text-xs text-[#4b5563] mb-4 flex-grow">EU member state with affordable tuition. Medical universities with English-taught nursing programs.</p>
        <div class="space-y-1 mb-4 text-xs">
          <div class="flex justify-between">
            <span class="text-[#6b7280]">Duration</span>
            <span class="text-[#111827] font-medium">4 Years</span>
          </div>
          <div class="flex justify-between">
            <span class="text-[#6b7280]">Tuition/yr</span>
            <span class="text-[#be1e2d] font-medium">€4,000–7,000</span>
          </div>
          <div class="flex justify-between">
            <span class="text-[#6b7280]">Living/mo</span>
            <span class="text-[#111827] font-medium">₹12,000–18,000</span>
          </div>
          <div class="flex justify-between pt-1 border-t border-[#e5e7eb]">
            <span class="text-[#6b7280]">Post-Grad Salary</span>
            <span class="text-[#059669] font-medium">€1,500–2,300/mo</span>
          </div>
        </div>
        <div class="pt-2 border-t border-[#e5e7eb] text-xs text-[#6b7280]">Intakes: Oct & Mar</div>
        </div>
      </div>

      <!-- Malta — EU Island -->
      <div class="group bg-[#ffffff] border border-[#e5e7eb] hover:border-[#be1e2d] transition-all duration-500 flex flex-col overflow-hidden">
        <div class="relative h-40 overflow-hidden">
          <img
            src="https://images.unsplash.com/photo-1591955506264-3f5a6834570a?w=600&q=80&auto=format&fit=crop"
            alt="Valletta, Malta"
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
          <div class="absolute bottom-3 left-3 text-xs tracking-[0.2em] uppercase text-white/90">🇲🇹 EU Island</div>
          <div class="absolute top-3 right-3 text-xs bg-[rgba(16,185,129,0.9)] text-white px-2 py-1">ENGLISH SPEAKING</div>
        </div>
        <div class="p-6 flex flex-col flex-grow">
        <h3 class="text-xl font-medium mb-2" style="font-family: var(--font-display);">Malta</h3>
        <p class="text-xs text-[#4b5563] mb-4 flex-grow">English-speaking EU island nation. Affordable fees, safe environment. Gateway to European healthcare careers.</p>
        <div class="space-y-1 mb-4 text-xs">
          <div class="flex justify-between">
            <span class="text-[#6b7280]">Duration</span>
            <span class="text-[#111827] font-medium">3–4 Years</span>
          </div>
          <div class="flex justify-between">
            <span class="text-[#6b7280]">Tuition/yr</span>
            <span class="text-[#be1e2d] font-medium">€8,000–12,000</span>
          </div>
          <div class="flex justify-between">
            <span class="text-[#6b7280]">Living/mo</span>
            <span class="text-[#111827] font-medium">₹15,000–20,000</span>
          </div>
          <div class="flex justify-between pt-1 border-t border-[#e5e7eb]">
            <span class="text-[#6b7280]">Post-Grad Salary</span>
            <span class="text-[#059669] font-medium">€1,500–2,500/mo</span>
          </div>
        </div>
        <div class="pt-2 border-t border-[#e5e7eb] text-xs text-[#6b7280]">Intakes: Oct & Feb</div>
        </div>
      </div>

      <!-- UK — Premium -->
      <div class="group bg-[#ffffff] border border-[#e5e7eb] hover:border-[#be1e2d] transition-all duration-500 flex flex-col overflow-hidden">
        <div class="relative h-40 overflow-hidden">
          <img
            src="https://images.unsplash.com/photo-1513635269975-59663e0ac1ad?w=600&q=80&auto=format&fit=crop"
            alt="London, United Kingdom"
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
          <div class="absolute bottom-3 left-3 text-xs tracking-[0.2em] uppercase text-white/90">🇬🇧 Premium</div>
          <div class="absolute top-3 right-3 text-xs bg-[rgba(16,185,129,0.9)] text-white px-2 py-1">HIGH ROI</div>
        </div>
        <div class="p-6 flex flex-col flex-grow">
        <h3 class="text-xl font-medium mb-2" style="font-family: var(--font-display);">United Kingdom</h3>
        <p class="text-xs text-[#4b5563] mb-4 flex-grow">BSc Nursing (Hons) at UK universities. Work 20 hrs/week during studies. Post-study work visa.</p>
        <div class="space-y-1 mb-4 text-xs">
          <div class="flex justify-between">
            <span class="text-[#6b7280]">Duration</span>
            <span class="text-[#111827] font-medium">3 Years</span>
          </div>
          <div class="flex justify-between">
            <span class="text-[#6b7280]">Tuition/yr</span>
            <span class="text-[#be1e2d] font-medium">£12,000–18,000</span>
          </div>
          <div class="flex justify-between">
            <span class="text-[#6b7280]">Living/mo</span>
            <span class="text-[#111827] font-medium">£800–1,200</span>
          </div>
          <div class="flex justify-between pt-1 border-t border-[#e5e7eb]">
            <span class="text-[#6b7280]">Post-Grad Salary</span>
            <span class="text-[#059669] font-medium">£2,100–2,900/mo</span>
          </div>
        </div>
        <div class="pt-2 border-t border-[#e5e7eb] text-xs text-[#6b7280]">Work Rights: ✓ Yes</div>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- WHY STUDY NURSING ABROAD — objection-handling section -->
<section class="py-24 lg:py-32">
