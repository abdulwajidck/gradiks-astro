function formatPhone(p) { p = p.replace(/[\s\-]/g, ''); return p.startsWith('+') ? p : '+91' + p.replace(/^0+/, ''); }
function buildPayload(fields, notes) {
  const payload = { fields: { ...fields, lead_source: 'Google Ads', facebook_campaign_name: CRM_CAMPAIGN } };
  if (notes.length) payload.fields.notes = notes.join(' | ');
  return payload;
}
document.getElementById('lead-form')?.addEventListener('submit', async (e) => {
  e.preventDefault();
  const f = e.target, btn = f.querySelector('button[type="submit"]');
  btn.disabled = true; btn.innerHTML = 'Sending…';
  const name = f.querySelector('[name="name"]').value.trim();
  const phone = formatPhone(f.querySelector('[name="phone"]').value.trim());
  const email = f.querySelector('[name="email"]').value.trim();
  const pcb = f.querySelector('[name="pcb_percent"]').value.trim();
  const country = f.querySelector('[name="preferred_country"]').value;
  const notes = []; if (pcb) notes.push('12th PCB: ' + pcb); if (country) notes.push('Country: ' + country);
  window.__sendToBackend?.({ form_type: FORM_TYPE, name, phone, email, pcb_percentage: pcb, preferred_country: country });
  const done = () => { btn.innerHTML = 'Redirecting…'; btn.style.background = '#22c55e'; setTimeout(() => { window.location.href = '/nursing-thank-you'; }, 500); };
  Promise.race([fetch(TELECRM_URL, { method:'POST', headers:{'Content-Type':'application/json','Authorization':TELECRM_KEY}, body:JSON.stringify(buildPayload({name,phone,email},notes)), keepalive:true }), new Promise(r=>setTimeout(r,1500))]).then(done).catch(done);
});
document.getElementById('hero-lead-form')?.addEventListener('submit', async (e) => {
  e.preventDefault();
  const f = e.target, btn = f.querySelector('button[type="submit"]');
  btn.disabled = true;
