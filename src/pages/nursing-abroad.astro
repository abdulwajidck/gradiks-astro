---
import MainLayout from '../layouts/MainLayout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
const title = "BSc Nursing Abroad 2026 | No NEET | Top Countries | Gradiks";
const description = "BSc Nursing abroad for Indian students. Georgia, Albania, Bulgaria, Malta, UK. No NEET required. English medium. Admissions open for 2026 batch. Get free cost breakdown.";
---

<MainLayout title={title} description={description}>
<Navigation />

<!-- TRUST BAR — Apple-style minimal strip -->
<div class="trust-bar">
  <div class="trust-items">
    <span class="trust-stat">350+</span>
    <span class="trust-label">Students placed</span>
    <span class="trust-divider" aria-hidden="true">·</span>
    <span class="trust-stat">100%</span>
    <span class="trust-label">Visa success</span>
    <span class="trust-divider" aria-hidden="true">·</span>
    <span class="trust-stat accent">₹80K</span>
    <span class="trust-label">vs ₹12K India</span>
    <span class="trust-divider" aria-hidden="true">·</span>
    <span class="trust-stat">5</span>
    <span class="trust-label">Countries</span>
    <span class="trust-divider" aria-hidden="true">·</span>
    <span class="trust-stat">Since 2015</span>
    <span class="trust-label">10+ years</span>
  </div>
</div>

<!-- HERO — Apple-style full-width editorial -->
<section class="hero">
  <div class="hero-content">
    <p class="hero-eyebrow">For Indian Science Students — 2026 Batch</p>
    <h1 class="hero-headline">
      BSc Nursing<br>
      <span class="hero-headline-accent">Abroad</span>
    </h1>
    <p class="hero-subheadline">
      Stop accepting ₹12K/month in India.<br>
      BSc Nursing abroad pays ₹80K–₹2L/month after graduation.
    </p>
    <div class="hero-ctas">
      <button onclick="document.getElementById('lead-form-container')?.scrollIntoView({ behavior: 'smooth', block: 'center' })" class="cta-primary">
        Get free cost breakdown
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </button>
      <a href="tel:+919****3210" class="cta-secondary">Call expert — free</a>
    </div>
    <div class="hero-meta">
      <span>NMC recognized</span>
      <span class="meta-dot" aria-hidden="true">·</span>
      <span>No NEET required</span>
      <span class="meta-dot" aria-hidden="true">·</span>
      <span>English medium</span>
      <span class="meta-dot" aria-hidden="true">·</span>
      <span>5 countries</span>
    </div>
  </div>
  <div class="hero-image-wrapper">
    <img
      src="https://images.unsplash.com/photo-1559839734-2b71ea197ec2?w=900&q=85&auto=format&fit=crop"
      alt="International nurse in modern hospital setting"
      class="hero-image"
      loading="eager"
    />
    <div class="hero-image-overlay">
      <div class="hero-badge">No NEET required</div>
    </div>
    <div class="hero-country-flags">🇬🇪 🇦🇱 🇧🇬 🇲🇹 🇬🇧</div>
  </div>
</section>

<!-- DESTINATIONS — Apple-style clean grid -->
<section class="destinations">
  <div class="section-header">
    <p class="section-eyebrow">5 Destinations</p>
    <h2 class="section-headline">Study Nursing<br>in Your Budget</h2>
    <p class="section-desc">From ₹4L/year budget to ₹20L+ premium — there's a country for every mark sheet and bank balance.</p>
  </div>
  <div class="country-grid">

    <!-- Georgia -->
    <div class="country-card">
      <div class="country-image-wrap">
        <img src="https://images.unsplash.com/photo-1565008576549-57569a49371d?w=600&q=80&auto=format&fit=crop" alt="Tbilisi, Georgia" loading="lazy" />
        <div class="country-overlay">
          <span class="country-flag">🇬🇪</span>
          <span class="country-tag">European Degree</span>
        </div>
      </div>
      <div class="country-body">
        <h3 class="country-name">Georgia</h3>
        <p class="country-desc">European BSc Nursing at Asian cost. Safe country, warm climate, multiple intakes.</p>
        <div class="country-stats">
          <div class="country-stat"><span class="stat-val">4 Years</span><span class="stat-key">Duration</span></div>
          <div class="country-stat"><span class="stat-val">$3–5.5K</span><span class="stat-key">Tuition/yr</span></div>
          <div class="country-stat"><span class="stat-val">₹8–12K</span><span class="stat-key">Living/mo</span></div>
          <div class="country-stat accent"><span class="stat-val">€1.2–1.8K</span><span class="stat-key">Post-grad salary</span></div>
        </div>
        <div class="country-intakes">Intakes: Feb &amp; Sep</div>
      </div>
    </div>

    <!-- Albania -->
    <div class="country-card">
      <div class="country-image-wrap">
        <img src="https://images.unsplash.com/photo-1524231757912-21f4fe3a7200?w=600&q=80&auto=format&fit=crop" alt="Tirana, Albania" loading="lazy" />
        <div class="country-overlay">
          <span class="country-flag">🇦🇱</span>
          <span class="country-tag new">New</span>
        </div>
      </div>
      <div class="country-body">
        <h3 class="country-name">Albania</h3>
        <p class="country-desc">Affordable European nursing degree. English-taught. Growing destination for Indian students.</p>
        <div class="country-stats">
          <div class="country-stat"><span class="stat-val">4 Years</span><span class="stat-key">Duration</span></div>
          <div class="country-stat"><span class="stat-val">$3.5–6K</span><span class="stat-key">Tuition/yr</span></div>
          <div class="country-stat"><span class="stat-val">₹10–15K</span><span class="stat-key">Living/mo</span></div>
          <div class="country-stat accent"><span class="stat-val">€1–1.5K</span><span class="stat-key">Post-grad salary</span></div>
        </div>
        <div class="country-intakes">Intakes: Sep &amp; Jan</div>
      </div>
    </div>

    <!-- Bulgaria -->
    <div class="country-card">
      <div class="country-image-wrap">
        <img src="https://images.unsplash.com/photo-1618666012174-83b441c0bc76?w=600&q=80&auto=format&fit=crop" alt="Sofia, Bulgaria" loading="lazy" />
        <div class="country-overlay">
          <span class="country-flag">🇧🇬</span>
          <span class="country-tag">EU Member</span>
        </div>
      </div>
      <div class="country-body">
        <h3 class="country-name">Bulgaria</h3>
        <p class="country-desc">EU member with affordable tuition. Medical universities with English-taught nursing programs.</p>
        <div class="country-stats">
          <div class="country-stat"><span class="stat-val">4 Years</span><span class="stat-key">Duration</span></div>
          <div class="country-stat"><span class="stat-val">€4–7K</span><span class="stat-key">Tuition/yr</span></div>
          <div class="country-stat"><span class="stat-val">₹12–18K</span><span class="stat-key">Living/mo</span></div>
          <div class="country-stat accent"><span class="stat-val">€1.5–2.3K</span><span class="stat-key">Post-grad salary</span></div>
        </div>
        <div class="country-intakes">Intakes: Oct &amp; Mar</div>
      </div>
    </div>

    <!-- Malta -->
    <div class="country-card">
      <div class="country-image-wrap">
        <img src="https://images.unsplash.com/photo-1591955506264-3f5a6834570a?w=600&q=80&auto=format&fit=crop" alt="Valletta, Malta" loading="lazy" />
        <div class="country-overlay">
          <span class="country-flag">🇲🇹</span>
          <span class="country-tag">English Speaking</span>
        </div>
      </div>
      <div class="country-body">
        <h3 class="country-name">Malta</h3>
        <p class="country-desc">English-speaking EU island. Affordable fees, safe environment. Gateway to European healthcare.</p>
        <div class="country-stats">
          <div class="country-stat"><span class="stat-val">3–4 Years</span><span class="stat-key">Duration</span></div>
          <div class="country-stat"><span class="stat-val">€8–12K</span><span class="stat-key">Tuition/yr</span></div>
          <div class="country-stat"><span class="stat-val">₹15–20K</span><span class="stat-key">Living/mo</span></div>
          <div class="country-stat accent"><span class="stat-val">€1.5–2.5K</span><span class="stat-key">Post-grad salary</span></div>
        </div>
        <div class="country-intakes">Intakes: Oct &amp; Feb</div>
      </div>
    </div>

    <!-- UK -->
    <div class="country-card">
      <div class="country-image-wrap">
        <img src="https://images.unsplash.com/photo-1513635269975-59663e0ac1ad?w=600&q=80&auto=format&fit=crop" alt="London, United Kingdom" loading="lazy" />
        <div class="country-overlay">
          <span class="country-flag">🇬🇧</span>
          <span class="country-tag">High ROI</span>
        </div>
      </div>
      <div class="country-body">
        <h3 class="country-name">United Kingdom</h3>
        <p class="country-desc">BSc Nursing (Hons) at UK universities. Work 20 hrs/week during studies. Post-study work visa.</p>
        <div class="country-stats">
          <div class="country-stat"><span class="stat-val">3 Years</span><span class="stat-key">Duration</span></div>
          <div class="country-stat"><span class="stat-val">£12–18K</span><span class="stat-key">Tuition/yr</span></div>
          <div class="country-stat"><span class="stat-val">£800–1.2K</span><span class="stat-key">Living/mo</span></div>
          <div class="country-stat accent"><span class="stat-val">£2.1–2.9K</span><span class="stat-key">Post-grad salary</span></div>
        </div>
        <div class="country-intakes">Work Rights: ✓ Yes</div>
      </div>
    </div>

  </div>
</section>

<!-- WHY SECTION — Apple-style clean dark section -->
<section class="why-section">
  <div class="why-header">
    <p class="section-eyebrow inverted">Why BSc Nursing Abroad</p>
    <h2 class="section-headline inverted">The Real Answer<br>to Your Problem</h2>
  </div>
  <div class="why-grid">

    <div class="why-card">
      <div class="why-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
      </div>
      <h3 class="why-title">No NEET Required</h3>
      <p class="why-desc">Unlike MBBS, BSc Nursing abroad doesn't need NEET. Your 12th PCB percentage is what matters — not a single exam result that went wrong.</p>
    </div>

    <div class="why-card">
      <div class="why-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
      </div>
      <h3 class="why-title">English Medium Only</h3>
      <p class="why-desc">Every program we recommend is fully English-taught. No foreign language requirement. Indian students adapt faster, academically and socially.</p>
    </div>

    <div class="why-card">
      <div class="why-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
      </div>
      <h3 class="why-title">Work While Studying</h3>
      <p class="why-desc">UK allows 20 hrs/week part-time. Georgia, Albania, and Bulgaria offer on-campus work. Offset living costs while building your career network abroad.</p>
    </div>

    <div class="why-card">
      <div class="why-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
      </div>
      <h3 class="why-title">Practice in India</h3>
      <p class="why-desc">NMC-recognized degrees let you return and register with your State Nursing Council. Work in government or private hospitals, or pursue higher studies.</p>
    </div>

    <div class="why-card">
      <div class="why-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
      </div>
      <h3 class="why-title">International Salary</h3>
      <p class="why-desc">UK nurses earn £25–35K/year. Malta and Bulgaria nurses earn €18–28K/year with EU license. Gulf countries offer tax-free salaries. Same degree, 5x the salary.</p>
    </div>

    <div class="why-card">
      <div class="why-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>
      </div>
      <h3 class="why-title">Scholarship Available</h3>
      <p class="why-desc">Merit-based scholarships in UK, Georgia, Albania, Bulgaria, and Malta. We help identify and apply. Reduces total program cost significantly.</p>
    </div>

    <div class="why-card featured">
      <div class="why-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/><line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/></svg>
      </div>
      <h3 class="why-title">The Respect You Deserve</h3>
      <p class="why-desc">In India, nurses are often overworked and under-respected. In UK, EU, and Gulf — nurses are valued professionals. Same degree. Completely different life.</p>
    </div>

    <div class="why-card problem">
      <div class="why-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
      </div>
      <h3 class="why-title">Escape India's Reality</h3>
      <p class="why-desc">Fresh nurses in India earn ₹8–15K/month. Long shifts. Limited growth. The BSc Nursing abroad route exists because India failed to fix this. Don't wait for it to change.</p>
    </div>

  </div>
</section>

<!-- SOCIAL PROOF — Apple clean stats + testimonials -->
<section class="social-proof">
  <!-- Overall Stats -->
  <div class="stats-strip">
    <div class="stat-item">
      <div class="stat-number">350+</div>
      <div class="stat-desc">Students Placed</div>
    </div>
    <div class="stat-item">
      <div class="stat-number accent">₹80K</div>
      <div class="stat-desc">Avg Monthly Salary Abroad<br><span class="stat-sub">vs ₹12K in India</span></div>
    </div>
    <div class="stat-item">
      <div class="stat-number">6 Mo</div>
      <div class="stat-desc">Avg Time to Placement</div>
    </div>
    <div class="stat-item">
      <div class="stat-number">100%</div>
      <div class="stat-desc">Visa Success Rate</div>
    </div>
  </div>

  <div class="testimonials-header">
    <p class="section-eyebrow">Real Students. Real Results.</p>
    <h2 class="section-headline">Gradiks Students<br>Are Working Now</h2>
  </div>

  <div class="testimonial-grid">
    <div class="testimonial-card">
      <div class="testimonial-person">
        <div class="person-avatar">R</div>
        <div class="person-info">
          <div class="person-name">Rahul <span class="person-loc">🇮🇳 Kerala</span></div>
          <div class="person-detail">BSc Nursing, Albania · 2024 · From Kozhikode</div>
        </div>
      </div>
      <p class="testimonial-quote">"Gradiks told me Albania was my best option given my 12th marks. I didn't believe it at first. Now I'm working in a UAE hospital, saving ₹80K/month."</p>
      <div class="testimonial-outcome">✓ Placed in UAE · Salary ₹80K/mo</div>
    </div>

    <div class="testimonial-card">
      <div class="testimonial-person">
        <div class="person-avatar">A</div>
        <div class="person-info">
          <div class="person-name">Aishwarya <span class="person-loc">🇮🇳 Kerala</span></div>
          <div class="person-detail">BSc Nursing, Georgia · 2023 · From Kochi</div>
        </div>
      </div>
      <p class="testimonial-quote">"I scored 58% in 12th. Every agent said try again next year. Gradiks found me a European-degree university in Georgia. Graduated without a loan."</p>
      <div class="testimonial-outcome">✓ Now at Apollo Hospital, Chennai</div>
    </div>

    <div class="testimonial-card">
      <div class="testimonial-person">
        <div class="person-avatar">M</div>
        <div class="person-info">
          <div class="person-name">Muhammed <span class="person-loc">🇮🇳 Kerala</span></div>
          <div class="person-detail">BSc Nursing, UK · 2022 · From Malappuram</div>
        </div>
      </div>
      <p class="testimonial-quote">"Gradiks was the only one who told me UK was possible with my profile. They were honest about the cost and the OSCE challenge. Worth it — I'm in Manchester now."</p>
      <div class="testimonial-outcome">✓ NHS Hospital, Manchester · £28K/yr</div>
    </div>
  </div>
</section>

<!-- ELIGIBILITY — Apple-style split layout -->
<section class="eligibility-section">
  <div class="eligibility-grid">

    <!-- Eligibility Checklist -->
    <div class="eligibility-left">
      <p class="section-eyebrow">Simple Requirements</p>
      <h2 class="section-headline">Are You<br><span class="section-headline-muted">Eligible?</span></h2>
      <p class="section-desc">BSc Nursing abroad has straightforward criteria. No competitive entrance exams. If you have science in 12th, you likely qualify.</p>
      <ul class="eligibility-list">
        <li class="eligibility-item">
          <span class="check-icon">✓</span>
          <span>10+2 with Physics, Chemistry, Biology (PCB)</span>
        </li>
        <li class="eligibility-item">
          <span class="check-icon">✓</span>
          <span>Minimum 50% aggregate in PCB (some countries accept 45%)</span>
        </li>
        <li class="eligibility-item">
          <span class="check-icon">✓</span>
          <span><strong>NEET is NOT required</strong> for BSc Nursing admissions abroad</span>
        </li>
        <li class="eligibility-item">
          <span class="check-icon">✓</span>
          <span>Valid Indian passport</span>
        </li>
        <li class="eligibility-item">
          <span class="check-icon">✓</span>
          <span>No age limit at most universities</span>
        </li>
      </ul>
      <div class="eligibility-note">
        <strong>Not sure about your score?</strong> Tell us your 12th % in the form below. We'll tell you exactly which countries you qualify for — free.
      </div>
    </div>

    <!-- After Graduation -->
    <div class="eligibility-right">
      <p class="section-eyebrow">Career Outcomes</p>
      <h2 class="section-headline">What After<br><span class="section-headline-muted">Graduation?</span></h2>
      <p class="section-desc">BSc Nursing opens multiple career paths — practice in India, work abroad, or pursue higher studies. Your degree is yours forever.</p>

      <div class="path-card">
        <h3 class="path-title">🇮🇳 Practice in India</h3>
        <ol class="path-steps">
          <li><span class="step-num">1</span>Pass NMC Screening Test (NEXT exam)</li>
          <li><span class="step-num">2</span>Register with State Nursing Council</li>
          <li><span class="step-num">3</span>Join government or private hospital</li>
        </ol>
      </div>

      <div class="path-card">
        <h3 class="path-title">🌍 Work Abroad</h3>
        <p class="path-desc">Pass the destination country's licensing exam:</p>
        <div class="exam-grid">
          <div class="exam-item"><div class="exam-country">UK</div><div class="exam-detail">OSCE exam + NMC registration</div></div>
          <div class="exam-item"><div class="exam-country">Malta</div><div class="exam-detail">EU nursing license</div></div>
          <div class="exam-item"><div class="exam-country">Bulgaria</div><div class="exam-detail">EU nursing license</div></div>
          <div class="exam-item"><div class="exam-country">UAE / Gulf</div><div class="exam-detail">DHA or MOH exam</div></div>
        </div>
      </div>

      <div class="salary-grid">
        <div class="salary-item">
          <div class="salary-val">₹3–6L</div>
          <div class="salary-desc">Fresh Nurse Salary/yr (India)</div>
        </div>
        <div class="salary-item">
          <div class="salary-val">£25–35K</div>
          <div class="salary-desc">UK Nurse Salary/yr</div>
        </div>
      </div>
    </div>

  </div>
</section>

<!-- LEAD FORM — Apple-style minimal -->
<section id="lead-form-container" class="form-section">
  <div class="form-urgency">2026 Batch Applications Closing Soon — Only 18 Seats Remaining</div>
  <div class="form-header">
    <p class="section-eyebrow">Free · No Obligation · 24hr Response</p>
    <h2 class="form-title">Get Your Personalized<br>Cost Breakdown</h2>
    <p class="form-desc">Tell us your 12th marks and preferred country. We'll reply with exact universities, fees, and total cost — within 24 hours. No sales pitch.</p>
  </div>

  <form id="lead-form" class="apple-form">
    <div class="form-row">
      <div class="form-field">
        <label class="field-label">Full Name *</label>
        <input type="text" name="name" required class="field-input" placeholder="Your full name" />
      </div>
      <div class="form-field">
        <label class="field-label">Phone *</label>
        <input type="tel" name="phone" required class="field-input" placeholder="+91 98765 43210" />
      </div>
    </div>
    <div class="form-field">
      <label class="field-label">Email *</label>
      <input type="email" name="email" required class="field-input" placeholder="your@email.com" />
    </div>
    <div class="form-field">
      <label class="field-label">12th PCB % *</label>
      <input type="text" name="12th_marks" required class="field-input" placeholder="e.g. 58% or 72%" />
    </div>
    <div class="form-field">
      <label class="field-label">Any questions? <span class="optional">(optional)</span></label>
