---
import MainLayout from '../layouts/MainLayout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
const title = "BSc Nursing Abroad 2026 | European Degree, Indian Budget | Gradiks";
const description = "BSc Nursing abroad for Indian students — European degree at Indian budget. No capitation, no management quota. Georgia, Albania, Bulgaria, Malta, UK. Get free eligibility check.";
---

<MainLayout title={title} description={description}>
<Navigation />

<main>
<!-- ============================================
     HERO SECTION
     ============================================ -->
<section class="country-hero-section mbbs-hero-premium relative overflow-hidden" style="min-height: auto; padding-block: clamp(3rem, 6vw, 5rem);">
  <div class="gradient-spotlight gradient-spotlight-1" style="top: -10%; right: -5%; width: 800px; height: 800px;"></div>
  <div class="gradient-spotlight gradient-spotlight-2" style="bottom: -10%; left: -10%; width: 600px; height: 600px;"></div>

  <div class="max-w-[1200px] mx-auto px-6 lg:px-12 relative z-10">
    <div class="max-w-3xl">
      <!-- H1 -->
      <h1 class="hero-headline animate-fade-in-up delay-100" style="color: #fafaf9; max-width: 800px;">
        BSc Nursing Abroad
        <br />
        <span class="hero-headline-accent" style="color: var(--color-accent-gold);">European Degree, Indian Budget</span>
      </h1>

      <!-- Subheadline -->
      <p class="hero-subheadline animate-fade-in-up delay-200" style="color: rgba(255,255,255,0.72); max-width: 560px;">
        Total cost ₹8–12L all-inclusive. INC pathway reviewed. Zero capitation. Zero commission.
      </p>

      <!-- Inline Eligibility Form -->
      <div class="animate-fade-in-up delay-300 mt-6 bg-white/[0.06] backdrop-blur-lg border border-white/10 rounded-2xl p-5 lg:p-6 max-w-xl">
        <form id="hero-lead-form" class="space-y-3">
          <div class="grid sm:grid-cols-2 gap-3">
            <div>
              <label for="hero-pcb" class="block text-xs font-medium mb-1" style="color: rgba(255,255,255,0.6);">Your 12th PCB %</label>
              <input id="hero-pcb" type="text" name="pcb_percent" required class="w-full px-4 py-3 bg-white/10 border border-white/20 text-white placeholder-white/35 text-sm rounded-lg" placeholder="e.g. 62%">
            </div>
            <div>
              <label for="hero-phone" class="block text-xs font-medium mb-1" style="color: rgba(255,255,255,0.6);">WhatsApp Number</label>
              <input id="hero-phone" type="tel" name="phone" required class="w-full px-4 py-3 bg-white/10 border border-white/20 text-white placeholder-white/35 text-sm rounded-lg" placeholder="+91 98765 43210">
            </div>
          </div>
          <button type="submit" class="w-full py-4 text-white font-semibold tracking-wide text-sm rounded-lg" style="background: var(--color-brand-red); box-shadow: 0 8px 28px rgba(190,30,45,0.28);">
            Check My Eligibility — Free
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="inline ml-2 -mt-0.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </button>
          <p class="text-center text-[11px]" style="color: rgba(255,255,255,0.35);">Free · No spam · 24hr response</p>
        </form>
      </div>
    </div>
  </div>
</section>

<!-- MARQUEE TRUST BAR -->
<section style="background: var(--color-brand-navy); border-top: 1px solid rgba(255,255,255,0.06);">
  <div class="trust-ticker-track" style="padding: 0.875rem 0; color: rgba(255,255,255,0.55); font-size: 0.8125rem;">
    <span class="flex items-center gap-2">🎓 <span class="font-display font-bold text-white text-sm">4-Year</span> BSc</span>
    <span style="color: rgba(255,255,255,0.12); margin: 0 1.5rem;">|</span>
    <span class="flex items-center gap-2">💰 <span class="font-display font-bold text-white text-sm">$3–5.5K/yr</span> Tuition</span>
    <span style="color: rgba(255,255,255,0.12); margin: 0 1.5rem;">|</span>
    <span class="flex items-center gap-2">📅 <span class="font-display font-bold text-white text-sm">Feb & Sep</span> Intake</span>
    <span style="color: rgba(255,255,255,0.12); margin: 0 1.5rem;">|</span>
    <span class="flex items-center gap-2">🏥 <span class="font-display font-bold text-white text-sm">INC</span> Pathway Reviewed</span>
    <span style="color: rgba(255,255,255,0.12); margin: 0 1.5rem;">|</span>
    <span class="flex items-center gap-2">🌍 <span class="font-display font-bold text-white text-sm">Work</span> Abroad After</span>
    <!-- Duplicate for seamless loop -->
    <span style="color: rgba(255,255,255,0.12); margin: 0 1.5rem;">|</span>
    <span class="flex items-center gap-2">🎓 <span class="font-display font-bold text-white text-sm">4-Year</span> BSc</span>
    <span style="color: rgba(255,255,255,0.12); margin: 0 1.5rem;">|</span>
    <span class="flex items-center gap-2">💰 <span class="font-display font-bold text-white text-sm">$3–5.5K/yr</span> Tuition</span>
    <span style="color: rgba(255,255,255,0.12); margin: 0 1.5rem;">|</span>
    <span class="flex items-center gap-2">📅 <span class="font-display font-bold text-white text-sm">Feb & Sep</span> Intake</span>
    <span style="color: rgba(255,255,255,0.12); margin: 0 1.5rem;">|</span>
    <span class="flex items-center gap-2">🏥 <span class="font-display font-bold text-white text-sm">INC</span> Pathway Reviewed</span>
    <span style="color: rgba(255,255,255,0.12); margin: 0 1.5rem;">|</span>
    <span class="flex items-center gap-2">🌍 <span class="font-display font-bold text-white text-sm">Work</span> Abroad After</span>
  </div>
</section>

<!-- ============================================
     COMPARISON TABLE
     ============================================ -->
<section class="py-16 lg:py-24" style="background: #fafaf9;">
  <div class="max-w-[1200px] mx-auto px-6 lg:px-12">
    <div class="text-center mb-12 reveal">
      <h2 class="section-headline" style="font-size: clamp(1.75rem, 4vw, 2.75rem);">Why Abroad When You Can Study Nursing in India?</h2>
      <p class="section-desc mx-auto mt-4">Honest comparison. Decide for yourself.</p>
    </div>

    <div class="max-w-3xl mx-auto reveal reveal-delay-1">
      <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
          <thead>
            <tr style="border-bottom: 2px solid var(--color-brand-red);">
              <th class="py-3 px-4 text-sm font-semibold" style="color: var(--color-text-primary);">Factor</th>
              <th class="py-3 px-4 text-sm font-semibold" style="color: var(--color-text-secondary);">India Private Nursing</th>
              <th class="py-3 px-4 text-sm font-semibold" style="color: var(--color-brand-red);">Abroad BSc Nursing</th>
            </tr>
          </thead>
          <tbody>
            <tr style="border-bottom: 1px solid #e5e7eb;">
              <td class="py-3 px-4 text-sm font-medium" style="color: var(--color-text-primary);">Total Cost</td>
              <td class="py-3 px-4 text-sm" style="color: var(--color-text-secondary);">₹15–30L + capitation</td>
              <td class="py-3 px-4 text-sm font-semibold" style="color: var(--color-brand-red);">₹8–12L all inclusive</td>
            </tr>
            <tr style="border-bottom: 1px solid #e5e7eb;">
              <td class="py-3 px-4 text-sm font-medium" style="color: var(--color-text-primary);">Capitation Fee</td>
              <td class="py-3 px-4 text-sm" style="color: var(--color-text-secondary);">₹5–15L extra</td>
              <td class="py-3 px-4 text-sm font-semibold" style="color: var(--color-brand-red);">Zero</td>
            </tr>
            <tr style="border-bottom: 1px solid #e5e7eb;">
              <td class="py-3 px-4 text-sm font-medium" style="color: var(--color-text-primary);">Management Quota</td>
              <td class="py-3 px-4 text-sm" style="color: var(--color-text-secondary);">Yes</td>
              <td class="py-3 px-4 text-sm font-semibold" style="color: var(--color-brand-red);">No</td>
            </tr>
            <tr style="border-bottom: 1px solid #e5e7eb;">
              <td class="py-3 px-4 text-sm font-medium" style="color: var(--color-text-primary);">Degree Type</td>
              <td class="py-3 px-4 text-sm" style="color: var(--color-text-secondary);">Indian</td>
              <td class="py-3 px-4 text-sm font-semibold" style="color: var(--color-brand-red);">European Standard</td>
            </tr>
            <tr style="border-bottom: 1px solid #e5e7eb;">
              <td class="py-3 px-4 text-sm font-medium" style="color: var(--color-text-primary);">Work Abroad After</td>
              <td class="py-3 px-4 text-sm" style="color: var(--color-text-secondary);">Difficult</td>
              <td class="py-3 px-4 text-sm font-semibold" style="color: var(--color-brand-red);">UK, UAE, Australia pathways open</td>
            </tr>
            <tr>
              <td class="py-3 px-4 text-sm font-medium" style="color: var(--color-text-primary);">Language of Teaching</td>
              <td class="py-3 px-4 text-sm" style="color: var(--color-text-secondary);">Regional mix</td>
              <td class="py-3 px-4 text-sm font-semibold" style="color: var(--color-brand-red);">English only</td>
            </tr>
          </tbody>
        </table>
      </div>

      <div class="text-center mt-8">
        <button onclick="document.getElementById('lead-form-container')?.scrollIntoView({ behavior: 'smooth', block: 'center' })" class="cta-primary" style="background: var(--color-brand-red);">
          Get the Full Fee Breakdown — Free
        </button>
      </div>
    </div>
  </div>
</section>

<!-- ============================================
     ELIGIBILITY CHECK
     ============================================ -->
<section class="py-16 lg:py-24" style="background: var(--color-surface);">
  <div class="max-w-[1200px] mx-auto px-6 lg:px-12">
    <div class="text-center mb-12 reveal">
      <h2 class="section-headline" style="font-size: clamp(1.75rem, 4vw, 2.75rem);">Is Nursing Abroad Right for You?</h2>
    </div>

    <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto reveal reveal-delay-1">
      <!-- Good fit -->
      <div class="rounded-2xl p-8 border" style="background: rgba(5,150,105,0.04); border-color: rgba(5,150,105,0.2);">
        <div class="flex items-center gap-2 mb-4">
          <span class="text-2xl">✅</span>
          <h3 class="text-xl font-semibold" style="color: var(--color-success); font-family: var(--font-display);">Good fit if</h3>
        </div>
        <ul class="space-y-3 text-sm" style="color: var(--color-text-secondary);">
          <li>• 12th PCB 45–60%</li>
          <li>• Want European exposure</li>
          <li>• Budget ₹8–12L total</li>
          <li>• Open to working abroad</li>
        </ul>
      </div>

      <!-- Not right fit -->
      <div class="rounded-2xl p-8 border" style="background: rgba(190,30,45,0.03); border-color: rgba(190,30,45,0.15);">
        <div class="flex items-center gap-2 mb-4">
          <span class="text-2xl">❌</span>
          <h3 class="text-xl font-semibold" style="color: var(--color-brand-red); font-family: var(--font-display);">Not right if</h3>
        </div>
        <ul class="space-y-3 text-sm" style="color: var(--color-text-secondary);">
          <li>• Want to practice in India only without additional registration</li>
          <li>• Expecting India-style hostel culture</li>
          <li>• Want a program under 3 years</li>
        </ul>
      </div>
    </div>

    <p class="text-center mt-8 text-sm" style="color: var(--color-text-secondary); max-width: 500px; margin-left: auto; margin-right: auto;">
      If you're unsure, tell us your profile. We'll tell you exactly where you stand.
    </p>

    <div class="text-center mt-4">
      <button onclick="document.getElementById('lead-form-container')?.scrollIntoView({ behavior: 'smooth', block: 'center' })" class="cta-primary" style="background: var(--color-brand-red);">
        Check If You Qualify — Takes 30 Seconds
      </button>
    </div>
  </div>
</section>

<!-- ============================================
     WHY NURSING ABROAD — 4 BLOCKS
     ============================================ -->
<section class="py-16 lg:py-24" style="background: #fafaf9;">
  <div class="max-w-[1200px] mx-auto px-6 lg:px-12">

    <!-- Block 1: Cost Reality -->
    <div class="max-w-4xl mx-auto mb-20 reveal">
      <h2 class="text-2xl lg:text-3xl font-semibold mb-6" style="font-family: var(--font-display); color: var(--color-text-primary);">📊 The Cost Reality</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
          <thead>
            <tr style="border-bottom: 2px solid var(--color-brand-navy);">
              <th class="py-3 px-4 text-sm font-semibold">Year</th>
              <th class="py-3 px-4 text-sm font-semibold">What's Included</th>
              <th class="py-3 px-4 text-sm font-semibold text-right">Estimated Cost</th>
            </tr>
          </thead>
          <tbody>
            <tr style="border-bottom: 1px solid #e5e7eb;">
              <td class="py-3 px-4 text-sm font-semibold" style="color: var(--color-brand-red);">Year 1</td>
              <td class="py-3 px-4 text-sm" style="color: var(--color-text-secondary);">Tuition + hostel + food + visa + flights</td>
              <td class="py-3 px-4 text-sm font-semibold text-right">₹3.5–4.5L</td>
            </tr>
            <tr style="border-bottom: 1px solid #e5e7eb;">
              <td class="py-3 px-4 text-sm font-semibold" style="color: var(--color-brand-red);">Year 2–4</td>
              <td class="py-3 px-4 text-sm" style="color: var(--color-text-secondary);">Tuition + hostel + food (each year)</td>
              <td class="py-3 px-4 text-sm font-semibold text-right">₹2–2.5L/yr</td>
            </tr>
            <tr>
              <td class="py-3 px-4 text-sm font-semibold text-lg" style="color: var(--color-brand-red); font-family: var(--font-display);">Total</td>
              <td class="py-3 px-4 text-sm" style="color: var(--color-text-secondary);">All-in, 4 years</td>
              <td class="py-3 px-4 text-sm font-bold text-right text-lg" style="color: var(--color-brand-red); font-family: var(--font-display);">₹8–12L</td>
            </tr>
          </tbody>
        </table>
      </div>
      <p class="mt-4 text-sm" style="color: var(--color-success);">No hidden costs. This is what you actually pay.</p>
    </div>

    <!-- Block 2: Career Reality -->
    <div class="max-w-4xl mx-auto mb-20 reveal reveal-delay-1">
      <h2 class="text-2xl lg:text-3xl font-semibold mb-6" style="font-family: var(--font-display); color: var(--color-text-primary);">💼 The Career Reality</h2>
      <p class="text-sm mb-6" style="color: var(--color-text-secondary);">Where Gradiks nursing graduates are working today:</p>
      <div class="grid sm:grid-cols-3 gap-4">
        <div class="rounded-xl p-6 border" style="border-color: #e5e7eb; background: #fafaf9;">
          <div class="text-lg mb-1">🇦🇪</div>
          <div class="font-semibold text-sm mb-1" style="color: var(--color-text-primary);">UAE Hospital</div>
          <div class="text-sm" style="color: var(--color-text-secondary);">AED 4,000–7,000/mo</div>
        </div>
        <div class="rounded-xl p-6 border" style="border-color: #e5e7eb; background: #fafaf9;">
          <div class="text-lg mb-1">🇮🇳</div>
          <div class="font-semibold text-sm mb-1" style="color: var(--color-text-primary);">Apollo Chennai</div>
          <div class="text-sm" style="color: var(--color-text-secondary);">₹3–6L/yr</div>
        </div>
        <div class="rounded-xl p-6 border" style="border-color: #e5e7eb; background: #fafaf9;">
          <div class="text-lg mb-1">🇬🇧</div>
          <div class="font-semibold text-sm mb-1" style="color: var(--color-text-primary);">NHS Manchester</div>
          <div class="text-sm" style="color: var(--color-text-secondary);">£25–35K/yr</div>
        </div>
      </div>
      <p class="mt-4 text-sm" style="color: var(--color-success);">These are real graduate outcomes, not projections.</p>
    </div>

    <!-- Block 3: Registration Reality -->
    <div class="max-w-4xl mx-auto mb-20 reveal reveal-delay-2">
      <h2 class="text-2xl lg:text-3xl font-semibold mb-6" style="font-family: var(--font-display); color: var(--color-text-primary);">📋 The Registration Reality</h2>
      <div class="rounded-2xl p-8 border" style="border-color: #e5e7eb; background: #fafaf9;">
        <p class="text-sm mb-4 leading-relaxed" style="color: var(--color-text-secondary);">
          Your European BSc Nursing degree is recognized. To practice in India, you need to register with the Indian Nursing Council (INC). This involves an application, document verification, and sometimes a short screening test — but the degree itself is valid. We guide you through every step of this process.
        </p>
        <p class="text-sm leading-relaxed" style="color: var(--color-text-secondary);">
          Most consultants don't tell you this upfront. We do.
        </p>
      </div>
    </div>

    <!-- Block 4: Life Abroad -->
    <div class="max-w-4xl mx-auto reveal reveal-delay-3">
      <h2 class="text-2xl lg:text-3xl font-semibold mb-6" style="font-family: var(--font-display); color: var(--color-text-primary);">🏠 Life as a Nursing Student Abroad</h2>
      <div class="grid sm:grid-cols-3 gap-4">
        <div class="rounded-xl p-6 border" style="border-color: #e5e7eb; background: #fafaf9;">
          <div class="text-2xl mb-2">🛡️</div>
          <div class="font-semibold text-sm mb-1" style="color: var(--color-text-primary);">Safe & Welcoming</div>
          <div class="text-xs" style="color: var(--color-text-secondary);">Georgia, Albania, Malta are among the safest countries for international students</div>
        </div>
        <div class="rounded-xl p-6 border" style="border-color: #e5e7eb; background: #fafaf9;">
          <div class="text-2xl mb-2">🗣️</div>
          <div class="font-semibold text-sm mb-1" style="color: var(--color-text-primary);">English-Friendly</div>
          <div class="text-xs" style="color: var(--color-text-secondary);">Universities teach in English. Locals in student areas speak basic English</div>
        </div>
        <div class="rounded-xl p-6 border" style="border-color: #e5e7eb; background: #fafaf9;">
          <div class="text-2xl mb-2">💰</div>
          <div class="font-semibold text-sm mb-1" style="color: var(--color-text-primary);">Living Cost</div>
          <div class="text-xs" style="color: var(--color-text-secondary);">₹8,000–15,000/month including hostel, food, and transport</div>
        </div>
      </div>
    </div>

    <div class="text-center mt-12">
      <button onclick="document.getElementById('lead-form-container')?.scrollIntoView({ behavior: 'smooth', block: 'center' })" class="cta-primary" style="background: var(--color-brand-red);">
        Get Honest Advice for Your Profile — Free
      </button>
    </div>
  </div>
</section>

<!-- ============================================
     UNIVERSITIES
     ============================================ -->
<section class="py-16 lg:py-24" style="background: var(--color-surface);">
  <div class="max-w-[1200px] mx-auto px-6 lg:px-12">
    <div class="text-center mb-12 reveal">
      <h2 class="section-headline" style="font-size: clamp(1.75rem, 4vw, 2.75rem);">Universities We Work With</h2>
      <p class="section-desc mx-auto mt-4">We'll tell you which one fits your profile — not which one pays us more.</p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 reveal reveal-delay-1">
      <div class="feature-card">
        <div class="flex items-center gap-2 mb-3">
          <span class="text-xl">🇬🇪</span>
          <h3 class="font-semibold text-lg" style="font-family: var(--font-display);">Tbilisi State Medical University</h3>
        </div>
        <div class="space-y-1 text-xs" style="color: var(--color-text-secondary);">
          <p>Est. 1918</p>
          <p>INC/WHO Recognized</p>
          <p>$3,500/yr tuition</p>
          <p>Feb & Sep Intake</p>
        </div>
      </div>
      <div class="feature-card">
        <div class="flex items-center gap-2 mb-3">
          <span class="text-xl">🇦🇱</span>
          <h3 class="font-semibold text-lg" style="font-family: var(--font-display);">University of Tirana</h3>
        </div>
        <div class="space-y-1 text-xs" style="color: var(--color-text-secondary);">
          <p>Est. 1957</p>
          <p>WHO Recognized</p>
          <p>$2,800/yr tuition</p>
          <p>Sep Intake</p>
        </div>
      </div>
      <div class="feature-card">
        <div class="flex items-center gap-2 mb-3">
          <span class="text-xl">🇧🇬</span>
          <h3 class="font-semibold text-lg" style="font-family: var(--font-display);">Medical University of Sofia</h3>
        </div>
        <div class="space-y-1 text-xs" style="color: var(--color-text-secondary);">
          <p>Est. 1917</p>
          <p>EU/WHO Recognized</p>
          <p>$4,500/yr tuition</p>
          <p>Sep Intake</p>
        </div>
      </div>
      <div class="feature-card">
        <div class="flex items-center gap-2 mb-3">
          <span class="text-xl">🇲🇹</span>
          <h3 class="font-semibold text-lg" style="font-family: var(--font-display);">University of Malta</h3>
        </div>
        <div class="space-y-1 text-xs" style="color: var(--color-text-secondary);">
          <p>Est. 1592</p>
          <p>EU/WHO Recognized</p>
          <p>$5,500/yr tuition</p>
          <p>Sep Intake</p>
        </div>
      </div>
    </div>

    <div class="text-center mt-8">
      <button onclick="document.getElementById('lead-form-container')?.scrollIntoView({ behavior: 'smooth', block: 'center' })" class="cta-primary" style="background: var(--color-brand-red);">
        Find Out Which University Fits You — Free
      </button>
    </div>
  </div>
</section>

<!-- ============================================
     TESTIMONIALS
     ============================================ -->
<section class="py-16 lg:py-24" style="background: var(--color-brand-navy);">
  <div class="max-w-[1200px] mx-auto px-6 lg:px-12">
    <div class="text-center mb-12 reveal">
      <h2 class="section-headline inverted">Real Students. Real Outcomes.<br>No Exaggeration.</h2>
    </div>

    <div class="grid md:grid-cols-3 gap-6 reveal reveal-delay-1">
