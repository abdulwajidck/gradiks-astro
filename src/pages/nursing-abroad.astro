  window.__sendToBackend?.({ form_type: 'hero-' + FORM_TYPE, phone, pcb_percentage: pcb });
  const done = () => { btn.style.background = '#22c55e'; setTimeout(() => { window.location.href = '/nursing-thank-you'; }, 500); };
  Promise.race([fetch(TELECRM_URL, { method:'POST', headers:{'Content-Type':'application/json','Authorization':TELECRM_KEY}, body:JSON.stringify(buildPayload({phone},notes)), keepalive:true }), new Promise(r=>setTimeout(r,1500))]).then(done).catch(done);
});
</script>
