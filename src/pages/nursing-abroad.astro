---
import MainLayout from '../layouts/MainLayout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
const title = "BSc Nursing Abroad 2026 | European Degree, Indian Budget | Gradiks";
const description = "BSc Nursing abroad for Indian students — European degree at Indian budget. No capitation, no management quota. Georgia, Albania, Bulgaria, Malta, UK. Get free eligibility check.";
const CRM_CAMPAIGN = "Nursing Abroad - Hub";
const FORM_TYPE = "nursing-abroad";
---

<style>
  .process-step { display: flex; gap: 1.25rem; align-items: flex-start; padding: 1.5rem 0; border-bottom: 1px solid #e5e7eb; }
  .process-step:last-child { border-bottom: none; }
  .step-num {
    flex-shrink: 0;
    width: 2.5rem; height: 2.5rem;
    border-radius: 50%;
    background: var(--color-brand-red);
    color: #fff;
    display: flex; align-items: center; justify-content: center;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.875rem;
  }
  .destination-row { display: grid; grid-template-columns: 1fr 1fr 1fr 1fr; gap: 1px; background: #e5e7eb; }
  .destination-cell { background: #fafaf9; padding: 1.5rem; }
  @media (max-width: 767px) { .destination-row { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 479px) { .destination-row { grid-template-columns: 1fr; } }
  .country-card { padding: 1.75rem; border: 1px solid #e5e7eb; border-radius: 20px; transition: border-color 0.2s, transform 0.2s; }
  .country-card:hover { border-color: var(--color-brand-red); transform: translateY(-2px); }
  .country-card-flag { font-size: 1.75rem; margin-bottom: 0.875rem; line-height: 1; }
  .country-card-name { font-family: var(--font-display); font-weight: 600; font-size: 1.0625rem; color: var(--color-text-primary); margin-bottom: 0.25rem; }
  .country-card-cost { font-size: 0.8125rem; font-weight: 700; color: var(--color-brand-red); margin-bottom: 0.875rem; }
  .country-card-tag { display: inline-block; font-size: 0.6875rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; padding: 0.2rem 0.5rem; border-radius: 4px; background: rgba(190,30,45,0.08); color: var(--color-brand-red); margin-bottom: 0.5rem; }
</style>

<MainLayout title={title} description={description}>
<Navigation />

<main>
<!-- HERO -->
<section class="country-hero-section mbbs-hero-premium relative overflow-hidden" style="min-height: auto; padding-block: clamp(3.5rem, 7vw, 5.5rem);">
  <div class="gradient-spotlight gradient-spotlight-1" style="top: -10%; right: -5%; width: 800px; height: 800px;"></div>
  <div class="gradient-spotlight gradient-spotlight-2" style="bottom: -10%; left: -10%; width: 600px; height: 600px;"></div>

  <div class="max-w-[1200px] mx-auto px-6 lg:px-12 relative z-10">
    <div class="max-w-3xl">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full mb-6 text-xs font-semibold tracking-wide animate-fade-in-up" style="background: rgba(255,255,255,0.09); border: 1px solid rgba(255,255,255,0.16); color: rgba(255,255,255,0.8);">
        BSc Nursing Abroad — 2026 Intake
      </div>
      <h1 class="hero-headline animate-fade-in-up delay-100" style="color: #fafaf9; max-width: 800px;">
        European Degree.<br>
        <span style="color: var(--color-accent-gold);">Indian Budget.</span>
      </h1>
      <p class="hero-subheadline animate-fade-in-up delay-200" style="color: rgba(255,255,255,0.72); max-width: 520px;">
        From ₹14L all-in (Albania/Georgia) to ₹50L+ (UK). INC pathway reviewed before you commit. Zero capitation. Zero commission.
      </p>

      <div class="animate-fade-in-up delay-300 mt-8 bg-white/[0.06] border border-white/10 rounded-2xl p-5 lg:p-6 max-w-xl">
        <form id="hero-lead-form" class="space-y-3">
          <div class="grid sm:grid-cols-2 gap-3">
            <div>
              <label for="hero-pcb" class="block text-xs font-medium mb-1" style="color: rgba(255,255,255,0.6);">Your 12th PCB %</label>
              <input id="hero-pcb" type="text" name="pcb_percent" required class="w-full px-4 py-3 bg-white/10 border border-white/20 text-white placeholder-white/35 text-sm rounded-xl" placeholder="e.g. 62%">
            </div>
            <div>
              <label for="hero-phone" class="block text-xs font-medium mb-1" style="color: rgba(255,255,255,0.6);">WhatsApp Number</label>
              <input id="hero-phone" type="tel" name="phone" required class="w-full px-4 py-3 bg-white/10 border border-white/20 text-white placeholder-white/35 text-sm rounded-xl" placeholder="+91 98765 43210">
            </div>
          </div>
          <button type="submit" class="w-full py-4 text-white font-semibold tracking-wide text-sm rounded-xl" style="background: var(--color-brand-red); box-shadow: 0 8px 28px rgba(190,30,45,0.28);">
            Check My Eligibility — Free
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="inline ml-2 -mt-0.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </button>
          <p class="text-center text-[11px]" style="color: rgba(255,255,255,0.35);">Free · No spam · 24hr response</p>
        </form>
      </div>
    </div>
  </div>
</section>

<!-- MARQUEE TRUST BAR -->
<section style="background: var(--color-brand-navy); border-top: 1px solid rgba(255,255,255,0.06);">
  <div class="trust-ticker-track" style="padding: 0.875rem 0; color: rgba(255,255,255,0.55); font-size: 0.8125rem;">
    <span class="flex items-center gap-2"><span class="font-display font-bold text-white text-sm">4-Year</span> BSc Nursing</span>
    <span style="color: rgba(255,255,255,0.12); margin: 0 1.5rem;">|</span>
    <span class="flex items-center gap-2"><span class="font-display font-bold text-white text-sm">From ₹14L</span> All-In</span>
    <span style="color: rgba(255,255,255,0.12); margin: 0 1.5rem;">|</span>
    <span class="flex items-center gap-2"><span class="font-display font-bold text-white text-sm">No NEET</span> Required</span>
    <span style="color: rgba(255,255,255,0.12); margin: 0 1.5rem;">|</span>
    <span class="flex items-center gap-2"><span class="font-display font-bold text-white text-sm">INC</span> Pathway Reviewed</span>
    <span style="color: rgba(255,255,255,0.12); margin: 0 1.5rem;">|</span>
    <span class="flex items-center gap-2"><span class="font-display font-bold text-white text-sm">Zero</span> Commission</span>
    <span style="color: rgba(255,255,255,0.12); margin: 0 1.5rem;">|</span>
    <span class="flex items-center gap-2"><span class="font-display font-bold text-white text-sm">4-Year</span> BSc Nursing</span>
    <span style="color: rgba(255,255,255,0.12); margin: 0 1.5rem;">|</span>
    <span class="flex items-center gap-2"><span class="font-display font-bold text-white text-sm">From ₹14L</span> All-In</span>
    <span style="color: rgba(255,255,255,0.12); margin: 0 1.5rem;">|</span>
    <span class="flex items-center gap-2"><span class="font-display font-bold text-white text-sm">No NEET</span> Required</span>
    <span style="color: rgba(255,255,255,0.12); margin: 0 1.5rem;">|</span>
    <span class="flex items-center gap-2"><span class="font-display font-bold text-white text-sm">INC</span> Pathway Reviewed</span>
    <span style="color: rgba(255,255,255,0.12); margin: 0 1.5rem;">|</span>
    <span class="flex items-center gap-2"><span class="font-display font-bold text-white text-sm">Zero</span> Commission</span>
  </div>
</section>

<!-- COMPARISON TABLE -->
<section class="py-16 lg:py-24" style="background: #fafaf9;">
  <div class="max-w-[1200px] mx-auto px-6 lg:px-12">
    <div class="max-w-3xl mx-auto">
      <div class="mb-10 reveal">
        <p class="section-eyebrow mb-2">The Honest Comparison</p>
        <h2 class="section-headline" style="font-size: clamp(1.75rem, 4vw, 2.5rem);">Why abroad when you can study nursing in India?</h2>
        <p class="section-desc mt-3">Decide for yourself.</p>
      </div>

      <div class="overflow-x-auto reveal reveal-delay-1">
        <table class="w-full text-left border-collapse">
          <thead>
            <tr style="border-bottom: 2px solid var(--color-brand-red);">
              <th class="py-3 px-4 text-sm font-semibold" style="color: var(--color-text-primary);">Factor</th>
              <th class="py-3 px-4 text-sm font-semibold" style="color: var(--color-text-secondary);">India Private Nursing</th>
              <th class="py-3 px-4 text-sm font-semibold" style="color: var(--color-brand-red);">Abroad BSc Nursing</th>
            </tr>
          </thead>
          <tbody>
            <tr style="border-bottom: 1px solid #e5e7eb;">
              <td class="py-3 px-4 text-sm font-medium" style="color: var(--color-text-primary);">Total Cost</td>
              <td class="py-3 px-4 text-sm" style="color: var(--color-text-secondary);">₹15–30L + capitation</td>
              <td class="py-3 px-4 text-sm font-semibold" style="color: var(--color-brand-red);">From ₹14L (by country)</td>
            </tr>
            <tr style="border-bottom: 1px solid #e5e7eb;">
              <td class="py-3 px-4 text-sm font-medium" style="color: var(--color-text-primary);">Capitation Fee</td>
              <td class="py-3 px-4 text-sm" style="color: var(--color-text-secondary);">₹5–15L extra</td>
              <td class="py-3 px-4 text-sm font-semibold" style="color: var(--color-brand-red);">Zero</td>
            </tr>
            <tr style="border-bottom: 1px solid #e5e7eb;">
              <td class="py-3 px-4 text-sm font-medium" style="color: var(--color-text-primary);">Management Quota</td>
              <td class="py-3 px-4 text-sm" style="color: var(--color-text-secondary);">Yes</td>
              <td class="py-3 px-4 text-sm font-semibold" style="color: var(--color-brand-red);">No</td>
            </tr>
            <tr style="border-bottom: 1px solid #e5e7eb;">
              <td class="py-3 px-4 text-sm font-medium" style="color: var(--color-text-primary);">Degree Type</td>
              <td class="py-3 px-4 text-sm" style="color: var(--color-text-secondary);">Indian</td>
              <td class="py-3 px-4 text-sm font-semibold" style="color: var(--color-brand-red);">European standard</td>
            </tr>
            <tr style="border-bottom: 1px solid #e5e7eb;">
              <td class="py-3 px-4 text-sm font-medium" style="color: var(--color-text-primary);">Work Abroad After</td>
              <td class="py-3 px-4 text-sm" style="color: var(--color-text-secondary);">Difficult</td>
              <td class="py-3 px-4 text-sm font-semibold" style="color: var(--color-brand-red);">UK, UAE, Australia pathways open</td>
            </tr>
            <tr>
              <td class="py-3 px-4 text-sm font-medium" style="color: var(--color-text-primary);">Language of Teaching</td>
              <td class="py-3 px-4 text-sm" style="color: var(--color-text-secondary);">Regional mix</td>
              <td class="py-3 px-4 text-sm font-semibold" style="color: var(--color-brand-red);">English only</td>
            </tr>
          </tbody>
        </table>
      </div>

      <div class="text-center mt-8 reveal reveal-delay-2">
        <button onclick="document.getElementById('lead-form-container')?.scrollIntoView({ behavior: 'smooth', block: 'center' })" class="cta-primary" style="background: var(--color-brand-red);">
          Get the Full Fee Breakdown — Free
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </button>
      </div>
    </div>
  </div>
</section>

<!-- IS IT RIGHT FOR YOU -->
<section class="py-16 lg:py-24" style="background: var(--color-surface);">
  <div class="max-w-[1200px] mx-auto px-6 lg:px-12">
    <div class="max-w-4xl mx-auto">
      <div class="mb-10 reveal">
        <p class="section-eyebrow mb-2">Fit Check</p>
        <h2 class="section-headline" style="font-size: clamp(1.75rem, 4vw, 2.5rem);">Is nursing abroad right for you?</h2>
      </div>
      <div class="grid md:grid-cols-2 gap-6 reveal reveal-delay-1">
        <div class="rounded-2xl p-8 border" style="background: rgba(5,150,105,0.04); border-color: rgba(5,150,105,0.2);">
          <h3 class="text-lg font-semibold mb-4" style="color: var(--color-success); font-family: var(--font-display);">A good fit if</h3>
          <ul class="space-y-3">
            <li class="flex gap-3 items-start text-sm" style="color: var(--color-text-secondary);">
              <span class="flex-shrink-0 w-4 h-4 rounded-full flex items-center justify-center text-xs font-bold mt-0.5" style="background: rgba(5,150,105,0.15); color: var(--color-success);">+</span>
              12th PCB 45–65% and NEET is not an option
            </li>
            <li class="flex gap-3 items-start text-sm" style="color: var(--color-text-secondary);">
              <span class="flex-shrink-0 w-4 h-4 rounded-full flex items-center justify-center text-xs font-bold mt-0.5" style="background: rgba(5,150,105,0.15); color: var(--color-success);">+</span>
              Budget suits the destination you choose (from ₹14L for Albania/Georgia)
            </li>
            <li class="flex gap-3 items-start text-sm" style="color: var(--color-text-secondary);">
              <span class="flex-shrink-0 w-4 h-4 rounded-full flex items-center justify-center text-xs font-bold mt-0.5" style="background: rgba(5,150,105,0.15); color: var(--color-success);">+</span>
              Want the option to work in UK, UAE, or Australia after graduation
            </li>
            <li class="flex gap-3 items-start text-sm" style="color: var(--color-text-secondary);">
              <span class="flex-shrink-0 w-4 h-4 rounded-full flex items-center justify-center text-xs font-bold mt-0.5" style="background: rgba(5,150,105,0.15); color: var(--color-success);">+</span>
              Want a European-standard degree with international recognition
            </li>
          </ul>
        </div>
        <div class="rounded-2xl p-8 border" style="background: rgba(190,30,45,0.03); border-color: rgba(190,30,45,0.15);">
          <h3 class="text-lg font-semibold mb-4" style="color: var(--color-brand-red); font-family: var(--font-display);">Not the right fit if</h3>
          <ul class="space-y-3">
            <li class="flex gap-3 items-start text-sm" style="color: var(--color-text-secondary);">
              <span class="flex-shrink-0 w-4 h-4 rounded-full flex items-center justify-center text-xs font-bold mt-0.5" style="background: rgba(190,30,45,0.1); color: var(--color-brand-red);">–</span>
              Want to practice in India only and aren't willing to do INC registration
            </li>
            <li class="flex gap-3 items-start text-sm" style="color: var(--color-text-secondary);">
              <span class="flex-shrink-0 w-4 h-4 rounded-full flex items-center justify-center text-xs font-bold mt-0.5" style="background: rgba(190,30,45,0.1); color: var(--color-brand-red);">–</span>
              Expecting an India-style hostel culture abroad
            </li>
            <li class="flex gap-3 items-start text-sm" style="color: var(--color-text-secondary);">
              <span class="flex-shrink-0 w-4 h-4 rounded-full flex items-center justify-center text-xs font-bold mt-0.5" style="background: rgba(190,30,45,0.1); color: var(--color-brand-red);">–</span>
              Want a program shorter than 3 years
            </li>
          </ul>
        </div>
      </div>
      <p class="text-center mt-6 text-sm" style="color: var(--color-text-secondary);">If you're unsure, tell us your profile. We'll tell you exactly where you stand.</p>
      <div class="text-center mt-4 reveal reveal-delay-2">
        <button onclick="document.getElementById('lead-form-container')?.scrollIntoView({ behavior: 'smooth', block: 'center' })" class="cta-primary" style="background: var(--color-brand-red);">
          Check If You Qualify — Takes 30 Seconds
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </button>
      </div>
    </div>
  </div>
</section>

<!-- WHAT YOU ACTUALLY NEED TO KNOW — 4 EDITORIAL BLOCKS -->
<section class="country-why-section py-20 lg:py-28">
  <div class="max-w-[1200px] mx-auto px-6 lg:px-12">
    <div class="max-w-2xl mb-16 reveal">
      <p class="section-eyebrow inverted mb-3">The Full Picture</p>
      <h2 class="section-headline inverted">Four things most consultants<br>don't tell you upfront</h2>
    </div>

    <div class="grid md:grid-cols-2 gap-px" style="border: 1px solid rgba(255,255,255,0.08);">
      <div class="why-block-na p-10 border border-white/8 reveal" style="background: rgba(255,255,255,0.02);">
        <div class="text-5xl font-light mb-4" style="font-family: var(--font-display); color: rgba(255,255,255,0.12); line-height: 1;">01</div>
        <h3 class="text-xl font-semibold text-white mb-3" style="font-family: var(--font-display);">The real cost</h3>
        <p class="text-sm mb-6" style="color: rgba(255,255,255,0.6); line-height: 1.75;">Albania/Georgia (cheapest tier): Year 1 = ₹3.5–4.5L (tuition + hostel + food + visa + flights). Years 2–4: ₹2–2.5L/yr each. Total 4 years: ₹14–20L. Bulgaria: ₹20–35L. Malta: ₹28–44L. UK: ₹50L+ (offset by part-time work earnings). No capitation. No hidden setup fees — ask us for the country-specific document breakdown.</p>
        <div class="p-4 rounded-xl" style="background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.08);">
          <p class="text-xs" style="color: rgba(255,255,255,0.5);">Compare: India private nursing college — ₹15–30L + capitation ₹5–15L = ₹20–45L total.</p>
        </div>
      </div>

      <div class="why-block-na p-10 border border-white/8 reveal reveal-delay-1" style="background: rgba(255,255,255,0.02);">
        <div class="text-5xl font-light mb-4" style="font-family: var(--font-display); color: rgba(255,255,255,0.12); line-height: 1;">02</div>
        <h3 class="text-xl font-semibold text-white mb-3" style="font-family: var(--font-display);">The INC registration process</h3>
        <p class="text-sm mb-4" style="color: rgba(255,255,255,0.6); line-height: 1.75;">Your European BSc Nursing degree is recognized. To practice in India, you need INC registration: document verification, sometimes a short screening. The degree is valid — this is a bureaucratic step, not a barrier. Most consultants reveal this only after you've paid. We explain it in your first call.</p>
      </div>

      <div class="why-block-na p-10 border border-white/8 reveal" style="background: rgba(255,255,255,0.02);">
        <div class="text-5xl font-light mb-4" style="font-family: var(--font-display); color: rgba(255,255,255,0.12); line-height: 1;">03</div>
        <h3 class="text-xl font-semibold text-white mb-3" style="font-family: var(--font-display);">Where graduates actually work</h3>
        <div class="space-y-3 text-sm" style="color: rgba(255,255,255,0.6);">
          <div class="flex items-baseline justify-between py-2" style="border-bottom: 1px solid rgba(255,255,255,0.06);">
            <span>UAE hospital (DHA/MOH licensed)</span>
            <span class="font-semibold text-white">AED 4,000–7,000/mo</span>
          </div>
          <div class="flex items-baseline justify-between py-2" style="border-bottom: 1px solid rgba(255,255,255,0.06);">
            <span>NHS United Kingdom (NMC registered)</span>
            <span class="font-semibold text-white">£25–35K/yr</span>
          </div>
          <div class="flex items-baseline justify-between py-2" style="border-bottom: 1px solid rgba(255,255,255,0.06);">
            <span>Apollo / Fortis India (INC registered)</span>
            <span class="font-semibold text-white">₹3–6L/yr</span>
          </div>
          <div class="flex items-baseline justify-between py-2">
            <span>Australia / New Zealand (AHPRA/NCNZ)</span>
            <span class="font-semibold text-white">AUD 65–85K/yr</span>
          </div>
        </div>
      </div>

      <div class="why-block-na p-10 border border-white/8 reveal reveal-delay-1" style="background: rgba(255,255,255,0.02);">
        <div class="text-5xl font-light mb-4" style="font-family: var(--font-display); color: rgba(255,255,255,0.12); line-height: 1;">04</div>
        <h3 class="text-xl font-semibold text-white mb-3" style="font-family: var(--font-display);">Life as a student abroad</h3>
        <p class="text-sm mb-4" style="color: rgba(255,255,255,0.6); line-height: 1.75;">Georgia, Albania, and Bulgaria are among Europe's safest countries. Classes are in English. Living cost runs ₹8,000–18,000/month depending on the country, covering hostel, food, and transport. Established Indian student communities exist in all five destinations we counsel.</p>
        <p class="text-sm" style="color: rgba(255,255,255,0.6); line-height: 1.75;">We give you a pre-departure briefing covering accommodation, Day 1, what to pack, and who to call if something goes wrong. Not a PDF — a call.</p>
      </div>
    </div>

    <div class="text-center mt-10 reveal">
      <button onclick="document.getElementById('lead-form-container')?.scrollIntoView({ behavior: 'smooth', block: 'center' })" class="cta-primary" style="background: var(--color-brand-red);">
        Get Honest Advice for Your Profile — Free
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </button>
    </div>
  </div>
</section>

<!-- DESTINATIONS -->
<section class="py-16 lg:py-24" style="background: #fafaf9;">
  <div class="max-w-[1200px] mx-auto px-6 lg:px-12">
    <div class="mb-12 reveal">
      <p class="section-eyebrow mb-2">Five Destinations</p>
      <h2 class="section-headline" style="font-size: clamp(1.75rem, 4vw, 2.5rem);">Choose your country.</h2>
      <p class="section-desc mt-3">Each fits a different profile. We'll tell you which one fits yours.</p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 reveal reveal-delay-1">
      <a href="/nursing-georgia" class="country-card block" style="text-decoration: none;">
        <div class="country-card-flag">🇬🇪</div>
        <div class="country-card-name">Georgia</div>
        <div class="country-card-cost">$3–5.5K/yr tuition · ₹8–12K/mo living</div>
        <div class="country-card-tag">No NEET</div>
