<script>
document.getElementById('lead-form')?.addEventListener('submit', async (e) => {
  e.preventDefault();
  const form = e.target;
  const btn = form.querySelector('button[type="submit"]');

  const name = form.querySelector('[name="name"]').value.trim();
  const phone = form.querySelector('[name="phone"]').value.trim();
  const email = form.querySelector('[name="email"]').value.trim();
  const marks = form.querySelector('[name="12th_marks"]').value.trim();
  const questions = form.querySelector('textarea')?.value.trim() || '';

  btn.disabled = true;
  btn.textContent = 'Submitting...';
  btn.style.opacity = '0.7';

  try {
    let normalizedPhone = phone.replace(/[\s\-]/g, '');
    if (!normalizedPhone.startsWith('+')) {
      normalizedPhone = '+91' + normalizedPhone;
    }

    const apiKey = 'e3589356-338b-4e7b-bea0-c6e54619932f1775381043124';
    const endpoint = `https://app.telecrm.in/api/b1/enterprise/${apiKey}/autoupdatelead`;

    const payload = {
      fields: {
        name,
        phone: normalizedPhone,
        email,
        '12th_marks': marks,
      },
      actions: [
        {
          type: 'SYSTEM_NOTE',
          text: `Lead Source: Gradiks Website — BSc Nursing Abroad\nQuestions: ${questions}`,
        },
      ],
    };

    const res = await fetch(endpoint, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload),
    });

    if (!res.ok) {
      const errText = await res.text();
      throw new Error(`CRM error ${res.status}: ${errText}`);
    }

    btn.textContent = 'Submitted ✓';
    btn.style.backgroundColor = '#22c55e';

    setTimeout(() => {
      window.location.href = '/nursing-thank-you';
    }, 800);

  } catch (err) {
    console.error('Form submission error:', err);
    btn.disabled = false;
    btn.textContent = 'Get My Personalized Cost Breakdown';
    btn.style.opacity = '1';
    alert(`Submission failed: ${err.message}. Please try again or call us directly.`);
  }
});
</script>
</MainLayout>