---
import MainLayout from '../layouts/MainLayout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
const title = "Gradiks — Study in Germany | Tuition-Free Universities";
const description = "Study in Germany with Gradiks. Tuition-free public universities. MSc Data Science, AI, Engineering, Computer Science & more. Honest consultancy — no hidden fees.";
---
<MainLayout title={title} description={description}>
<Navigation />
<!-- TRUST BAR -->
<section class="bg-[#232d61] py-4 mt-20">
  <div class="max-w-[1400px] mx-auto px-6 lg:px-12">
    <div class="flex flex-wrap justify-center items-center gap-8 lg:gap-16 text-white text-sm">
      <span class="flex items-center gap-2">
        <span class="font-display font-semibold">€0</span>
        <span class="text-white/70">Tuition Fee</span>
      </span>
      <span class="text-white/30 hidden sm:block">•</span>
      <span class="flex items-center gap-2">
        <span class="font-display font-semibold">400+</span>
        <span class="text-white/70">Universities</span>
      </span>
      <span class="text-white/30 hidden sm:block">•</span>
      <span class="flex items-center gap-2">
        <span class="font-display font-semibold">18 Mo</span>
        <span class="text-white/70">Job Seeker Visa</span>
      </span>
    </div>
  </div>
</section>
<!-- HERO SECTION -->
<section class="min-h-screen flex items-center relative overflow-hidden py-20 lg:py-32 bg-[#1d1d1f]">
  <div class="absolute inset-0 z-0">
    <div class="absolute top-1/3 right-0 w-[1000px] h-[1000px] bg-gradient-radial from-[rgba(190,30,45,0.06)] via-transparent to-transparent rounded-full blur-3xl"></div>
  </div>
  <div class="max-w-[1400px] mx-auto px-6 lg:px-12 py-20 lg:py-32 relative z-10 w-full">
    <div class="max-w-4xl">
      <!-- Badge -->
      <div class="inline-flex items-center gap-3 px-4 py-2 border border-white/20 bg-white/5 backdrop-blur-sm mb-8 animate-fade-in-up">
        <span class="text-2xl">🇩🇪</span>
        <span class="text-xs font-medium tracking-[0.15em] uppercase text-white/80">Study in Germany</span>
      </div>
      <!-- Headline -->
      <h1 class="text-6xl md:text-7xl lg:text-8xl font-semibold leading-[1.04] tracking-[-0.02em] mb-8 animate-fade-in-up delay-100 text-white" style="font-family: var(--font-display);">
        Tuition-Free
        <br />
        <span class="text-[#be1e2d]">Education</span>
      </h1>
      <!-- Subheadline -->
      <p class="text-xl md:text-2xl text-white/70 max-w-2xl leading-relaxed mb-12 animate-fade-in-up delay-200">
        Master's programs in Data Science, AI, Engineering & more at Germany's top public universities. No tuition fees. World-class education.
      </p>
      <!-- CTA Buttons -->
      <div class="flex flex-col sm:flex-row gap-4 animate-fade-in-up delay-300">
        <button onclick="document.getElementById('lead-form-container')?.scrollIntoView({ behavior: 'smooth', block: 'center' })" class="group relative px-8 py-4 bg-[#be1e2d] text-white font-semibold tracking-wide overflow-hidden transition-all duration-300 hover:shadow-[0_0_40px_rgba(190,30,45,0.3)]">
          <span class="relative z-10 flex items-center justify-center gap-2">
            Start Application
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-1"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </span>
        </button>
      </div>
    </div>
  </div>
</section>
<!-- PROGRAMS SECTION -->
<section class="py-24 lg:py-32 bg-[#f5f5f7]">
  <div class="max-w-[1400px] mx-auto px-6 lg:px-12">
    <div class="max-w-3xl mb-16">
      <div class="text-xs tracking-[0.3em] uppercase text-[#be1e2d] mb-4">Programs</div>
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-semibold tracking-tight leading-[1.07] letter-tight" style="font-family: var(--font-display);">
        Popular Master's<br />Programs
      </h2>
    </div>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      <div class="group bg-white p-8 hover:shadow-[0_4px_24px_rgba(0,0,0,0.08)] transition-all duration-500">
        <div class="text-xs tracking-[0.2em] uppercase text-[#be1e2d] mb-4">Master of Science</div>
        <h3 class="text-2xl font-semibold mb-4" style="font-family: var(--font-display);">Data Science</h3>
        <p class="text-sm text-[#4b5563] mb-6">AI, Machine Learning, Big Data Analytics at top German technical universities.</p>
        <div class="flex justify-between items-center pt-6 border-t border-[#e5e7eb]">
          <div>
            <div class="text-xs text-[#6b7280]">Duration</div>
            <div class="text-[#111827]">2 Years</div>
          </div>
          <div class="text-right">
            <div class="text-xs text-[#6b7280]">Tuition</div>
            <div class="text-[#be1e2d] font-medium">FREE</div>
          </div>
        </div>
      </div>
      <div class="group bg-white p-8 hover:shadow-[0_4px_24px_rgba(0,0,0,0.08)] transition-all duration-500">
        <div class="text-xs tracking-[0.2em] uppercase text-[#be1e2d] mb-4">Master of Science</div>
        <h3 class="text-2xl font-semibold mb-4" style="font-family: var(--font-display);">Computer Science</h3>
        <p class="text-sm text-[#4b5563] mb-6">Software Engineering, Cybersecurity, Distributed Systems at TU Munich, TU Berlin.</p>
        <div class="flex justify-between items-center pt-6 border-t border-[#e5e7eb]">
          <div>
            <div class="text-xs text-[#6b7280]">Duration</div>
            <div class="text-[#111827]">2 Years</div>
          </div>
          <div class="text-right">
            <div class="text-xs text-[#6b7280]">Tuition</div>
            <div class="text-[#be1e2d] font-medium">FREE</div>
          </div>
        </div>
      </div>
      <div class="group bg-white p-8 hover:shadow-[0_4px_24px_rgba(0,0,0,0.08)] transition-all duration-500">
        <div class="text-xs tracking-[0.2em] uppercase text-[#be1e2d] mb-4">Master of Science</div>
        <h3 class="text-2xl font-semibold mb-4" style="font-family: var(--font-display);">Engineering</h3>
        <p class="text-sm text-[#4b5563] mb-6">Mechanical, Electrical, Automotive Engineering at world-renowned technical universities.</p>
        <div class="flex justify-between items-center pt-6 border-t border-[#e5e7eb]">
          <div>
            <div class="text-xs text-[#6b7280]">Duration</div>
            <div class="text-[#111827]">2 Years</div>
          </div>
          <div class="text-right">
            <div class="text-xs text-[#6b7280]">Tuition</div>
            <div class="text-[#be1e2d] font-medium">FREE</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
<!-- WHY GERMANY -->
<section class="py-24 lg:py-32 bg-[#1d1d1f]">
  <div class="max-w-[1400px] mx-auto px-6 lg:px-12">
    <div class="max-w-3xl mb-16">
      <div class="text-xs tracking-[0.3em] uppercase text-[#be1e2d] mb-4">Why Germany</div>
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-semibold tracking-tight leading-[1.07] letter-tight text-white" style="font-family: var(--font-display);">
        Why<br />Germany?
      </h2>
    </div>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      <div class="bg-white/5 backdrop-blur-sm border border-white/10 p-8 lg:p-10 group hover:bg-white/10 transition-colors duration-500">
        <div class="text-5xl font-light text-white/30 mb-4 group-hover:text-[#be1e2d] transition-colors" style="font-family: var(--font-display);">01</div>
        <h3 class="text-xl font-semibold mb-3 text-white" style="font-family: var(--font-display);">Tuition Free</h3>
        <p class="text-sm text-white/60">Public universities charge zero tuition. Just semester contribution (€150-350).</p>
      </div>
      <div class="bg-white/5 backdrop-blur-sm border border-white/10 p-8 lg:p-10 group hover:bg-white/10 transition-colors duration-500">
        <div class="text-5xl font-light text-white/30 mb-4 group-hover:text-[#be1e2d] transition-colors" style="font-family: var(--font-display);">02</div>
        <h3 class="text-xl font-semibold mb-3 text-white" style="font-family: var(--font-display);">World-Class Education</h3>
        <p class="text-sm text-white/60">German engineering and technical education is respected globally by employers.</p>
      </div>
      <div class="bg-white/5 backdrop-blur-sm border border-white/10 p-8 lg:p-10 group hover:bg-white/10 transition-colors duration-500">
        <div class="text-5xl font-light text-white/30 mb-4 group-hover:text-[#be1e2d] transition-colors" style="font-family: var(--font-display);">03</div>
        <h3 class="text-xl font-semibold mb-3 text-white" style="font-family: var(--font-display);">18-Month Job Seeker Visa</h3>
        <p class="text-sm text-white/60">Stay back and find employment in Europe's strongest economy after graduation.</p>
      </div>
      <div class="bg-white/5 backdrop-blur-sm border border-white/10 p-8 lg:p-10 group hover:bg-white/10 transition-colors duration-500">
        <div class="text-5xl font-light text-white/30 mb-4 group-hover:text-[#be1e2d] transition-colors" style="font-family: var(--font-display);">04</div>
        <h3 class="text-xl font-semibold mb-3 text-white" style="font-family: var(--font-display);">Work While Studying</h3>
        <p class="text-sm text-white/60">120 full days or 240 half days per year. Earn €12-15/hour.</p>
      </div>
      <div class="bg-white/5 backdrop-blur-sm border border-white/10 p-8 lg:p-10 group hover:bg-white/10 transition-colors duration-500">
        <div class="text-5xl font-light text-white/30 mb-4 group-hover:text-[#be1e2d] transition-colors" style="font-family: var(--font-display);">05</div>
        <h3 class="text-xl font-semibold mb-3 text-white" style="font-family: var(--font-display);">English Programs</h3>
        <p class="text-sm text-white/60">Over 1,500 Master's programs taught entirely in English. No German required.</p>
      </div>
      <div class="bg-white/5 backdrop-blur-sm border border-white/10 p-8 lg:p-10 group hover:bg-white/10 transition-colors duration-500">
        <div class="text-5xl font-light text-white/30 mb-4 group-hover:text-[#be1e2d] transition-colors" style="font-family: var(--font-display);">06</div>
        <h3 class="text-xl font-semibold mb-3 text-white" style="font-family: var(--font-display);">EU Blue Card Pathway</h3>
        <p class="text-sm text-white/60">Fast-track to permanent residency for skilled professionals.</p>
      </div>
    </div>
  </div>
</section>
<!-- ELIGIBILITY -->
<section class="py-24 lg:py-32 bg-[#f5f5f7]">
  <div class="max-w-[1400px] mx-auto px-6 lg:px-12">
    <div class="grid lg:grid-cols-2 gap-16">
      <div>
        <div class="text-xs tracking-[0.3em] uppercase text-[#be1e2d] mb-4">Requirements</div>
        <h2 class="text-4xl md:text-5xl font-semibold tracking-tight mb-8 leading-[1.07] letter-tight" style="font-family: var(--font-display);">
          Are You<br />Eligible?
        </h2>
        <p class="text-[#4b5563] mb-8">
          Germany has clear, transparent requirements. No backdoors. No shortcuts.
        </p>
        <ul class="space-y-4">
          <li class="flex gap-4">
            <span class="flex-shrink-0 w-6 h-6 border border-[#be1e2d] flex items-center justify-center text-[#be1e2d] text-xs">✓</span>
            <span class="text-[#4b5563]">Bachelor's degree in relevant field (min. 3 years)</span>
          </li>
          <li class="flex gap-4">
            <span class="flex-shrink-0 w-6 h-6 border border-[#be1e2d] flex items-center justify-center text-[#be1e2d] text-xs">✓</span>
            <span class="text-[#4b5563]">IELTS 6.5+ or TOEFL 90+ (English programs)</span>
          </li>
          <li class="flex gap-4">
            <span class="flex-shrink-0 w-6 h-6 border border-[#be1e2d] flex items-center justify-center text-[#be1e2d] text-xs">✓</span>
            <span class="text-[#4b5563]">GRE not required for most programs</span>
          </li>
          <li class="flex gap-4">
            <span class="flex-shrink-0 w-6 h-6 border border-[#be1e2d] flex items-center justify-center text-[#be1e2d] text-xs">✓</span>
            <span class="text-[#4b5563]">Blocked Account: €11,904 (one year living expenses)</span>
          </li>
        </ul>
      </div>
      <div class="bg-white rounded-xl p-8 lg:p-12 shadow-[0_4px_24px_rgba(0,0,0,0.06)]">
        <h3 class="text-2xl font-semibold mb-8" style="font-family: var(--font-display);">Important Deadlines</h3>
        <div class="space-y-8">
          <div class="pb-8 border-b border-[#e5e7eb]">
            <div class="flex items-center gap-3 mb-3">
              <span class="w-2 h-2 bg-[#be1e2d]"></span>
              <span class="text-xs tracking-[0.2em] uppercase text-[#be1e2d]">Winter Semester</span>
            </div>
            <div class="text-xl text-[#111827] mb-1" style="font-family: var(--font-display);">Applications: April - July</div>
            <div class="text-sm text-[#6b7280]">Classes start: October</div>
          </div>
          <div>
            <div class="flex items-center gap-3 mb-3">
              <span class="w-2 h-2 bg-[#6b7280]"></span>
              <span class="text-xs tracking-[0.2em] uppercase text-[#6b7280]">Summer Semester</span>
            </div>
            <div class="text-xl text-[#111827] mb-1" style="font-family: var(--font-display);">Applications: October - January</div>
            <div class="text-sm text-[#6b7280]">Classes start: April (limited programs)</div>
          </div>
        </div>
        <div class="mt-8 p-4 bg-[rgba(190, 30, 45, 0.08)] border border-[#be1e2d] rounded-lg">
          <p class="text-sm text-[#4b5563]">
            <strong class="text-[#be1e2d]">Note:</strong> Most English-taught Master's programs only accept Winter intake. Apply early — popular programs fill up.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
<!-- LEAD FORM -->
<section id="lead-form-container" class="py-24 lg:py-32">
  <div class="max-w-[1400px] mx-auto px-6 lg:px-12">
    <div class="max-w-2xl mx-auto">
      <div class="text-center mb-12">
        <div class="text-xs tracking-[0.3em] uppercase text-[#be1e2d] mb-4">Apply Now</div>
        <h2 class="text-4xl md:text-5xl font-semibold tracking-tight mb-4 leading-[1.07] letter-tight" style="font-family: var(--font-display);">
          Start Your<br />Application
        </h2>
      </div>
      <form id="lead-form" class="bg-white rounded-xl p-8 lg:p-12 shadow-[0_4px_24px_rgba(0,0,0,0.06)]">
        <div class="grid md:grid-cols-2 gap-6 mb-6">
          <div>
            <label class="form-label text-sm font-medium text-[#111827] mb-2 block">Full Name *</label>
            <input type="text" required class="w-full px-4 py-3 border border-[#e5e7eb] rounded-lg focus:outline-none focus:border-[#be1e2d] focus:ring-1 focus:ring-[#be1e2d] transition-all" placeholder="Your name">
          </div>
          <div>
            <label class="form-label text-sm font-medium text-[#111827] mb-2 block">Phone *</label>
            <input type="tel" required class="w-full px-4 py-3 border border-[#e5e7eb] rounded-lg focus:outline-none focus:border-[#be1e2d] focus:ring-1 focus:ring-[#be1e2d] transition-all" placeholder="+91...">
          </div>
        </div>
        <div class="mb-6">
          <label class="form-label text-sm font-medium text-[#111827] mb-2 block">Email *</label>
          <input type="email" required class="w-full px-4 py-3 border border-[#e5e7eb] rounded-lg focus:outline-none focus:border-[#be1e2d] focus:ring-1 focus:ring-[#be1e2d] transition-all" placeholder="email@example.com">
        </div>
        <div class="mb-8">
          <label class="form-label text-sm font-medium text-[#111827] mb-2 block">Program Interest</label>
          <select class="w-full px-4 py-3 border border-[#e5e7eb] rounded-lg focus:outline-none focus:border-[#be1e2d] focus:ring-1 focus:ring-[#be1e2d] transition-all bg-white">
            <option value="">Select program</option>
            <option value="data-science">MSc Data Science</option>
            <option value="cs">MSc Computer Science</option>
            <option value="engineering">MSc Engineering</option>
            <option value="business">MBA / Management</option>
            <option value="other">Other / Not Sure</option>
          </select>
        </div>
        <button type="submit" class="w-full py-5 bg-[#be1e2d] text-white font-semibold tracking-wide hover:shadow-[0_0_40px_rgba(190,30,45,0.25)] transition-all duration-300 flex items-center justify-center gap-3">
          Get Free Consultation
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </button>
      </form>
    </div>
  </div>
</section>
<!-- MOBILE STICKY CTA -->
<div class="fixed bottom-0 left-0 right-0 bg-white border-t border-[#e5e7eb] p-4 lg:hidden z-50">
  <div class="flex gap-3">
    <button onclick="document.getElementById('lead-form-container')?.scrollIntoView({ behavior: 'smooth', block: 'center' })" class="flex-1 py-3 bg-[#be1e2d] text-white font-semibold text-center">
      Start Application
    </button>
  </div>
</div>
<Footer />
<script>
document.getElementById('lead-form')?.addEventListener('submit', async (e) => {
  e.preventDefault();
  const btn = e.target.querySelector('button[type="submit"]');
  const originalText = btn.innerHTML;
  btn.innerHTML = `<svg class="animate-spin" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12a9 9 0 11-6.219-8.56"/></svg> SUBMITTING...`;
  btn.disabled = true;
  const name = e.target.querySelector('input[type="text"]').value.trim();
  const phone = e.target.querySelector('input[type="tel"]').value.trim();
  const email = e.target.querySelector('input[type="email"]').value.trim();
  const program = e.target.querySelector('select')?.value || '';
  let formattedPhone = phone;
  if (!formattedPhone.startsWith('+')) { formattedPhone = '+91' + formattedPhone.replace(/^0+/, ''); }
  const payload = { fields: { name, phone: formattedPhone, email, lead_source: 'Google Ads', facebook_campaign_name: 'Germany LP - Study Lead' } };
  const extraInfo = [];
  if (program) extraInfo.push('Program: ' + program);
  if (extraInfo.length > 0) payload.fields.notes = extraInfo.join(' | ');
  try {
    const response = await fetch('https://next-api.telecrm.in/enterprise/69a16e9a4ce16643f28061a1/autoupdatelead', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer bc0b7478-97ce-49b2-b96c-13ef444898311775379897519:0ba13bb8-04fb-4ec6-a9f8-e2ba4e6879f7' },
      body: JSON.stringify(payload),
    });
    if (!response.ok) console.error('TeleCRM error:', response.status, await response.text());
  } catch (err) { console.error('TeleCRM fetch error:', err); }
  btn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> Request Submitted`;
  btn.style.backgroundColor = '#22c55e';
  setTimeout(() => { btn.innerHTML = originalText; btn.style.backgroundColor = ''; btn.disabled = false; e.target.reset(); }, 3000);
});
</script>
</MainLayout>