  <Footer />

  <script>
    document.getElementById('lead-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const form = e.target as HTMLFormElement;
      const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      const original = btn.innerHTML;
      btn.disabled = true;
      btn.innerHTML = `<svg class="animate-spin" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12a9 9 0 11-6.219-8.56"/></svg> Sending…`;

      const fd = new FormData(form);
      const name = (fd.get('name') as string || '').trim();
      const phoneRaw = (fd.get('phone') as string || '').trim();
      const email = (fd.get('email') as string || '').trim();
      const neet = (fd.get('neet') as string || '').trim();
      const country = (fd.get('country') as string || '').trim();

      let phone = phoneRaw.replace(/[\s\-]/g, '');
      if (!phone.startsWith('+')) phone = '+91' + phone.replace(/^0+/, '');

      const notes: string[] = [];
      if (neet) notes.push('NEET Score: ' + neet);
      if (country) notes.push('Country: ' + country);

      const payload: any = {
        fields: {
          name, phone, email,
          lead_source: 'Google Ads',
          facebook_campaign_name: 'MBBS New LP - MBBS Lead',
        },
      };
      if (notes.length) payload.fields.notes = notes.join(' | ');

      // Mirror existing pages' analytics + backend logging
      (window as any).__sendToBackend && (window as any).__sendToBackend({
        form_type: 'mbbs-new-lp', name, phone, email, neet_score: neet, preferred_country: country,
      });

      try {
        await fetch('https://next-api.telecrm.in/enterprise/69a16e9a4ce16643f28061a1/autoupdatelead', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Authorization': 'Bearer bc0b7478-97ce-49b2-b96c-13ef444898311775379897519:0ba13bb8-04fb-4ec6-a9f8-e2ba4e6879f7',
          },
          body: JSON.stringify(payload),
          keepalive: true,
        });
        btn.innerHTML = 'Redirecting…';
        btn.style.backgroundColor = '#22c55e';
        setTimeout(() => { window.location.href = '/mbbs-thank-you'; }, 400);
      } catch {
        btn.disabled = false;
        btn.innerHTML = original;
        alert('Something went wrong. Please try again or call +91 97781 30583.');
      }
    });
  </script>
