---
import MainLayout from '../layouts/MainLayout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';

const title = "Gradiks — Premium Study Abroad Guidance for Kerala Students";
const description = "Serious, transparent study abroad guidance for Kerala students after 12th. Get a free profile review, shortlist the right countries, and speak to an expert advisor.";
---

<MainLayout title={title} description={description}>
<Navigation />
<!-- TRUST BAR -->
<section class="bg-[#232d61] py-4 mt-20 text-white">
  <div class="max-w-[1400px] mx-auto px-6 lg:px-12">
    <div class="flex flex-wrap justify-center items-center gap-8 lg:gap-16 text-white text-sm">
      <span class="flex items-center gap-2">
        <span class="font-display font-semibold">2,000+</span>
        <span class="text-white/70">Students Guided</span>
      </span>
      <span class="text-white/30 hidden sm:block">•</span>
      <span class="flex items-center gap-2">
        <span class="font-display font-semibold">98%</span>
        <span class="text-white/70">Success Rate</span>
      </span>
      <span class="text-white/30 hidden sm:block">•</span>
      <span class="flex items-center gap-2">
        <span class="font-display font-semibold">50+</span>
        <span class="text-white/70">Partner Universities</span>
      </span>
      <span class="text-white/30 hidden sm:block">•</span>
      <span class="flex items-center gap-2">
        <span class="font-display font-semibold">15+</span>
        <span class="text-white/70">Countries</span>
      </span>
    </div>
  </div>
</section>
<!-- HERO SECTION -->
<section class="relative overflow-hidden bg-white">
  <!-- Subtle gradient decoration -->
  <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-gradient-radial from-[rgba(190,30,45,0.04)] via-transparent to-transparent rounded-full blur-3xl"></div>
  <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-gradient-radial from-[rgba(35,45,97,0.03)] via-transparent to-transparent rounded-full blur-3xl"></div>

  <div class="max-w-[1200px] mx-auto px-6 lg:px-12 pt-32 lg:pt-44 pb-20 lg:pb-28 relative z-10">
    <div class="grid lg:grid-cols-2 gap-16 lg:gap-20 items-center">
      <!-- Left: Content -->
      <div>
        <!-- Badge -->
        <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-[rgba(21,190,83,0.12)] border border-[rgba(21,190,83,0.3)] mb-6 animate-fade-in-up" style="border-radius: 4px;">
          <span class="w-1.5 h-1.5 bg-[#15be53] rounded-full"></span>
          <span class="text-[0.8125rem] font-semibold tracking-[0.15em] uppercase text-[#108c3d]" style="font-family: var(--font-body);">Trusted by 2,000+ Families</span>
        </div>

        <!-- Headline -->
        <h1 class="hero-headline animate-fade-in-up delay-100" style="margin-bottom: 1.5rem;">
          Your Child's
          <br />
          <span class="hero-headline-accent">Medical</span> Dreams,
          <br />
          Our Honest Guidance
        </h1>

        <!-- Subheadline -->
        <p class="hero-subheadline animate-fade-in-up delay-200">
          Transparent MBBS admission support abroad. No false promises, no hidden fees — just clear advice for your family's future.
        </p>

        <!-- CTA Row -->
        <div class="hero-ctas animate-fade-in-up delay-300">
          <button onclick="document.getElementById('lead-form-container')?.scrollIntoView({ behavior: 'smooth', block: 'center' })" class="cta-primary">
            Get Free Assessment
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </button>
          <button onclick="document.getElementById('why-section')?.scrollIntoView({ behavior: 'smooth', block: 'start' })" class="cta-secondary">
            Learn More
          </button>
        </div>

        <!-- Trust micro-stats -->
        <div class="hero-meta animate-fade-in-up delay-400">
          <div class="flex items-center gap-2">
            <div class="flex -space-x-1.5">
              <img src="https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=32&h=32&fit=crop&crop=face" alt="" class="w-6 h-6 rounded-full border-2 border-white object-cover" />
              <img src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=32&h=32&fit=crop&crop=face" alt="" class="w-6 h-6 rounded-full border-2 border-white object-cover" />
              <img src="https://images.unsplash.com/photo-1438761681033-6461ffad8d80?w=32&h=32&fit=crop&crop=face" alt="" class="w-6 h-6 rounded-full border-2 border-white object-cover" />
            </div>
            <span>2,000+ students placed</span>
          </div>
          <span class="meta-dot">|</span>
          <div class="flex items-center gap-1">
            <span class="text-[#f59e0b]">★★★★★</span>
            <span>4.9/5 from parents</span>
          </div>
        </div>
      </div>

      <!-- Right: Visual card -->
      <div class="relative hidden lg:block animate-fade-in delay-500">
        <!-- Main card with Stripe-style shadow -->
        <div class="relative bg-white border border-[#e5edf5] overflow-hidden" style="border-radius: 8px; box-shadow: rgba(50,50,93,0.25) 0px 30px 45px -30px, rgba(0,0,0,0.1) 0px 18px 36px -18px;">
          <!-- Image top -->
          <div class="relative h-[240px] overflow-hidden">
            <img src="https://images.unsplash.com/photo-1612349317150-e413f6a5b16d?w=600&q=80&auto=format&fit=crop" alt="Doctor in white coat consulting with patient" class="w-full h-full object-cover" loading="eager" />
            <div class="absolute inset-0 bg-gradient-to-t from-white via-transparent to-transparent"></div>
          </div>

          <!-- Card body -->
          <div class="px-6 pb-6 -mt-8 relative">
            <!-- Floating stat pills -->
            <div class="grid grid-cols-3 gap-3 mb-5">
              <div class="bg-white border border-[#e5edf5] p-3 text-center" style="border-radius: 6px; box-shadow: rgba(23,23,23,0.06) 0px 3px 6px;">
                <div class="stat-val text-xl">2K+</div>
                <div class="text-[0.6875rem] text-[#6b7280] mt-0.5">Students</div>
              </div>
              <div class="bg-white border border-[#e5edf5] p-3 text-center" style="border-radius: 6px; box-shadow: rgba(23,23,23,0.06) 0px 3px 6px;">
                <div class="stat-val text-xl">50+</div>
                <div class="text-[0.6875rem] text-[#6b7280] mt-0.5">Universities</div>
              </div>
              <div class="bg-white border border-[#e5edf5] p-3 text-center" style="border-radius: 6px; box-shadow: rgba(23,23,23,0.06) 0px 3px 6px;">
                <div class="stat-val text-xl text-[#15be53]">98%</div>
                <div class="text-[0.6875rem] text-[#6b7280] mt-0.5">Success</div>
              </div>
            </div>

            <!-- Feature rows -->
            <div class="space-y-3">
              <div class="flex items-center gap-3 p-3 bg-[#f8f9fb] border border-[#e5edf5]" style="border-radius: 5px;">
                <div class="w-8 h-8 flex items-center justify-center bg-[rgba(21,190,83,0.12)]" style="border-radius: 4px;">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#15be53" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                </div>
                <div>
                  <div class="why-title text-sm" style="color: #111827; margin-bottom: 0.125rem;">NMC Verified</div>
                  <div class="text-[0.6875rem] text-[#6b7280]">All universities MCI/NMC approved</div>
                </div>
              </div>
              <div class="flex items-center gap-3 p-3 bg-[#f8f9fb] border border-[#e5edf5]" style="border-radius: 5px;">
                <div class="w-8 h-8 flex items-center justify-center bg-[rgba(83,58,253,0.08)]" style="border-radius: 4px;">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#533afd" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                </div>
                <div>
                  <div class="why-title text-sm" style="color: #111827; margin-bottom: 0.125rem;">15+ Countries</div>
                  <div class="text-[0.6875rem] text-[#6b7280]">Georgia, Germany, UK & more</div>
                </div>
              </div>
              <div class="flex items-center gap-3 p-3 bg-[#f8f9fb] border border-[#e5edf5]" style="border-radius: 5px;">
                <div class="w-8 h-8 flex items-center justify-center bg-[rgba(190,30,45,0.06)]" style="border-radius: 4px;">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#be1e2d" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                </div>
                <div>
                  <div class="why-title text-sm" style="color: #111827; margin-bottom: 0.125rem;">Transparent Pricing</div>
                  <div class="text-[0.6875rem] text-[#6b7280]">No hidden charges, ever</div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Decorative accent -->
        <div class="absolute -z-10 top-6 left-6 right-6 bottom-6 border border-[#e5edf5]" style="border-radius: 12px;"></div>
      </div>
    </div>
  </div>
</section>
<!-- WHY CHOOSE US -->
<section id="why-section" class="py-24 lg:py-32 bg-[#f5f5f7]">
  <div class="max-w-[1400px] mx-auto px-6 lg:px-12">
    <div class="max-w-3xl mb-16">
      <div class="text-xs tracking-[0.3em] uppercase text-[#be1e2d] mb-4">Why Choose Us</div>
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-semibold tracking-tight leading-[1.07] letter-tight" style="font-family: var(--font-display);">
        What Makes Us<br />Different
      </h2>
    </div>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      <div class="bg-white p-8 lg:p-10 group hover:shadow-[0_4px_24px_rgba(0,0,0,0.08)] transition-all duration-500">
        <div class="w-14 h-14 border border-[#e5e7eb] flex items-center justify-center mb-6 group-hover:border-[#be1e2d] group-hover:text-[#be1e2d] transition-all duration-300">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        </div>
        <h3 class="text-xl font-semibold mb-3" style="font-family: var(--font-display);">Brutally Honest</h3>
        <p class="text-sm text-[#4b5563] leading-relaxed">No sugarcoating. We tell you exactly which universities match your budget, marks, and career goals.</p>
      </div>
      <div class="bg-white p-8 lg:p-10 group hover:shadow-[0_4px_24px_rgba(0,0,0,0.08)] transition-all duration-500">
        <div class="w-14 h-14 border border-[#e5e7eb] flex items-center justify-center mb-6 group-hover:border-[#be1e2d] group-hover:text-[#be1e2d] transition-all duration-300">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        </div>
        <h3 class="text-xl font-semibold mb-3" style="font-family: var(--font-display);">Verified Only</h3>
        <p class="text-sm text-[#4b5563] leading-relaxed">Every university we recommend is MCI/NMC approved. No diploma mills, no surprises.</p>
      </div>
      <div class="bg-white p-8 lg:p-10 group hover:shadow-[0_4px_24px_rgba(0,0,0,0.08)] transition-all duration-500">
        <div class="w-14 h-14 border border-[#e5e7eb] flex items-center justify-center mb-6 group-hover:border-[#be1e2d] group-hover:text-[#be1e2d] transition-all duration-300">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
        </div>
        <h3 class="text-xl font-semibold mb-3" style="font-family: var(--font-display);">Transparent Pricing</h3>
        <p class="text-sm text-[#4b5563] leading-relaxed">Clear breakdown of tuition, living costs, and our fees. No hidden charges, ever.</p>
      </div>
      <div class="bg-white p-8 lg:p-10 group hover:shadow-[0_4px_24px_rgba(0,0,0,0.08)] transition-all duration-500">
        <div class="w-14 h-14 border border-[#e5e7eb] flex items-center justify-center mb-6 group-hover:border-[#be1e2d] group-hover:text-[#be1e2d] transition-all duration-300">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
        </div>
        <h3 class="text-xl font-semibold mb-3" style="font-family: var(--font-display);">End-to-End Support</h3>
        <p class="text-sm text-[#4b5563] leading-relaxed">From application to visa to FMGE coaching — we're with you for the entire journey.</p>
      </div>
      <div class="bg-white p-8 lg:p-10 group hover:shadow-[0_4px_24px_rgba(0,0,0,0.08)] transition-all duration-500">
        <div class="w-14 h-14 border border-[#e5e7eb] flex items-center justify-center mb-6 group-hover:border-[#be1e2d] group-hover:text-[#be1e2d] transition-all duration-300">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        </div>
        <h3 class="text-xl font-semibold mb-3" style="font-family: var(--font-display);">Parent Updates</h3>
        <p class="text-sm text-[#4b5563] leading-relaxed">Regular updates for parents, campus visits arranged, and 24/7 emergency support.</p>
      </div>
      <div class="bg-white p-8 lg:p-10 group hover:shadow-[0_4px_24px_rgba(0,0,0,0.08)] transition-all duration-500">
        <div class="w-14 h-14 border border-[#e5e7eb] flex items-center justify-center mb-6 group-hover:border-[#be1e2d] group-hover:text-[#be1e2d] transition-all duration-300">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/></svg>
        </div>
        <h3 class="text-xl font-semibold mb-3" style="font-family: var(--font-display);">FMGE Success</h3>
        <p class="text-sm text-[#4b5563] leading-relaxed">Proven coaching programs to help you clear the FMGE and practice in India.</p>
      </div>
    </div>
  </div>
</section>
<!-- HOW IT WORKS -->
<section id="how-it-works" class="py-24 lg:py-32 bg-white">
  <div class="max-w-[1400px] mx-auto px-6 lg:px-12">
    <div class="text-center max-w-2xl mx-auto mb-16">
      <div class="section-eyebrow mb-4">How It Works</div>
      <h2 class="section-headline" style="margin-top: 0.5rem;">Your Journey to<br />Medical School</h2>
      <p class="section-desc mx-auto mt-4" style="text-align: center;">From your first enquiry to your first day at university — we handle everything in 4 simple steps.</p>
    </div>
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-6">
      <!-- Step 1 -->
      <div class="relative text-center group">
        <div class="w-16 h-16 mx-auto mb-6 flex items-center justify-center bg-[rgba(190,30,45,0.08)] rounded-2xl group-hover:bg-[#be1e2d] transition-all duration-300">
          <span class="font-display text-2xl font-bold text-[#be1e2d] group-hover:text-white transition-colors duration-300">01</span>
        </div>
        <div class="hidden lg:block absolute top-8 left-[calc(50%+2rem)] w-[calc(100%-4rem)] border-t border-dashed border-[#e5e7eb]"></div>
        <h3 class="font-display text-lg font-semibold text-[#111827] mb-2">Free Consultation</h3>
        <p class="text-sm text-[#4b5563] leading-relaxed">Share your NEET score, budget, and preferences. We assess your profile and suggest the best-fit countries and universities.</p>
      </div>
      <!-- Step 2 -->
      <div class="relative text-center group">
        <div class="w-16 h-16 mx-auto mb-6 flex items-center justify-center bg-[rgba(190,30,45,0.08)] rounded-2xl group-hover:bg-[#be1e2d] transition-all duration-300">
          <span class="font-display text-2xl font-bold text-[#be1e2d] group-hover:text-white transition-colors duration-300">02</span>
        </div>
        <div class="hidden lg:block absolute top-8 left-[calc(50%+2rem)] w-[calc(100%-4rem)] border-t border-dashed border-[#e5e7eb]"></div>
        <h3 class="font-display text-lg font-semibold text-[#111827] mb-2">University Selection</h3>
        <p class="text-sm text-[#4b5563] leading-relaxed">We present verified options with honest fee breakdowns, campus details, and success records. No pressure, no false promises.</p>
      </div>
      <!-- Step 3 -->
      <div class="relative text-center group">
        <div class="w-16 h-16 mx-auto mb-6 flex items-center justify-center bg-[rgba(190,30,45,0.08)] rounded-2xl group-hover:bg-[#be1e2d] transition-all duration-300">
          <span class="font-display text-2xl font-bold text-[#be1e2d] group-hover:text-white transition-colors duration-300">03</span>
        </div>
        <div class="hidden lg:block absolute top-8 left-[calc(50%+2rem)] w-[calc(100%-4rem)] border-t border-dashed border-[#e5e7eb]"></div>
        <h3 class="font-display text-lg font-semibold text-[#111827] mb-2">Application & Visa</h3>
        <p class="text-sm text-[#4b5563] leading-relaxed">We handle documentation, university applications, visa processing, and travel arrangements end-to-end.</p>
      </div>
      <!-- Step 4 -->
      <div class="relative text-center group">
        <div class="w-16 h-16 mx-auto mb-6 flex items-center justify-center bg-[rgba(190,30,45,0.08)] rounded-2xl group-hover:bg-[#be1e2d] transition-all duration-300">
          <span class="font-display text-2xl font-bold text-[#be1e2d] group-hover:text-white transition-colors duration-300">04</span>
        </div>
        <h3 class="font-display text-lg font-semibold text-[#111827] mb-2">Arrival & Support</h3>
        <p class="text-sm text-[#4b5563] leading-relaxed">Airport pickup, hostel setup, Indian food arrangements, and ongoing support including FMGE coaching until you graduate.</p>
      </div>
    </div>
  </div>
</section>
<!-- COUNTRIES SECTION -->
<section class="py-24 lg:py-32 bg-[#1d1d1f] text-white">
  <div class="max-w-[1400px] mx-auto px-6 lg:px-12">
    <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-8 mb-16">
      <div class="max-w-2xl">
        <div class="text-xs tracking-[0.3em] uppercase text-[#be1e2d] mb-4">Destinations</div>
        <h2 class="text-4xl md:text-5xl lg:text-6xl font-semibold tracking-tight leading-[1.07] letter-tight text-white" style="font-family: var(--font-display);">
          Top Countries for<br />MBBS
        </h2>
      </div>
      <p class="text-white/60 max-w-md lg:text-right">
        Choose from world's best medical universities with affordable fees and global recognition.
      </p>
    </div>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      <!-- Georgia -->
      <a href="/georgia-study" class="group relative bg-white/5 backdrop-blur-sm border border-white/10 p-8 lg:p-10 hover:border-[#be1e2d] transition-all duration-500 overflow-hidden">
        <div class="absolute top-0 right-0 w-32 h-32 bg-gradient-radial from-[rgba(190,30,45,0.15)] to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        <div class="relative z-10">
          <div class="text-4xl mb-6">🇬🇪</div>
          <h3 class="text-2xl font-semibold mb-3 text-white" style="font-family: var(--font-display);">Georgia</h3>
          <p class="text-sm text-white/60 mb-6">Affordable MBBS in Tbilisi with English-medium programs and NMC-approved universities.</p>
          <div class="flex items-center gap-2 text-[#be1e2d] text-sm font-medium">
            <span>Explore</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </div>
        </div>
      </a>
      <!-- Uzbekistan -->
      <a href="/uzbekistan-study" class="group relative bg-white/5 backdrop-blur-sm border border-white/10 p-8 lg:p-10 hover:border-[#be1e2d] transition-all duration-500 overflow-hidden">
        <div class="absolute top-0 right-0 w-32 h-32 bg-gradient-radial from-[rgba(190,30,45,0.15)] to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        <div class="relative z-10">
          <div class="text-4xl mb-6">🇺🇿</div>
          <h3 class="text-2xl font-semibold mb-3 text-white" style="font-family: var(--font-display);">Uzbekistan</h3>
          <p class="text-sm text-white/60 mb-6">Low-cost MBBS with Indian student-friendly environment and WHO-recognized universities.</p>
