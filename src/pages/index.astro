  btn.innerHTML = 'SENDING...';
  Promise.race([sent, timeout]).then(() => {
    btn.innerHTML = 'REDIRECTING...';
    btn.style.backgroundColor = '#22c55e';
    setTimeout(() => { window.location.href = '/mbbs-thank-you'; }, 500);
  });
});
</script>
</MainLayout>
