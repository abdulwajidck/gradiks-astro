---
import MainLayout from '../layouts/MainLayout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';

const title = "Gradiks — Premium Study Abroad Guidance for Kerala Students";
const description = "Serious, transparent study abroad guidance for Kerala students after 12th. Get a free profile review, shortlist the right countries, and speak to an expert advisor.";
---

<MainLayout title={title} description={description}>
  <Navigation />

  <!-- HERO SECTION -->
  <section class="relative overflow-hidden pt-28 lg:pt-36 pb-20 lg:pb-28">
    <div class="absolute inset-0 z-0">
      <div class="absolute inset-x-0 top-0 h-[36rem] bg-[linear-gradient(180deg,rgba(190,30,45,0.08),rgba(190,30,45,0))]"></div>
      <div class="absolute top-[12%] right-[-8%] h-[38rem] w-[38rem] rounded-full bg-[radial-gradient(circle,rgba(35,45,97,0.12),transparent_65%)] blur-3xl"></div>
      <div class="absolute bottom-[-10%] left-[-8%] h-[32rem] w-[32rem] rounded-full bg-[radial-gradient(circle,rgba(190,30,45,0.12),transparent_65%)] blur-3xl"></div>
    </div>

    <div class="relative z-10 mx-auto grid max-w-[1400px] gap-14 px-6 lg:grid-cols-[minmax(0,1.1fr)_30rem] lg:items-start lg:gap-12 lg:px-12">
      <div class="space-y-8 lg:space-y-10">
        <div class="flex flex-col gap-4 animate-fade-in-up">
          <div class="inline-flex w-fit items-center gap-3 border border-[rgba(190,30,45,0.18)] bg-white/90 px-4 py-2 text-[11px] font-semibold uppercase tracking-[0.22em] text-[#7c2d12] shadow-[0_20px_60px_rgba(17,24,39,0.06)] backdrop-blur">
            <span class="h-2 w-2 rounded-full bg-[#be1e2d] animate-pulse"></span>
            Trusted guidance for Kerala students after 12th
          </div>
          <div class="max-w-4xl space-y-5">
            <h1 class="max-w-4xl text-[clamp(3.2rem,7vw,6.8rem)] font-semibold leading-[0.92] tracking-[-0.04em] text-[#111827] animate-fade-in-up delay-100" style="font-family: var(--font-display);">
              STUDY ABROAD
              <span class="block text-[#be1e2d]">WITHOUT COSTLY</span>
              WRONG TURNS
            </h1>
            <p class="max-w-2xl text-lg leading-8 text-[#4b5563] animate-fade-in-up delay-200 md:text-xl">
              Gradiks helps students and families from Kerala choose the right country, course, and pathway after 12th — with clear advice, realistic budgets, and premium one-to-one support.
            </p>
          </div>
        </div>

        <div class="grid gap-4 text-sm text-[#374151] md:grid-cols-3 animate-fade-in-up delay-300">
          <div class="border border-[#e5e7eb] bg-white/80 p-4 shadow-[0_14px_40px_rgba(17,24,39,0.04)] backdrop-blur">
            <div class="mb-2 text-[11px] font-semibold uppercase tracking-[0.22em] text-[#9a3412]">Built for clarity</div>
            <p>No pressure tactics. Just the right options for your marks, budget, and long-term plan.</p>
          </div>
          <div class="border border-[#e5e7eb] bg-white/80 p-4 shadow-[0_14px_40px_rgba(17,24,39,0.04)] backdrop-blur">
            <div class="mb-2 text-[11px] font-semibold uppercase tracking-[0.22em] text-[#9a3412]">Shortlist faster</div>
            <p>Get country and course guidance before wasting time on random applications.</p>
          </div>
          <div class="border border-[#e5e7eb] bg-white/80 p-4 shadow-[0_14px_40px_rgba(17,24,39,0.04)] backdrop-blur">
            <div class="mb-2 text-[11px] font-semibold uppercase tracking-[0.22em] text-[#9a3412]">Family-first support</div>
            <p>Serious handholding for both students and parents through every decision.</p>
          </div>
        </div>

        <div class="flex flex-col gap-4 sm:flex-row animate-fade-in-up delay-400">
          <button onclick="document.getElementById('lead-form-container')?.scrollIntoView({ behavior: 'smooth', block: 'start' })" class="group inline-flex items-center justify-center gap-3 bg-[#111827] px-8 py-4 text-sm font-semibold uppercase tracking-[0.18em] text-white transition-all duration-300 hover:-translate-y-0.5 hover:bg-[#0f172a] hover:shadow-[0_24px_60px_rgba(17,24,39,0.24)]">
            Get Free Profile Review
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-1"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </button>
          <a href="tel:+919****3210" class="inline-flex items-center justify-center gap-3 border border-[#d1d5db] bg-white px-8 py-4 text-sm font-semibold uppercase tracking-[0.18em] text-[#111827] transition-all duration-300 hover:border-[#111827] hover:shadow-[0_18px_45px_rgba(17,24,39,0.08)]">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Talk to an Advisor
          </a>
        </div>

        <div class="flex flex-wrap items-center gap-x-8 gap-y-3 border-t border-[#e5e7eb] pt-6 text-sm text-[#4b5563] animate-fade-in-up delay-500">
          <div class="flex items-center gap-2"><span class="text-[#be1e2d]">●</span> Free first consultation</div>
          <div class="flex items-center gap-2"><span class="text-[#be1e2d]">●</span> Parent-friendly guidance</div>
          <div class="flex items-center gap-2"><span class="text-[#be1e2d]">●</span> Response within 24 hours</div>
        </div>
      </div>

      <aside class="animate-fade-in delay-300 lg:sticky lg:top-28">
        <div class="overflow-hidden border border-[rgba(17,24,39,0.08)] bg-[linear-gradient(180deg,#fff,#f8f7f4)] shadow-[0_30px_80px_rgba(17,24,39,0.12)]">
          <div class="border-b border-[#ece7df] px-7 py-6 lg:px-8">
            <div class="mb-2 text-[11px] font-semibold uppercase tracking-[0.28em] text-[#9a3412]">Priority intake</div>
            <h2 class="text-3xl font-semibold tracking-[-0.03em] text-[#111827]" style="font-family: var(--font-display);">Get your shortlist started</h2>
            <p class="mt-3 text-sm leading-6 text-[#4b5563]">Tell us where you are right now. We’ll help you identify the right next step based on marks, interest, and budget.</p>
          </div>

          <form id="lead-form" class="space-y-5 px-7 py-7 lg:px-8 lg:py-8">
            <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-1">
              <div>
                <label class="form-label" for="student-name">Student Name *</label>
                <input id="student-name" name="studentName" type="text" required class="form-input" placeholder="Full name" />
              </div>
              <div>
                <label class="form-label" for="parent-phone">Student / Parent Phone *</label>
                <input id="parent-phone" name="phone" type="tel" required class="form-input" placeholder="+91 98765 43210" />
              </div>
            </div>

            <div>
              <label class="form-label" for="email-address">Email Address *</label>
              <input id="email-address" name="email" type="email" required class="form-input" placeholder="email@example.com" />
            </div>

            <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-2">
              <div>
                <label class="form-label" for="qualification">Current Stage *</label>
                <select id="qualification" name="qualification" class="form-select" required>
                  <option value="" class="bg-white">Select stage</option>
                  <option value="completed-12th" class="bg-white">Completed 12th</option>
                  <option value="appearing-12th" class="bg-white">Appearing for 12th</option>
                  <option value="neet-repeat" class="bg-white">NEET repeat / gap year</option>
                  <option value="other" class="bg-white">Other</option>
                </select>
              </div>
              <div>
                <label class="form-label" for="preferred-country">Preferred Country</label>
                <select id="preferred-country" name="preferredCountry" class="form-select">
                  <option value="" class="bg-white">Not sure yet</option>
                  <option value="germany" class="bg-white">Germany</option>
                  <option value="ireland" class="bg-white">Ireland</option>
                  <option value="uk" class="bg-white">United Kingdom</option>
                  <option value="india" class="bg-white">India</option>
                  <option value="other" class="bg-white">Other</option>
                </select>
              </div>
            </div>

            <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-2">
              <div>
                <label class="form-label" for="neet-score">NEET Score</label>
                <input id="neet-score" name="neetScore" type="number" class="form-input" placeholder="If available" />
              </div>
              <div>
                <label class="form-label" for="budget-range">Budget Range</label>
                <select id="budget-range" name="budget" class="form-select">
                  <option value="" class="bg-white">Select budget</option>
                  <option value="below-15" class="bg-white">Below ₹15L / year</option>
                  <option value="15-25" class="bg-white">₹15L – ₹25L / year</option>
                  <option value="25-40" class="bg-white">₹25L – ₹40L / year</option>
                  <option value="above-40" class="bg-white">Above ₹40L / year</option>
                </select>
              </div>
            </div>

            <div>
              <label class="form-label" for="message">What do you need help with?</label>
              <textarea id="message" name="message" class="form-textarea min-h-[110px]" placeholder="Tell us the course, country, or concern you want help with."></textarea>
            </div>

            <div class="rounded-none border border-[#eadfd3] bg-[#fffaf4] p-4 text-sm leading-6 text-[#5b4635]">
              <div class="font-semibold text-[#111827]">What happens after you submit?</div>
              <ul class="mt-2 space-y-1.5">
                <li>• We review your profile and preferred path</li>
                <li>• An advisor contacts you within 24 hours</li>
                <li>• You get the next best step — not a generic pitch</li>
              </ul>
            </div>

            <button type="submit" class="inline-flex w-full items-center justify-center gap-3 bg-[#be1e2d] px-6 py-5 text-sm font-semibold uppercase tracking-[0.18em] text-white transition-all duration-300 hover:-translate-y-0.5 hover:bg-[#a81826] hover:shadow-[0_24px_60px_rgba(190,30,45,0.24)]">
              Request Free Consultation
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </button>

            <p class="text-center text-xs leading-5 text-[#6b7280]">
              By submitting, you agree to our privacy policy. Your details stay private and are used only to contact you about your enquiry.
            </p>
          </form>
        </div>
      </aside>
    </div>
  </section>

  <!-- TRUST STRIP -->
  <section class="border-y border-[#e5e7eb] bg-[#f8f7f4] py-12">
    <div class="mx-auto flex max-w-[1400px] flex-col gap-8 px-6 lg:flex-row lg:items-center lg:justify-between lg:px-12">
      <div>
        <div class="text-[11px] font-semibold uppercase tracking-[0.26em] text-[#9a3412]">Why families trust Gradiks</div>
        <p class="mt-3 max-w-xl text-base leading-7 text-[#4b5563]">Students are not looking for hype. Parents are not looking for guesswork. This page is built to show certainty, seriousness, and the right next move.</p>
      </div>
      <div class="grid grid-cols-2 gap-x-10 gap-y-6 text-sm text-[#374151] md:grid-cols-4">
        <div>
          <div class="text-3xl font-semibold text-[#111827]" style="font-family: var(--font-display);">2,000+</div>
          <div class="mt-1 uppercase tracking-[0.18em] text-[11px] text-[#6b7280]">Families guided</div>
        </div>
        <div>
          <div class="text-3xl font-semibold text-[#111827]" style="font-family: var(--font-display);">50+</div>
          <div class="mt-1 uppercase tracking-[0.18em] text-[11px] text-[#6b7280]">Partner universities</div>
        </div>
        <div>
          <div class="text-3xl font-semibold text-[#111827]" style="font-family: var(--font-display);">15+</div>
          <div class="mt-1 uppercase tracking-[0.18em] text-[11px] text-[#6b7280]">Countries</div>
        </div>
        <div>
          <div class="text-3xl font-semibold text-[#111827]" style="font-family: var(--font-display);">24h</div>
          <div class="mt-1 uppercase tracking-[0.18em] text-[11px] text-[#6b7280]">Response target</div>
        </div>
      </div>
    </div>
  </section>

  <!-- VALUE SECTION -->
  <section class="py-24 lg:py-32">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-12">
      <div class="grid gap-14 lg:grid-cols-[0.9fr_1.1fr] lg:gap-16">
        <div class="space-y-5">
          <div class="text-[11px] font-semibold uppercase tracking-[0.28em] text-[#9a3412]">What makes the approach premium</div>
          <h2 class="text-[clamp(2.6rem,4.5vw,5rem)] font-semibold leading-[0.95] tracking-[-0.04em] text-[#111827]" style="font-family: var(--font-display);">
            STRATEGY FIRST.
            <span class="block text-[#4b5563]">APPLICATIONS AFTER.</span>
          </h2>
          <p class="max-w-xl text-lg leading-8 text-[#4b5563]">A lot of students lose time because they start with country names instead of the right plan. Gradiks makes the decision path clear before you commit money, exams, or paperwork.</p>
        </div>

        <div class="grid gap-px bg-[#e5e7eb] md:grid-cols-2">
          <div class="bg-white p-8 lg:p-10">
            <div class="mb-6 flex h-12 w-12 items-center justify-center border border-[#e5e7eb] text-[#be1e2d]">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
            </div>
            <h3 class="text-xl font-semibold text-[#111827]" style="font-family: var(--font-display);">Honest profile evaluation</h3>
            <p class="mt-3 text-sm leading-7 text-[#4b5563]">We help you see what is realistic now, what needs improvement, and which route makes sense for your goals.</p>
          </div>
          <div class="bg-white p-8 lg:p-10">
            <div class="mb-6 flex h-12 w-12 items-center justify-center border border-[#e5e7eb] text-[#be1e2d]">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            </div>
            <h3 class="text-xl font-semibold text-[#111827]" style="font-family: var(--font-display);">Verified options only</h3>
            <p class="mt-3 text-sm leading-7 text-[#4b5563]">No inflated promises. No low-trust institutions. Only pathways that can stand up to scrutiny from students and parents.</p>
          </div>
          <div class="bg-white p-8 lg:p-10">
            <div class="mb-6 flex h-12 w-12 items-center justify-center border border-[#e5e7eb] text-[#be1e2d]">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
            </div>
            <h3 class="text-xl font-semibold text-[#111827]" style="font-family: var(--font-display);">Budget clarity from the start</h3>
            <p class="mt-3 text-sm leading-7 text-[#4b5563]">Families can plan better when the tuition, living costs, and process fees are discussed clearly upfront.</p>
          </div>
          <div class="bg-white p-8 lg:p-10">
            <div class="mb-6 flex h-12 w-12 items-center justify-center border border-[#e5e7eb] text-[#be1e2d]">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
            </div>
            <h3 class="text-xl font-semibold text-[#111827]" style="font-family: var(--font-display);">Guidance beyond the first call</h3>
            <p class="mt-3 text-sm leading-7 text-[#4b5563]">From shortlist to documentation, the experience is designed to feel serious, structured, and dependable.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- DESTINATIONS SECTION -->
  <section class="border-y border-[#e5e7eb] bg-[#f8f7f4] py-24 lg:py-32">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-12">
      <div class="mb-14 flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
        <div class="max-w-3xl">
          <div class="text-[11px] font-semibold uppercase tracking-[0.28em] text-[#9a3412]">Popular destinations</div>
          <h2 class="mt-4 text-[clamp(2.6rem,4.8vw,5rem)] font-semibold leading-[0.95] tracking-[-0.04em] text-[#111827]" style="font-family: var(--font-display);">
            CHOOSE THE RIGHT
            <span class="block text-[#4b5563]">PATH, NOT JUST A COUNTRY</span>
          </h2>
        </div>
        <p class="max-w-lg text-base leading-7 text-[#4b5563]">Every destination has different costs, timelines, language expectations, and career outcomes. The right move depends on fit, not hype.</p>
      </div>

      <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
        <a href="/germany-study" class="group border border-[#e5e7eb] bg-white p-8 transition-all duration-300 hover:-translate-y-1 hover:border-[#be1e2d] hover:shadow-[0_22px_50px_rgba(17,24,39,0.08)]">
          <div class="text-4xl">🇩🇪</div>
          <h3 class="mt-8 text-2xl font-semibold text-[#111827]" style="font-family: var(--font-display);">Germany</h3>
          <p class="mt-3 text-sm leading-7 text-[#4b5563]">For students looking at strong academic reputation, structure, and long-term value.</p>
          <div class="mt-8 inline-flex items-center gap-2 text-sm font-semibold uppercase tracking-[0.16em] text-[#be1e2d]">
            Explore option
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-1"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </div>
        </a>

        <a href="/ireland-study" class="group border border-[#e5e7eb] bg-white p-8 transition-all duration-300 hover:-translate-y-1 hover:border-[#be1e2d] hover:shadow-[0_22px_50px_rgba(17,24,39,0.08)]">
          <div class="text-4xl">🇮🇪</div>
          <h3 class="mt-8 text-2xl font-semibold text-[#111827]" style="font-family: var(--font-display);">Ireland</h3>
          <p class="mt-3 text-sm leading-7 text-[#4b5563]">A strong choice for English-speaking study, global exposure, and a cleaner transition path.</p>
          <div class="mt-8 inline-flex items-center gap-2 text-sm font-semibold uppercase tracking-[0.16em] text-[#be1e2d]">
            Explore option
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-1"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </div>
        </a>

        <a href="/uk-study" class="group border border-[#e5e7eb] bg-white p-8 transition-all duration-300 hover:-translate-y-1 hover:border-[#be1e2d] hover:shadow-[0_22px_50px_rgba(17,24,39,0.08)]">
          <div class="text-4xl">🇬🇧</div>
          <h3 class="mt-8 text-2xl font-semibold text-[#111827]" style="font-family: var(--font-display);">United Kingdom</h3>
          <p class="mt-3 text-sm leading-7 text-[#4b5563]">For families aiming for premium institutions, strong recognition, and a globally legible degree path.</p>
          <div class="mt-8 inline-flex items-center gap-2 text-sm font-semibold uppercase tracking-[0.16em] text-[#be1e2d]">
            Explore option
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-1"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </div>
        </a>

        <a href="/india-medical" class="group border border-[#e5e7eb] bg-white p-8 transition-all duration-300 hover:-translate-y-1 hover:border-[#be1e2d] hover:shadow-[0_22px_50px_rgba(17,24,39,0.08)]">
          <div class="text-4xl">🇮🇳</div>
          <h3 class="mt-8 text-2xl font-semibold text-[#111827]" style="font-family: var(--font-display);">India Medical</h3>
          <p class="mt-3 text-sm leading-7 text-[#4b5563]">For students who need counselling support, planning help, and clarity around the India route as well.</p>
          <div class="mt-8 inline-flex items-center gap-2 text-sm font-semibold uppercase tracking-[0.16em] text-[#be1e2d]">
            Explore option
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-1"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </div>
        </a>

        <a href="/nursing-abroad" class="group border border-[#e5e7eb] bg-white p-8 transition-all duration-300 hover:-translate-y-1 hover:border-[#be1e2d] hover:shadow-[0_22px_50px_rgba(17,24,39,0.08)]">
          <div class="text-4xl">🩺</div>
