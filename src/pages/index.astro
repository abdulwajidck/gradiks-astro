// Custom video player for brand film
const videoContainer = document.getElementById('gradiks-video-container');
const video = document.getElementById('gradiks-brand-video');
const overlay = document.getElementById('gradiks-video-overlay');
const playBtn = document.getElementById('gradiks-video-play-btn');

if (video && overlay && playBtn && videoContainer) {
  const playVideo = () => {
    video.play().catch(() => {});
    videoContainer.classList.add('playing');
    overlay.style.display = 'none';
  };

  playBtn.addEventListener('click', playVideo);
  videoContainer.addEventListener('click', (e) => {
    if (!video.paused) return;
    if (e.target === playBtn || playBtn.contains(e.target)) return;
    playVideo();
  });

  video.addEventListener('ended', () => {
    videoContainer.classList.remove('playing');
    overlay.style.display = '';
  });

  // Pause when scrolling out of view (performance + UX)
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (!entry.isIntersecting && !video.paused) {
        video.pause();
      }
    });
  }, { threshold: 0.25 });
  observer.observe(videoContainer);
}
</script>
