---
import MainLayout from '../layouts/MainLayout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';

const title = "Gradiks — Premium Study Abroad Guidance for Kerala Students";
const description = "Serious, transparent study abroad guidance for Kerala students after 12th. Get a free profile review, shortlist the right countries, and speak to an expert advisor.";
---

<MainLayout title={title} description={description}>
<Navigation />
<!-- TRUST BAR -->
<section class="bg-[#232d61] py-3.5 mt-20 text-white overflow-hidden">
  <div class="max-w-[1400px] mx-auto px-6 lg:px-12">
    <div class="flex flex-wrap justify-center items-center gap-6 lg:gap-14 text-white text-[0.8125rem]">
      <span class="flex items-center gap-2.5">
        <span class="font-display font-bold text-base tabular-nums" style="font-variant-numeric: tabular-nums;">2,000+</span>
        <span class="text-white/60">Students Guided</span>
      </span>
      <span class="text-white/20 hidden sm:block">|</span>
      <span class="flex items-center gap-2.5">
        <span class="font-display font-bold text-base tabular-nums">98%</span>
        <span class="text-white/60">Admission Success</span>
      </span>
      <span class="text-white/20 hidden sm:block">|</span>
      <span class="flex items-center gap-2.5">
        <span class="font-display font-bold text-base tabular-nums">50+</span>
        <span class="text-white/60">Partner Universities</span>
      </span>
      <span class="text-white/20 hidden sm:block">|</span>
      <span class="flex items-center gap-2.5">
        <span class="font-display font-bold text-base tabular-nums">15+</span>
        <span class="text-white/60">Countries</span>
      </span>
    </div>
  </div>
</section>

<!-- HERO SECTION -->
<section class="relative overflow-hidden bg-white">
  <div class="absolute top-0 right-0 w-[700px] h-[700px] bg-gradient-radial from-[oklch(0.55_0.18_25/0.04)] via-transparent to-transparent rounded-full blur-3xl pointer-events-none"></div>
  <div class="absolute bottom-0 left-0 w-[500px] h-[500px] bg-gradient-radial from-[oklch(0.35_0.08_260/0.03)] via-transparent to-transparent rounded-full blur-3xl pointer-events-none"></div>

  <div class="max-w-[1200px] mx-auto px-6 lg:px-12 pt-5 lg:pt-40 pb-4 lg:pb-32 relative z-10">
    <div class="grid lg:grid-cols-[1.15fr_0.85fr] gap-12 lg:gap-20 items-start">
      <!-- Left: Content -->
      <div>
        <!-- Badge -->
        <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-[oklch(0.85_0.12_145/0.15)] border border-[oklch(0.65_0.15_145/0.3)] mb-2 lg:mb-5 animate-fade-in-up" style="border-radius: 4px;">
          <span class="w-1.5 h-1.5 bg-[#15be53] rounded-full animate-pulse"></span>
          <span class="text-[0.8125rem] font-semibold tracking-[0.12em] uppercase text-[oklch(0.45_0.12_150)]" style="font-family: var(--font-body);">Trusted by 2,000+ Families</span>
        </div>

        <!-- Headline -->
        <h1 class="hero-headline animate-fade-in-up delay-100 !text-[1.7rem] !leading-[1.12] lg:!text-[clamp(2.75rem,5.5vw,4.25rem)] lg:!leading-[1.06]">
          <span class="text-[oklch(0.3_0.02_260)]">Your Child Deserves</span>
          <br />
          <span class="hero-headline-accent">Honest</span> <span class="text-[oklch(0.3_0.02_260)]">Medical</span>
          <br class="hidden lg:inline" />
          <span class="text-[oklch(0.3_0.02_260)]">Career Guidance</span>
        </h1>

        <!-- Subheadline -->
        <p class="hero-subheadline animate-fade-in-up delay-200 !max-w-[440px]">
          Transparent MBBS admissions abroad. No false promises, no hidden fees. Clear advice backed by 2,000+ successful placements.
        </p>

        <!-- Desktop CTA Row -->
        <div class="hero-ctas animate-fade-in-up delay-300">
          <button onclick="document.getElementById('lead-form-container')?.scrollIntoView({ behavior: 'smooth', block: 'center' })" class="cta-primary hidden lg:inline-flex">
            Get Free Assessment
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </button>
          <button onclick="document.getElementById('why-section')?.scrollIntoView({ behavior: 'smooth', block: 'start' })" class="cta-secondary hidden lg:inline-flex">
            Why Gradiks
          </button>

          <!-- MOBILE HERO FORM -->
          <div class="lg:hidden w-full mt-1">
            <form id="hero-lead-form" class="space-y-3">
              <input aria-label="Full Name" type="text" name="name" required class="form-input" placeholder="Full Name *">
              <input aria-label="Your phone number" type="tel" name="phone" required class="form-input" placeholder="Your phone number *">
              <input aria-label="Email" type="email" name="email" required class="form-input" placeholder="Email *">
              <button type="submit" class="w-full py-4 bg-[#be1e2d] text-white font-semibold tracking-wide text-sm flex items-center justify-center gap-2 hover:bg-[#a81826] transition-colors">GET FREE ASSESSMENT</button>
              <p class="text-center text-[10px] text-[oklch(0.65_0.01_260)]">Free consultation. No spam. Response within 24 hours.</p>
            </form>
          </div>
        </div>

        <!-- Trust micro-stats (desktop only) -->
        <div class="hero-meta animate-fade-in-up delay-400">
          <div class="flex items-center gap-2">
            <div class="flex -space-x-1.5">
              <img src="https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=32&h=32&fit=crop&crop=face" alt="" class="w-6 h-6 rounded-full border-2 border-white object-cover" />
              <img src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=32&h=32&fit=crop&crop=face" alt="" class="w-6 h-6 rounded-full border-2 border-white object-cover" />
              <img src="https://images.unsplash.com/photo-1438761681033-6461ffad8d80?w=32&h=32&fit=crop&crop=face" alt="" class="w-6 h-6 rounded-full border-2 border-white object-cover" />
            </div>
            <span>2,000+ students placed</span>
          </div>
          <span class="meta-dot">|</span>
          <div class="flex items-center gap-1">
            <span class="text-[#f59e0b]">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
            <span>4.9/5 from parents</span>
          </div>
        </div>
      </div>

      <!-- Right: Data-driven proof panel (desktop only) -->
      <div class="relative hidden lg:block animate-fade-in delay-500">
        <div class="relative bg-[oklch(0.985_0.005_260)] border border-[oklch(0.9_0.01_260)] overflow-hidden" style="border-radius: 10px; box-shadow: oklch(0.3 0.02 260 / 0.08) 0px 24px 48px -12px, oklch(0 0 0 / 0.04) 0px 8px 16px -8px;">

          <!-- Header strip -->
          <div class="px-7 pt-7 pb-5 border-b border-[oklch(0.92_0.01_260)]">
            <div class="flex items-center justify-between mb-1">
              <span class="text-[0.6875rem] font-semibold tracking-[0.15em] uppercase text-[oklch(0.55_0.01_260)]" style="font-family: var(--font-body);">Placement Track Record</span>
              <span class="text-[0.6875rem] text-[oklch(0.55_0.15_145)] font-semibold flex items-center gap-1">
                <span class="w-1.5 h-1.5 bg-[oklch(0.6_0.17_145)] rounded-full"></span>
                Live Data
              </span>
            </div>
            <div class="text-[2rem] font-bold tracking-tight text-[oklch(0.2_0.02_260)]" style="font-family: var(--font-display); line-height: 1.15;">
              2,000+ <span class="text-[1rem] font-normal text-[oklch(0.5_0.01_260)]">students placed since 2018</span>
            </div>
          </div>

          <!-- Key metrics grid -->
          <div class="grid grid-cols-3 gap-px bg-[oklch(0.92_0.01_260)]">
            <div class="bg-white px-5 py-5 text-center">
              <div class="text-[1.625rem] font-bold text-[oklch(0.2_0.02_260)] tracking-tight" style="font-family: var(--font-display);">98%</div>
              <div class="text-[0.6875rem] text-[oklch(0.5_0.01_260)] mt-1">Admission Rate</div>
            </div>
            <div class="bg-white px-5 py-5 text-center">
              <div class="text-[1.625rem] font-bold text-[oklch(0.2_0.02_260)] tracking-tight" style="font-family: var(--font-display);">50+</div>
              <div class="text-[0.6875rem] text-[oklch(0.5_0.01_260)] mt-1">NMC Universities</div>
            </div>
            <div class="bg-white px-5 py-5 text-center">
              <div class="text-[1.625rem] font-bold text-[oklch(0.45_0.16_145)] tracking-tight" style="font-family: var(--font-display);">3x</div>
              <div class="text-[0.6875rem] text-[oklch(0.5_0.01_260)] mt-1">FMGE Pass Rate</div>
            </div>
          </div>

          <!-- Proof rows -->
          <div class="p-6 space-y-3">
            <div class="flex items-center gap-3.5 p-3.5 bg-[oklch(0.97_0.005_260)] border border-[oklch(0.93_0.01_260)]" style="border-radius: 6px;">
              <div class="w-9 h-9 flex items-center justify-center bg-[oklch(0.85_0.1_145/0.2)] flex-shrink-0" style="border-radius: 5px;">
                <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="oklch(0.45 0.14 145)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              </div>
              <div>
                <div class="text-[0.8125rem] font-semibold text-[oklch(0.2_0.02_260)]" style="font-family: var(--font-display);">Every University NMC Verified</div>
                <div class="text-[0.6875rem] text-[oklch(0.5_0.01_260)]">WHO + ECFMG recognized worldwide</div>
              </div>
            </div>
            <div class="flex items-center gap-3.5 p-3.5 bg-[oklch(0.97_0.005_260)] border border-[oklch(0.93_0.01_260)]" style="border-radius: 6px;">
              <div class="w-9 h-9 flex items-center justify-center bg-[oklch(0.9_0.06_260/0.3)] flex-shrink-0" style="border-radius: 5px;">
                <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="oklch(0.45 0.08 260)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
              </div>
              <div>
                <div class="text-[0.8125rem] font-semibold text-[oklch(0.2_0.02_260)]" style="font-family: var(--font-display);">Zero Hidden Charges</div>
                <div class="text-[0.6875rem] text-[oklch(0.5_0.01_260)]">Full fee breakdown before you commit</div>
              </div>
            </div>
            <div class="flex items-center gap-3.5 p-3.5 bg-[oklch(0.97_0.005_260)] border border-[oklch(0.93_0.01_260)]" style="border-radius: 6px;">
              <div class="w-9 h-9 flex items-center justify-center bg-[oklch(0.92_0.08_25/0.25)] flex-shrink-0" style="border-radius: 5px;">
                <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="oklch(0.5 0.15 25)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              </div>
              <div>
                <div class="text-[0.8125rem] font-semibold text-[oklch(0.2_0.02_260)]" style="font-family: var(--font-display);">FMGE Coaching Included</div>
                <div class="text-[0.6875rem] text-[oklch(0.5_0.01_260)]">Structured prep from 3rd year onwards</div>
              </div>
            </div>
          </div>

          <!-- Bottom trust strip -->
          <div class="px-7 py-4 bg-[oklch(0.97_0.005_260)] border-t border-[oklch(0.92_0.01_260)] flex items-center justify-between">
            <span class="text-[0.6875rem] text-[oklch(0.5_0.01_260)]">Verified by NMC, WHO, ECFMG, IMED</span>
            <div class="flex items-center gap-1">
              <span class="text-[#f59e0b] text-xs">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
              <span class="text-[0.6875rem] font-semibold text-[oklch(0.35_0.02_260)]">4.9</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- WHY CHOOSE US -->
<section id="why-section" class="py-20 lg:py-28 bg-[oklch(0.975_0.003_260)]">
  <div class="max-w-[1200px] mx-auto px-6 lg:px-12">
    <div class="max-w-2xl mb-14 lg:mb-20">
      <div class="section-eyebrow mb-3">Why Choose Us</div>
      <h2 class="text-[clamp(2rem,4.5vw,3.25rem)] font-semibold tracking-tight leading-[1.08]" style="font-family: var(--font-display); color: oklch(0.2 0.02 260);">
        What Makes Gradiks<br />Different
      </h2>
      <p class="section-desc mt-4">We built our reputation on radical transparency. Here is what that means for your family.</p>
    </div>

    <!-- Asymmetric layout: featured card + supporting grid -->
    <div class="grid lg:grid-cols-[1.1fr_1fr] gap-6 lg:gap-8">
      <!-- Featured large card -->
      <div class="bg-white p-8 lg:p-10 relative overflow-hidden group transition-shadow duration-500 hover:shadow-[0_8px_40px_oklch(0_0_0/0.06)]" style="border-radius: 8px;">
        <div class="w-12 h-12 border border-[oklch(0.88_0.01_260)] flex items-center justify-center mb-6 group-hover:border-[#be1e2d] transition-colors duration-300" style="border-radius: 6px;">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[oklch(0.4_0.01_260)] group-hover:text-[#be1e2d] transition-colors duration-300"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        </div>
        <h3 class="text-[1.375rem] font-semibold mb-3 text-[oklch(0.15_0.02_260)]" style="font-family: var(--font-display);">Brutally Honest Advice</h3>
        <p class="text-[0.9375rem] text-[oklch(0.4_0.01_260)] leading-[1.6] mb-6">No sugarcoating, no upselling premium universities for commissions. We tell you exactly which universities match your child's budget, marks, and career goals — even if it means recommending a more affordable option.</p>
        <div class="flex items-center gap-3 pt-5 border-t border-[oklch(0.93_0.01_260)]">
          <div class="text-[1.5rem] font-bold text-[oklch(0.2_0.02_260)]" style="font-family: var(--font-display);">2,000+</div>
          <div class="text-[0.8125rem] text-[oklch(0.5_0.01_260)]">families guided with the same honest approach since 2018</div>
        </div>
      </div>

      <!-- Supporting 2x2 grid -->
      <div class="grid sm:grid-cols-2 gap-5">
        <div class="bg-white p-6 lg:p-7 group transition-shadow duration-500 hover:shadow-[0_4px_24px_oklch(0_0_0/0.06)]" style="border-radius: 8px;">
          <div class="w-10 h-10 border border-[oklch(0.88_0.01_260)] flex items-center justify-center mb-4 group-hover:border-[#be1e2d] transition-colors duration-300" style="border-radius: 5px;">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[oklch(0.4_0.01_260)] group-hover:text-[#be1e2d] transition-colors duration-300"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          </div>
          <h3 class="text-[1.0625rem] font-semibold mb-2 text-[oklch(0.15_0.02_260)]" style="font-family: var(--font-display);">NMC Verified Only</h3>
          <p class="text-[0.8125rem] text-[oklch(0.45_0.01_260)] leading-relaxed">Every university is MCI/NMC approved. No diploma mills, no surprises after admission.</p>
        </div>

        <div class="bg-white p-6 lg:p-7 group transition-shadow duration-500 hover:shadow-[0_4px_24px_oklch(0_0_0/0.06)]" style="border-radius: 8px;">
          <div class="w-10 h-10 border border-[oklch(0.88_0.01_260)] flex items-center justify-center mb-4 group-hover:border-[#be1e2d] transition-colors duration-300" style="border-radius: 5px;">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[oklch(0.4_0.01_260)] group-hover:text-[#be1e2d] transition-colors duration-300"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
          </div>
          <h3 class="text-[1.0625rem] font-semibold mb-2 text-[oklch(0.15_0.02_260)]" style="font-family: var(--font-display);">Transparent Pricing</h3>
          <p class="text-[0.8125rem] text-[oklch(0.45_0.01_260)] leading-relaxed">Full fee breakdown shared in the first call. No hidden charges, no surprise invoices later.</p>
        </div>

        <div class="bg-white p-6 lg:p-7 group transition-shadow duration-500 hover:shadow-[0_4px_24px_oklch(0_0_0/0.06)]" style="border-radius: 8px;">
          <div class="w-10 h-10 border border-[oklch(0.88_0.01_260)] flex items-center justify-center mb-4 group-hover:border-[#be1e2d] transition-colors duration-300" style="border-radius: 5px;">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[oklch(0.4_0.01_260)] group-hover:text-[#be1e2d] transition-colors duration-300"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
          </div>
          <h3 class="text-[1.0625rem] font-semibold mb-2 text-[oklch(0.15_0.02_260)]" style="font-family: var(--font-display);">End-to-End Support</h3>
          <p class="text-[0.8125rem] text-[oklch(0.45_0.01_260)] leading-relaxed">Application, visa, travel, hostel, and FMGE coaching. One team for the full journey.</p>
        </div>

        <div class="bg-white p-6 lg:p-7 group transition-shadow duration-500 hover:shadow-[0_4px_24px_oklch(0_0_0/0.06)]" style="border-radius: 8px;">
          <div class="w-10 h-10 border border-[oklch(0.88_0.01_260)] flex items-center justify-center mb-4 group-hover:border-[#be1e2d] transition-colors duration-300" style="border-radius: 5px;">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[oklch(0.4_0.01_260)] group-hover:text-[#be1e2d] transition-colors duration-300"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          </div>
          <h3 class="text-[1.0625rem] font-semibold mb-2 text-[oklch(0.15_0.02_260)]" style="font-family: var(--font-display);">Parent Updates</h3>
          <p class="text-[0.8125rem] text-[oklch(0.45_0.01_260)] leading-relaxed">Regular progress reports, attendance tracking, and 24/7 emergency support for families.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- HOW IT WORKS -->
<section id="how-it-works" class="py-20 lg:py-28 bg-white">
  <div class="max-w-[1100px] mx-auto px-6 lg:px-12">
    <div class="text-center max-w-2xl mx-auto mb-14 lg:mb-20">
      <div class="section-eyebrow mb-3">How It Works</div>
      <h2 class="section-headline" style="margin-top: 0.5rem;">Your Journey to<br />Medical School</h2>
      <p class="section-desc mx-auto mt-4" style="text-align: center;">From your first call to your first day at university. Four clear steps, zero confusion.</p>
    </div>

    <!-- Vertical timeline on mobile, horizontal on desktop -->
    <div class="relative">
      <!-- Desktop connecting line -->
      <div class="hidden lg:block absolute top-[2.5rem] left-[8%] right-[8%] h-px bg-[oklch(0.88_0.01_260)]"></div>

      <div class="grid lg:grid-cols-4 gap-10 lg:gap-8">
        <!-- Step 1 -->
        <div class="relative flex lg:flex-col items-start lg:items-center lg:text-center gap-5 lg:gap-0">
          <div class="w-[3.25rem] h-[3.25rem] flex-shrink-0 flex items-center justify-center bg-[#be1e2d] relative z-10 lg:mb-8" style="border-radius: 50%;">
            <span class="font-display text-lg font-bold text-white">01</span>
          </div>
          <!-- Mobile vertical line -->
          <div class="lg:hidden absolute left-[1.625rem] top-[3.25rem] bottom-0 w-px bg-[oklch(0.88_0.01_260)] -translate-x-1/2"></div>
          <div class="pb-2 lg:pb-0">
            <h3 class="font-display text-[1.0625rem] font-semibold text-[oklch(0.15_0.02_260)] mb-1.5">Free Consultation</h3>
            <p class="text-[0.8125rem] text-[oklch(0.45_0.01_260)] leading-relaxed">Share your NEET score, budget, and goals. We assess your profile and suggest best-fit countries and universities.</p>
          </div>
        </div>
        <!-- Step 2 -->
        <div class="relative flex lg:flex-col items-start lg:items-center lg:text-center gap-5 lg:gap-0">
          <div class="w-[3.25rem] h-[3.25rem] flex-shrink-0 flex items-center justify-center bg-[oklch(0.2_0.02_260)] relative z-10 lg:mb-8" style="border-radius: 50%;">
            <span class="font-display text-lg font-bold text-white">02</span>
          </div>
          <div class="lg:hidden absolute left-[1.625rem] top-[3.25rem] bottom-0 w-px bg-[oklch(0.88_0.01_260)] -translate-x-1/2"></div>
          <div class="pb-2 lg:pb-0">
