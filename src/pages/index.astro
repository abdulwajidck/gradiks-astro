---
import MainLayout from '../layouts/MainLayout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';

const title = "Gradiks Global | Brutally Honest Education Consultancy";
const description = "We don't sell dreams. We prepare you for reality. Study abroad with real data, real visa success rates, and honest guidance.";
---

<MainLayout title={title} description={description}>
<Navigation />

<!-- HERO — gradiks.com editorial layout -->
<section class="gradiks-hero" id="hero">
  <div class="gradiks-hero-grid" aria-hidden="true"></div>
  <div class="gradiks-hero-glow" aria-hidden="true"></div>

  <div class="gradiks-hero-inner">
    <div class="gradiks-hero-layout">
      <div>
        <div class="gradiks-hero-overline animate-fade-in-up">
          <span class="gradiks-hero-overline-bar"></span>
          <span class="gradiks-hero-overline-text">Brutally Honest Consultancy</span>
        </div>

        <h1 class="hero-headline animate-fade-in-up delay-100">
          MBBS Abroad<br />
          Without the<br />
          <span class="hero-headline-accent">Sales Pitch.</span>
        </h1>

        <!-- Truth vs Lie -->
        <div class="hero-truths mb-8 max-w-xl animate-fade-in-up delay-200">
          <div class="hero-truths-label">The truth they don't tell you</div>
          
          <div class="hero-truth-item">
            <div class="hero-truth-icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 3v18h18"/><path d="m19 9-5 5-4-4-3 3"/></svg>
            </div>
            <div class="hero-truth-content">
              <div class="hero-truth-lie">"99% visa success rate guaranteed"</div>
              <div class="hero-truth-fact">Real rejection rates for Indian students applying to MBBS abroad — published every quarter.</div>
            </div>
          </div>

          <div class="hero-truth-item">
            <div class="hero-truth-icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c0 2 2 3 6 3s6-1 6-3v-5"/></svg>
            </div>
            <div class="hero-truth-content">
              <div class="hero-truth-lie">"Our partner colleges pay our commission"</div>
              <div class="hero-truth-fact">We only recommend universities with strong FMGE results and proper clinical training — not the highest paying ones.</div>
            </div>
          </div>

          <div class="hero-truth-item">
            <div class="hero-truth-icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            </div>
            <div class="hero-truth-content">
              <div class="hero-truth-lie">"Sign our multi-year locked contract"</div>
              <div class="hero-truth-fact">Full cost breakdown and FMGE reality check before you decide. No hidden fees later.</div>
            </div>
          </div>
        </div>

        <p class="hero-subheadline animate-fade-in-up delay-300">
          No fake promises. No random university lists. Just clear data on NMC-approved colleges, real total costs, actual FMGE passing rates, and honest visa odds — based on your NEET score and budget.
        </p>

        <div class="hero-ctas animate-fade-in-up delay-400">
          <button onclick="document.getElementById('lead-form-container')?.scrollIntoView({ behavior: 'smooth', block: 'center' })" class="cta-primary">
            Get Your Roadmap
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </button>
          <button onclick="document.getElementById('why-section')?.scrollIntoView({ behavior: 'smooth', block: 'start' })" class="cta-secondary">
            How We're Different
          </button>
        </div>

        <div class="lg:hidden w-full mt-6 animate-fade-in-up delay-500">
          <form id="hero-lead-form" class="space-y-3 bg-white border border-black/10 p-4 rounded-sm shadow-[var(--shadow-soft-md)]">
            <input aria-label="Full Name" type="text" name="name" required class="form-input" placeholder="Full Name *">
            <input aria-label="Your phone number" type="tel" name="phone" required class="form-input" placeholder="Your phone number *">
            <input aria-label="Email" type="email" name="email" required class="form-input" placeholder="Email *">
            <button type="submit" class="w-full cta-primary justify-center">Get Your Roadmap</button>
            <p class="text-center text-[10px] text-gray-500">Free consultation. No spam. Response within 24 hours.</p>
          </form>
        </div>
      </div>

      <div class="gradiks-hero-visual hidden lg:block animate-scale-in delay-500">
        <div class="absolute -top-4 -right-4 w-8 h-8 border-t-2 border-r-2 border-[#be1e2d] z-10" aria-hidden="true"></div>
        <div class="absolute -bottom-4 -left-4 w-8 h-8 border-b-2 border-l-2 border-[#be1e2d] z-10" aria-hidden="true"></div>
        <div class="gradiks-hero-visual-frame">
          <img src="/images/gradiks-hero-mbbs-student.jpg" alt="Young Indian woman MBBS student in white coat with her parents during an honest consultation with a Gradiks counsellor about studying medicine abroad" loading="eager" fetchpriority="high" />
          <div class="absolute inset-y-0 left-0 w-32 bg-gradient-to-r from-[#f1f1f1] to-transparent pointer-events-none" aria-hidden="true"></div>
        </div>
        <div class="gradiks-hero-badge-float" style="top: 2.5rem; left: -1.5rem;">
          <p class="font-display text-[11px] font-bold tracking-wider text-gray-800">100% AUDITED</p>
          <p class="text-[9px] text-gray-500">Rejections Public</p>
        </div>
        <div class="gradiks-hero-badge-float delay" style="bottom: 3.5rem; right: -1rem;">
          <p class="font-display text-[11px] font-bold tracking-wider text-gray-800">COMMISSION-FREE</p>
          <p class="text-[9px] text-gray-500">Pure ROI Advice</p>
        </div>
      </div>
    </div>
  </div>

  <div class="gradiks-hero-marquee" role="marquee" aria-label="Gradiks transparency statistics">
    <div class="gradiks-hero-marquee-track">
      <span class="mx-6 text-gray-400">2,000+ STUDENTS GUIDED SINCE 2018</span>
      <span class="mx-2 text-[#be1e2d]">✦</span>
      <span class="mx-6 text-gray-400">50+ NMC-APPROVED UNIVERSITIES</span>
      <span class="mx-2 text-[#be1e2d]">✦</span>
      <span class="mx-6 text-gray-400">ZERO HIDDEN FEES POLICY</span>
      <span class="mx-2 text-[#be1e2d]">✦</span>
      <span class="mx-6 text-gray-400">FMGE COACHING INCLUDED</span>
      <span class="mx-2 text-[#be1e2d]">✦</span>
      <span class="mx-6 text-gray-400">15+ STUDY DESTINATIONS</span>
      <span class="mx-2 text-[#be1e2d]">✦</span>
      <span class="mx-6 text-gray-400">2,000+ STUDENTS GUIDED SINCE 2018</span>
      <span class="mx-2 text-[#be1e2d]">✦</span>
      <span class="mx-6 text-gray-400">50+ NMC-APPROVED UNIVERSITIES</span>
      <span class="mx-2 text-[#be1e2d]">✦</span>
      <span class="mx-6 text-gray-400">ZERO HIDDEN FEES POLICY</span>
      <span class="mx-2 text-[#be1e2d]">✦</span>
      <span class="mx-6 text-gray-400">FMGE COACHING INCLUDED</span>
      <span class="mx-2 text-[#be1e2d]">✦</span>
      <span class="mx-6 text-gray-400">15+ STUDY DESTINATIONS</span>
      <span class="mx-2 text-[#be1e2d]">✦</span>
    </div>
  </div>
</section>

<!-- ============================================
     WHY CHOOSE US — Asymmetric feature layout
     ============================================ -->
<section id="why-section" class="py-20 lg:py-28" style="background: #ffffff;">
  <div class="max-w-[1200px] mx-auto px-6 lg:px-12">
    <div class="max-w-2xl mb-14 lg:mb-20 reveal">
      <div class="section-eyebrow mb-3">Why Choose Us</div>
      <h2 class="section-headline">
        What Makes Gradiks<br />Different
      </h2>
      <p class="section-desc mt-4">We built our reputation on radical transparency. Here is what that means for your family.</p>
    </div>

    <!-- Asymmetric layout -->
    <div class="grid lg:grid-cols-[1.1fr_1fr] gap-6 lg:gap-8">
      <!-- Featured large card -->
      <div class="feature-card p-8 lg:p-10 reveal reveal-delay-1">
        <div class="feature-icon w-12 h-12">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        </div>
        <h3 class="text-[1.375rem] font-semibold mb-3" style="font-family: var(--font-display); color: #0d0d0d;">Brutally Honest Advice</h3>
        <p class="text-[0.9375rem] leading-relaxed mb-6" style="color: #4b5563;">No sugarcoating, no upselling premium universities for commissions. We tell you exactly which universities match your child's budget, marks, and career goals — even if it means recommending a more affordable option.</p>
        <div class="flex items-center gap-3 pt-5 border-t" style="border-color: #f1f1f1;">
          <div class="text-[1.5rem] font-bold" style="font-family: var(--font-display); color: #0d0d0d;">2,000+</div>
          <div class="text-[0.8125rem]" style="color: #6b7280;">families guided with the same honest approach since 2018</div>
        </div>
      </div>

      <!-- Supporting 2x2 grid -->
      <div class="grid sm:grid-cols-2 gap-5">
        <div class="feature-card reveal reveal-delay-2">
          <div class="feature-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          </div>
          <h3 class="text-[1.0625rem] font-semibold mb-2" style="color: #0d0d0d; font-family: var(--font-display);">NMC Verified Only</h3>
          <p class="text-[0.8125rem] leading-relaxed" style="color: #4b5563;">Every university is reviewed against current NMC requirements. No diploma mills, no surprises after admission.</p>
        </div>
        <div class="feature-card reveal reveal-delay-2">
          <div class="feature-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
          </div>
          <h3 class="text-[1.0625rem] font-semibold mb-2" style="color: #0d0d0d; font-family: var(--font-display);">Transparent Pricing</h3>
          <p class="text-[0.8125rem] leading-relaxed" style="color: #4b5563;">Full fee breakdown shared in the first call. No hidden charges, no surprise invoices later.</p>
        </div>
        <div class="feature-card reveal reveal-delay-3">
          <div class="feature-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
          </div>
          <h3 class="text-[1.0625rem] font-semibold mb-2" style="color: #0d0d0d; font-family: var(--font-display);">End-to-End Support</h3>
          <p class="text-[0.8125rem] leading-relaxed" style="color: #4b5563;">Application, visa, travel, hostel, and FMGE coaching. One team for the full journey.</p>
        </div>
        <div class="feature-card reveal reveal-delay-3">
          <div class="feature-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          </div>
          <h3 class="text-[1.0625rem] font-semibold mb-2" style="color: #0d0d0d; font-family: var(--font-display);">Parent Updates</h3>
          <p class="text-[0.8125rem] leading-relaxed" style="color: #4b5563;">Regular progress reports, attendance tracking, and 24/7 emergency support for families.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ============================================
     REAL STUDENTS — Powerful visual social proof
     ============================================ -->
<section id="real-students" class="py-20 lg:py-24" style="background: #f8f9fb;">
  <div class="max-w-[1200px] mx-auto px-6 lg:px-12">
    <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6 mb-12 lg:mb-16 reveal">
      <div class="max-w-2xl">
        <div class="section-eyebrow mb-3">Real Students. Real Decisions.</div>
        <h2 class="section-headline">These Are The<br />Conversations That Matter</h2>
      </div>
      <p class="max-w-md text-[0.9375rem] leading-relaxed" style="color: #4b5563;">
        Every student here sat across from us with the same fears you have. We showed them the real numbers. They made their own choice.
      </p>
    </div>

    <!-- Lead visual + student grid -->
    <div class="grid lg:grid-cols-12 gap-5">
      <!-- Large lead image -->
      <div class="lg:col-span-7 relative overflow-hidden rounded-sm border border-black/5 reveal">
        <img src="/images/gradiks-students-campus.jpg" alt="Group of confident Indian MBBS students outside a medical university abroad" class="w-full h-full object-cover" style="aspect-ratio: 16/10; min-height: 320px;" loading="lazy" />
        <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/20 to-transparent"></div>
        <div class="absolute bottom-0 left-0 p-8 text-white">
          <div class="font-display text-2xl leading-none tracking-[-0.02em] mb-1">They chose clarity<br />over comfort.</div>
          <div class="text-white/70 text-[0.8125rem]">Over 2,000 families have done the same since 2018.</div>
        </div>
      </div>

      <!-- Student stories grid -->
      <div class="lg:col-span-5 grid grid-cols-1 sm:grid-cols-2 gap-5">
        <div class="student-story-card reveal reveal-delay-1">
          <img src="/students/mariya-elezebeth.jpg" alt="Mariya Elezebeth, MBBS student at Tbilisi State Medical University, Georgia" class="student-story-img" loading="lazy" />
          <div class="p-5">
            <div class="font-display text-[1.0625rem] font-semibold leading-tight mb-1.5" style="color:#0d0d0d;">Mariya Elezebeth</div>
            <div class="text-[0.6875rem] text-[#6b7280] mb-3">3rd Year • Tbilisi State Medical University, Georgia</div>
            <p class="text-[0.8125rem] leading-relaxed" style="color:#4b5563;">"I scored 312 in NEET. Three agents told me I was wasting money. Gradiks built me a shortlist and I got in. Now I am in Tbilisi."</p>
          </div>
        </div>

        <div class="student-story-card reveal reveal-delay-2">
          <img src="/students/devika.jpg" alt="Devika, MBBS student at Kazan State Medical University, Russia" class="student-story-img" loading="lazy" />
          <div class="p-5">
            <div class="font-display text-[1.0625rem] font-semibold leading-tight mb-1.5" style="color:#0d0d0d;">Devika</div>
            <div class="text-[0.6875rem] text-[#6b7280] mb-3">5th Year • Kazan State Medical University, Russia</div>
            <p class="text-[0.8125rem] leading-relaxed" style="color:#4b5563;">"Hostel, mess, climate, exams — they prepared me for all of it. Even the visa interview. I felt ready before I landed."</p>
          </div>
        </div>

        <div class="student-story-card reveal reveal-delay-3">
          <img src="/students/abhishek-joseph.jpg" alt="Abhishek Joseph, MBBS student at Bashkir State Medical University, Russia" class="student-story-img" loading="lazy" />
          <div class="p-5">
            <div class="font-display text-[1.0625rem] font-semibold leading-tight mb-1.5" style="color:#0d0d0d;">Abhishek Joseph</div>
            <div class="text-[0.6875rem] text-[#6b7280] mb-3">4th Year • Bashkir State Medical University, Russia</div>
            <p class="text-[0.8125rem] leading-relaxed" style="color:#4b5563;">"My parents were terrified about NMC and FMGE. Gradiks sat with them for two hours and showed them the actual circulars."</p>
          </div>
        </div>

        <div class="student-story-card reveal reveal-delay-4">
          <img src="/students/sivadev-salimkumar.jpg" alt="Sivadev Salimkumar, MBBS student at Samarkand State Medical University, Uzbekistan" class="student-story-img" loading="lazy" />
          <div class="p-5">
            <div class="font-display text-[1.0625rem] font-semibold leading-tight mb-1.5" style="color:#0d0d0d;">Sivadev Salimkumar</div>
            <div class="text-[0.6875rem] text-[#6b7280] mb-3">2nd Year • Samarkand State Medical University, Uzbekistan</div>
            <p class="text-[0.8125rem] leading-relaxed" style="color:#4b5563;">"The student call before I joined was the thing that convinced me. I spoke to a senior in Samarkand for 40 minutes. Zero sales talk."</p>
          </div>
        </div>
      </div>
    </div>

    <p class="text-center text-[0.6875rem] text-[#9ca3af] mt-8">All stories are from verified families. No paid testimonials. Ever.</p>
  </div>
</section>

<!-- REAL MBBS TRAINING VISUALS (homepage) -->
<section class="py-12 lg:py-16 bg-white border-t border-[#f1f1f1]">
  <div class="max-w-[1200px] mx-auto px-6 lg:px-12">
    <div class="text-center mb-8">
      <div class="text-[11px] tracking-[0.3em] uppercase text-[#be1e2d] font-semibold mb-2">Not classroom theory</div>
      <h3 class="text-2xl md:text-3xl font-semibold tracking-tight">This is what 2,000+ hours of real MBBS clinical training looks like.</h3>
    </div>
    <div class="grid md:grid-cols-2 gap-4 max-w-4xl mx-auto">
      <div class="overflow-hidden rounded-xl border border-[#e5e7eb]">
        <img src="/images/mbbs/mbbs-dissection-lab.jpg" alt="MBBS students in dissection lab" class="w-full h-64 object-cover" />
        <div class="p-4 bg-[#fafafa] text-sm">Anatomy labs &amp; pre-clinical training — foundational years</div>
      </div>
      <div class="overflow-hidden rounded-xl border border-[#e5e7eb]">
        <img src="/images/mbbs/mbbs-clinical-ward.jpg" alt="MBBS students on hospital wards" class="w-full h-64 object-cover" />
        <div class="p-4 bg-[#fafafa] text-sm">Hospital rotations &amp; real patient care — clinical years</div>
      </div>
    </div>
  </div>
</section>

<!-- ============================================
     HOW IT WORKS — Clean numbered steps
     ============================================ -->
<section id="how-it-works" class="py-20 lg:py-28 bg-white">
  <div class="max-w-[1100px] mx-auto px-6 lg:px-12">
    <div class="text-center max-w-2xl mx-auto mb-14 lg:mb-20 reveal">
      <div class="section-eyebrow mb-3">How It Works</div>
      <h2 class="section-headline">Your Journey to<br />Medical School</h2>
      <p class="section-desc mx-auto mt-4" style="text-align: center;">From your first call to your first day at university. Four clear steps, zero confusion.</p>
    </div>

    <!-- Desktop horizontal steps, mobile vertical -->
    <div class="relative">
      <div class="hidden lg:block absolute top-[2.5rem] left-[8%] right-[8%] h-px" style="background: #e5e7eb;"></div>

      <div class="grid lg:grid-cols-4 gap-10 lg:gap-8">
        <!-- Step 1 -->
        <div class="relative flex lg:flex-col items-start lg:items-center lg:text-center gap-5 lg:gap-0 reveal reveal-delay-1">
          <div class="step-circle" style="background: var(--color-brand-red);">
            <span>01</span>
          </div>
          <div class="lg:hidden absolute left-[1.625rem] top-[3.25rem] bottom-0 w-px" style="background: #e5e7eb; transform: translateX(-50%);"></div>
          <div class="pb-2 lg:pb-0">
            <h3 class="font-display text-[1.0625rem] font-semibold mb-1.5" style="color: #0d0d0d;">Free Consultation</h3>
            <p class="text-[0.8125rem] leading-relaxed" style="color: #4b5563;">Share your NEET score, budget, and goals. We assess your profile and suggest best-fit countries and universities.</p>
          </div>
        </div>
        <!-- Step 2 -->
        <div class="relative flex lg:flex-col items-start lg:items-center lg:text-center gap-5 lg:gap-0 reveal reveal-delay-2">
          <div class="step-circle" style="background: var(--color-brand-navy);">
            <span>02</span>
          </div>
          <div class="lg:hidden absolute left-[1.625rem] top-[3.25rem] bottom-0 w-px" style="background: #e5e7eb; transform: translateX(-50%);"></div>
          <div class="pb-2 lg:pb-0">
            <h3 class="font-display text-[1.0625rem] font-semibold mb-1.5" style="color: #0d0d0d;">University Selection</h3>
            <p class="text-[0.8125rem] leading-relaxed" style="color: #4b5563;">Verified options with honest fee breakdowns, campus details, and success records. No pressure, no false promises.</p>
          </div>
        </div>
        <!-- Step 3 -->
        <div class="relative flex lg:flex-col items-start lg:items-center lg:text-center gap-5 lg:gap-0 reveal reveal-delay-3">
          <div class="step-circle" style="background: var(--color-brand-navy);">
            <span>03</span>
          </div>
          <div class="lg:hidden absolute left-[1.625rem] top-[3.25rem] bottom-0 w-px" style="background: #e5e7eb; transform: translateX(-50%);"></div>
          <div class="pb-2 lg:pb-0">
            <h3 class="font-display text-[1.0625rem] font-semibold mb-1.5" style="color: #0d0d0d;">Application & Visa</h3>
            <p class="text-[0.8125rem] leading-relaxed" style="color: #4b5563;">We handle documentation, university applications, visa processing, and travel arrangements end-to-end.</p>
          </div>
        </div>
        <!-- Step 4 -->
        <div class="relative flex lg:flex-col items-start lg:items-center lg:text-center gap-5 lg:gap-0 reveal reveal-delay-4">
          <div class="step-circle" style="background: #059669;">
            <span>04</span>
          </div>
          <div>
            <h3 class="font-display text-[1.0625rem] font-semibold mb-1.5" style="color: #0d0d0d;">Arrival & Support</h3>
            <p class="text-[0.8125rem] leading-relaxed" style="color: #4b5563;">Airport pickup, hostel setup, Indian food, and ongoing support including FMGE coaching until you graduate.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ============================================
     VIDEO — The honest conversation
