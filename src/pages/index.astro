---
import MainLayout from '../layouts/MainLayout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
const title = "Gradiks — Your Child's Medical Dreams, Our Honest Guidance";
const description = "Trusted MBBS abroad consultancy for Indian families. Transparent guidance, verified universities, and end-to-end support for your child's medical career.";
---
<MainLayout title={title} description={description}>
<Navigation />
<!-- TRUST BAR -->
<section class="bg-[#232d61] py-4 mt-20">
  <div class="max-w-[1400px] mx-auto px-6 lg:px-12">
    <div class="flex flex-wrap justify-center items-center gap-8 lg:gap-16 text-white text-sm">
      <span class="flex items-center gap-2">
        <span class="font-display font-semibold">2,000+</span>
        <span class="text-white/70">Students Guided</span>
      </span>
      <span class="text-white/30 hidden sm:block">•</span>
      <span class="flex items-center gap-2">
        <span class="font-display font-semibold">98%</span>
        <span class="text-white/70">Success Rate</span>
      </span>
      <span class="text-white/30 hidden sm:block">•</span>
      <span class="flex items-center gap-2">
        <span class="font-display font-semibold">50+</span>
        <span class="text-white/70">Partner Universities</span>
      </span>
      <span class="text-white/30 hidden sm:block">•</span>
      <span class="flex items-center gap-2">
        <span class="font-display font-semibold">15+</span>
        <span class="text-white/70">Countries</span>
      </span>
    </div>
  </div>
</section>
<!-- HERO SECTION -->
<section class="min-h-screen flex items-center relative overflow-hidden py-20 lg:py-32">
  <div class="absolute inset-0 z-0">
    <div class="absolute top-1/4 right-0 w-[800px] h-[800px] bg-gradient-radial from-[rgba(190,30,45,0.06)] via-transparent to-transparent rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 left-0 w-[600px] h-[600px] bg-gradient-radial from-[rgba(190,30,45,0.04)] via-transparent to-transparent rounded-full blur-3xl"></div>
  </div>
  <div class="max-w-[1400px] mx-auto px-6 lg:px-12 py-20 lg:py-32 relative z-10 w-full">
    <div class="grid lg:grid-cols-2 gap-16 lg:gap-24 items-center">
      <div class="space-y-8">
        <!-- Badge -->
        <div class="inline-flex items-center gap-3 px-4 py-2 border border-white/20 bg-white/5 backdrop-blur-sm">
          <span class="w-2 h-2 bg-[#be1e2d] rounded-full"></span>
          <span class="text-xs font-medium tracking-[0.15em] uppercase text-white/80">Trusted by 2,000+ Families</span>
        </div>
        <!-- Headline -->
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-semibold leading-[1.04] tracking-[-0.02em] animate-fade-in-up delay-100" style="font-family: var(--font-display);">
          Your Child's
          <br />
          <span class="text-[#be1e2d]">Medical</span>
          <br />
          Dreams
        </h1>
        <!-- Subheadline -->
        <p class="text-lg md:text-xl text-white/70 max-w-lg leading-relaxed animate-fade-in-up delay-200">
          Honest guidance for MBBS admissions abroad. No false promises, no hidden fees — just transparent advice for your family's future.
        </p>
        <!-- CTA Buttons -->
        <div class="flex flex-col sm:flex-row gap-4 animate-fade-in-up delay-300">
          <button onclick="document.getElementById('lead-form-container')?.scrollIntoView({ behavior: 'smooth', block: 'center' })" class="group relative px-8 py-4 bg-[#be1e2d] text-white font-semibold tracking-wide overflow-hidden transition-all duration-300 hover:shadow-[0_0_40px_rgba(190,30,45,0.3)]">
            <span class="relative z-10 flex items-center justify-center gap-2">
              Get Free Assessment
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-1"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </span>
          </button>
          <a href="tel:+9199876543210" class="group px-8 py-4 border border-white/30 text-white font-medium tracking-wide flex items-center justify-center gap-3 hover:bg-white hover:text-[#232d61] transition-all duration-300">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Call Now
          </a>
        </div>
        <!-- Meta line -->
        <p class="text-sm text-white/50 animate-fade-in-up delay-400">
          +91 98765 43210 · info@gradiks.com
        </p>
      </div>
      <!-- Hero Visual -->
      <div class="relative hidden lg:block animate-fade-in delay-500">
        <div class="relative bg-white/5 backdrop-blur-sm border border-white/10 p-8">
          <div class="absolute -top-4 -right-4 w-24 h-24 border border-[#be1e2d]/30"></div>
          <div class="absolute -bottom-4 -left-4 w-32 h-32 bg-[rgba(190, 30, 45, 0.1)]"></div>
          <div class="relative space-y-6">
            <div class="flex items-start gap-4 pb-6 border-b border-white/10">
              <div class="w-12 h-12 bg-[rgba(190, 30, 45, 0.1)] flex items-center justify-center text-[#be1e2d]">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>
              </div>
              <div>
                <div class="text-sm font-medium text-white mb-1">Verified Universities</div>
                <div class="text-xs text-white/50">MCI & NMC Approved</div>
              </div>
            </div>
            <div class="flex items-start gap-4 pb-6 border-b border-white/10">
              <div class="w-12 h-12 bg-[rgba(190, 30, 45, 0.1)] flex items-center justify-center text-[#be1e2d]">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
              </div>
              <div>
                <div class="text-sm font-medium text-white mb-1">15+ Countries</div>
                <div class="text-xs text-white/50">Global Options Available</div>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-[rgba(190, 30, 45, 0.1)] flex items-center justify-center text-[#be1e2d]">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
              </div>
              <div>
                <div class="text-sm font-medium text-white mb-1">Lifetime Support</div>
                <div class="text-xs text-white/50">From Admission to Practice</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
<!-- WHY CHOOSE US -->
<section class="py-24 lg:py-32 bg-[#f5f5f7]">
  <div class="max-w-[1400px] mx-auto px-6 lg:px-12">
    <div class="max-w-3xl mb-16">
      <div class="text-xs tracking-[0.3em] uppercase text-[#be1e2d] mb-4">Why Choose Us</div>
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-semibold tracking-tight leading-[1.07] letter-tight" style="font-family: var(--font-display);">
        What Makes Us<br />Different
      </h2>
    </div>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      <div class="bg-white p-8 lg:p-10 group hover:shadow-[0_4px_24px_rgba(0,0,0,0.08)] transition-all duration-500">
        <div class="w-14 h-14 border border-[#e5e7eb] flex items-center justify-center mb-6 group-hover:border-[#be1e2d] group-hover:text-[#be1e2d] transition-all duration-300">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        </div>
        <h3 class="text-xl font-semibold mb-3" style="font-family: var(--font-display);">Brutally Honest</h3>
        <p class="text-sm text-[#4b5563] leading-relaxed">No sugarcoating. We tell you exactly which universities match your budget, marks, and career goals.</p>
      </div>
      <div class="bg-white p-8 lg:p-10 group hover:shadow-[0_4px_24px_rgba(0,0,0,0.08)] transition-all duration-500">
        <div class="w-14 h-14 border border-[#e5e7eb] flex items-center justify-center mb-6 group-hover:border-[#be1e2d] group-hover:text-[#be1e2d] transition-all duration-300">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        </div>
        <h3 class="text-xl font-semibold mb-3" style="font-family: var(--font-display);">Verified Only</h3>
        <p class="text-sm text-[#4b5563] leading-relaxed">Every university we recommend is MCI/NMC approved. No diploma mills, no surprises.</p>
      </div>
      <div class="bg-white p-8 lg:p-10 group hover:shadow-[0_4px_24px_rgba(0,0,0,0.08)] transition-all duration-500">
        <div class="w-14 h-14 border border-[#e5e7eb] flex items-center justify-center mb-6 group-hover:border-[#be1e2d] group-hover:text-[#be1e2d] transition-all duration-300">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
        </div>
        <h3 class="text-xl font-semibold mb-3" style="font-family: var(--font-display);">Transparent Pricing</h3>
        <p class="text-sm text-[#4b5563] leading-relaxed">Clear breakdown of tuition, living costs, and our fees. No hidden charges, ever.</p>
      </div>
      <div class="bg-white p-8 lg:p-10 group hover:shadow-[0_4px_24px_rgba(0,0,0,0.08)] transition-all duration-500">
        <div class="w-14 h-14 border border-[#e5e7eb] flex items-center justify-center mb-6 group-hover:border-[#be1e2d] group-hover:text-[#be1e2d] transition-all duration-300">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
        </div>
        <h3 class="text-xl font-semibold mb-3" style="font-family: var(--font-display);">End-to-End Support</h3>
        <p class="text-sm text-[#4b5563] leading-relaxed">From application to visa to FMGE coaching — we're with you for the entire journey.</p>
      </div>
      <div class="bg-white p-8 lg:p-10 group hover:shadow-[0_4px_24px_rgba(0,0,0,0.08)] transition-all duration-500">
        <div class="w-14 h-14 border border-[#e5e7eb] flex items-center justify-center mb-6 group-hover:border-[#be1e2d] group-hover:text-[#be1e2d] transition-all duration-300">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        </div>
        <h3 class="text-xl font-semibold mb-3" style="font-family: var(--font-display);">Parent Updates</h3>
        <p class="text-sm text-[#4b5563] leading-relaxed">Regular updates for parents, campus visits arranged, and 24/7 emergency support.</p>
      </div>
      <div class="bg-white p-8 lg:p-10 group hover:shadow-[0_4px_24px_rgba(0,0,0,0.08)] transition-all duration-500">
        <div class="w-14 h-14 border border-[#e5e7eb] flex items-center justify-center mb-6 group-hover:border-[#be1e2d] group-hover:text-[#be1e2d] transition-all duration-300">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/></svg>
        </div>
        <h3 class="text-xl font-semibold mb-3" style="font-family: var(--font-display);">FMGE Success</h3>
        <p class="text-sm text-[#4b5563] leading-relaxed">Proven coaching programs to help you clear the FMGE and practice in India.</p>
      </div>
    </div>
  </div>
</section>
<!-- COUNTRIES SECTION -->
<section class="py-24 lg:py-32 bg-[#1d1d1f]">
  <div class="max-w-[1400px] mx-auto px-6 lg:px-12">
    <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-8 mb-16">
      <div class="max-w-2xl">
        <div class="text-xs tracking-[0.3em] uppercase text-[#be1e2d] mb-4">Destinations</div>
        <h2 class="text-4xl md:text-5xl lg:text-6xl font-semibold tracking-tight leading-[1.07] letter-tight text-white" style="font-family: var(--font-display);">
          Top Countries for<br />MBBS
        </h2>
      </div>
      <p class="text-white/60 max-w-md lg:text-right">
        Choose from world's best medical universities with affordable fees and global recognition.
      </p>
    </div>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      <a href="/germany-study" class="group relative bg-white/5 backdrop-blur-sm border border-white/10 p-8 lg:p-10 hover:border-[#be1e2d] transition-all duration-500 overflow-hidden">
        <div class="absolute top-0 right-0 w-32 h-32 bg-gradient-radial from-[rgba(190,30,45,0.15)] to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        <div class="relative z-10">
          <div class="text-4xl mb-6">🇩🇪</div>
          <h3 class="text-2xl font-semibold mb-3 text-white" style="font-family: var(--font-display);">Germany</h3>
          <p class="text-sm text-white/60 mb-6">Tuition-free world-class education with advanced medical training.</p>
          <div class="flex items-center gap-2 text-[#be1e2d] text-sm font-medium">
            <span>Explore</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </div>
        </div>
      </a>
      <a href="/ireland-study" class="group relative bg-white/5 backdrop-blur-sm border border-white/10 p-8 lg:p-10 hover:border-[#be1e2d] transition-all duration-500 overflow-hidden">
        <div class="absolute top-0 right-0 w-32 h-32 bg-gradient-radial from-[rgba(190,30,45,0.15)] to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        <div class="relative z-10">
          <div class="text-4xl mb-6">🇮🇪</div>
          <h3 class="text-2xl font-semibold mb-3 text-white" style="font-family: var(--font-display);">Ireland</h3>
          <p class="text-sm text-white/60 mb-6">English-speaking excellence with 2-year stay-back visa option.</p>
          <div class="flex items-center gap-2 text-[#be1e2d] text-sm font-medium">
            <span>Explore</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </div>
        </div>
      </a>
      <a href="/uk-study" class="group relative bg-white/5 backdrop-blur-sm border border-white/10 p-8 lg:p-10 hover:border-[#be1e2d] transition-all duration-500 overflow-hidden">
        <div class="absolute top-0 right-0 w-32 h-32 bg-gradient-radial from-[rgba(190,30,45,0.15)] to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        <div class="relative z-10">
          <div class="text-4xl mb-6">🇬🇧</div>
          <h3 class="text-2xl font-semibold mb-3 text-white" style="font-family: var(--font-display);">United Kingdom</h3>
          <p class="text-sm text-white/60 mb-6">Prestigious medical education with global recognition and NHS pathway.</p>
          <div class="flex items-center gap-2 text-[#be1e2d] text-sm font-medium">
            <span>Explore</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </div>
        </div>
      </a>
      <a href="/india-medical" class="group relative bg-white/5 backdrop-blur-sm border border-white/10 p-8 lg:p-10 hover:border-[#be1e2d] transition-all duration-500 overflow-hidden">
        <div class="absolute top-0 right-0 w-32 h-32 bg-gradient-radial from-[rgba(190,30,45,0.15)] to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        <div class="relative z-10">
          <div class="text-4xl mb-6">🇮🇳</div>
          <h3 class="text-2xl font-semibold mb-3 text-white" style="font-family: var(--font-display);">India Medical</h3>
          <p class="text-sm text-white/60 mb-6">NEET counselling support for MBBS, BDS & Allied Health in South India.</p>
          <div class="flex items-center gap-2 text-[#be1e2d] text-sm font-medium">
            <span>Explore</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </div>
        </div>
      </a>
      <a href="/nursing-abroad" class="group relative bg-gradient-to-br from-[rgba(190, 30, 45, 0.15)] to-transparent border border-white/10 p-8 lg:p-10 hover:border-[#be1e2d] transition-all duration-500 block">
        <div class="relative z-10">
          <div class="text-4xl mb-6">🩺</div>
          <h3 class="text-2xl font-semibold mb-3 text-white" style="font-family: var(--font-display);">Nursing Abroad</h3>
          <p class="text-sm text-white/60 mb-6">Build your international nursing career in UK, Ireland, and Germany with a guided pathway.</p>
          <div class="flex items-center gap-2 text-[#be1e2d] text-sm font-medium">
            <span>Explore</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </div>
        </div>
      </a>
      <button onclick="document.getElementById('lead-form-container')?.scrollIntoView({ behavior: 'smooth', block: 'center' })" class="group relative bg-white/5 backdrop-blur-sm border border-white/10 p-8 lg:p-10 hover:border-[#be1e2d] transition-all duration-500 text-left">
        <div class="relative z-10">
          <div class="text-4xl mb-6">📞</div>
          <h3 class="text-2xl font-semibold mb-3 text-white" style="font-family: var(--font-display);">Not Sure Where?</h3>
          <p class="text-sm text-white/60 mb-6">Let our experts analyze your profile and recommend the best options.</p>
          <div class="flex items-center gap-2 text-[#be1e2d] text-sm font-medium">
            <span>Get Guidance</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </div>
        </div>
      </button>
    </div>
  </div>
</section>
<!-- LEAD FORM SECTION -->
<section id="lead-form-container" class="py-24 lg:py-32 bg-[#f5f5f7]">
  <div class="max-w-[1400px] mx-auto px-6 lg:px-12">
    <div class="max-w-2xl mx-auto">
      <div class="text-center mb-12">
        <div class="text-xs tracking-[0.3em] uppercase text-[#be1e2d] mb-4">Get Started</div>
        <h2 class="text-4xl md:text-5xl font-semibold tracking-tight mb-4 leading-[1.07] letter-tight" style="font-family: var(--font-display);">
          Get Your Free<br />Assessment
        </h2>
        <p class="text-[#4b5563]">
          Fill in your details and our experts will contact you within 24 hours.
        </p>
      </div>
      <form id="lead-form" class="bg-white rounded-xl p-8 lg:p-12 shadow-[0_4px_24px_rgba(0,0,0,0.06)]">
