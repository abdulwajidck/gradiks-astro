---
import MainLayout from '../layouts/MainLayout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
const title = "Gradiks — Your Child's Medical Dreams, Our Honest Guidance";
const description = "Trusted MBBS abroad consultancy for Indian families. Transparent guidance, verified universities, and end-to-end support for your child's medical career.";
---
<MainLayout title={title} description={description}>
<Navigation />
<!-- TRUST BAR -->
<section class="bg-[#232d61] py-4 mt-20 text-white">
  <div class="max-w-[1400px] mx-auto px-6 lg:px-12">
    <div class="flex flex-wrap justify-center items-center gap-8 lg:gap-16 text-white text-sm">
      <span class="flex items-center gap-2">
        <span class="font-display font-semibold">2,000+</span>
        <span class="text-white/70">Students Guided</span>
      </span>
      <span class="text-white/30 hidden sm:block">•</span>
      <span class="flex items-center gap-2">
        <span class="font-display font-semibold">98%</span>
        <span class="text-white/70">Success Rate</span>
      </span>
      <span class="text-white/30 hidden sm:block">•</span>
      <span class="flex items-center gap-2">
        <span class="font-display font-semibold">50+</span>
        <span class="text-white/70">Partner Universities</span>
      </span>
      <span class="text-white/30 hidden sm:block">•</span>
      <span class="flex items-center gap-2">
        <span class="font-display font-semibold">15+</span>
        <span class="text-white/70">Countries</span>
      </span>
    </div>
  </div>
</section>
<!-- HERO SECTION -->
<section class="relative overflow-hidden bg-[#0a1628] min-h-screen">
  <!-- Background image with overlay -->
  <div class="absolute inset-0 z-0">
    <img src="https://images.unsplash.com/photo-1538108149393-fbbd81895907?w=1920&q=80&auto=format&fit=crop" alt="" class="w-full h-full object-cover opacity-20" loading="eager" />
    <div class="absolute inset-0 bg-gradient-to-br from-[#0a1628] via-[#0a1628]/95 to-[#0a1628]/80"></div>
    <div class="absolute top-0 right-0 w-[800px] h-[800px] bg-gradient-radial from-[rgba(190,30,45,0.08)] via-transparent to-transparent rounded-full blur-3xl"></div>
  </div>

  <div class="max-w-[1400px] mx-auto px-6 lg:px-12 pt-36 lg:pt-44 pb-24 lg:pb-32 relative z-10">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <!-- Left: Content -->
      <div class="space-y-8">
        <!-- Badge -->
        <div class="inline-flex items-center gap-3 px-4 py-2 border border-white/15 bg-white/5 backdrop-blur-sm animate-fade-in-up">
          <span class="w-2 h-2 bg-[#22c55e] rounded-full animate-pulse"></span>
          <span class="text-xs font-medium tracking-[0.15em] uppercase text-white/80">Trusted by 2,000+ Families</span>
        </div>

        <!-- Headline -->
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-semibold leading-[1.05] tracking-[-0.02em] text-white animate-fade-in-up delay-100" style="font-family: var(--font-display);">
          Your Child's
          <br />
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#be1e2d] to-[#ef4444]">Medical</span>
          <br />
          Dreams
        </h1>

        <!-- Subheadline -->
        <p class="text-lg md:text-xl text-white/60 max-w-lg leading-relaxed animate-fade-in-up delay-200">
          Honest guidance for MBBS admissions abroad. No false promises, no hidden fees — just transparent advice for your family's future.
        </p>

        <!-- Quick stats -->
        <div class="grid grid-cols-3 gap-4 animate-fade-in-up delay-300">
          <div class="bg-white/5 border border-white/10 rounded-xl p-4 text-center backdrop-blur-sm">
            <div class="text-2xl md:text-3xl font-bold text-white" style="font-family: var(--font-display);">2K+</div>
            <div class="text-xs text-white/50 mt-1">Students Guided</div>
          </div>
          <div class="bg-white/5 border border-white/10 rounded-xl p-4 text-center backdrop-blur-sm">
            <div class="text-2xl md:text-3xl font-bold text-white" style="font-family: var(--font-display);">50+</div>
            <div class="text-xs text-white/50 mt-1">Universities</div>
          </div>
          <div class="bg-white/5 border border-white/10 rounded-xl p-4 text-center backdrop-blur-sm">
            <div class="text-2xl md:text-3xl font-bold text-[#22c55e]" style="font-family: var(--font-display);">98%</div>
            <div class="text-xs text-white/50 mt-1">Success Rate</div>
          </div>
        </div>

        <!-- CTA -->
        <div class="flex flex-col sm:flex-row gap-4 animate-fade-in-up delay-400">
          <button onclick="document.getElementById('lead-form-container')?.scrollIntoView({ behavior: 'smooth', block: 'center' })" class="group relative px-8 py-4 bg-[#be1e2d] text-white font-semibold tracking-wide overflow-hidden transition-all duration-300 hover:shadow-[0_0_40px_rgba(190,30,45,0.3)]">
            <span class="relative z-10 flex items-center justify-center gap-2">
              Get Free Assessment
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-1"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </span>
          </button>
          <span class="flex items-center justify-center gap-2 text-white/40 text-sm py-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            No Hidden Fees
          </span>
        </div>
      </div>

      <!-- Right: Image composition -->
      <div class="relative hidden lg:block animate-fade-in delay-500">
        <!-- Main image -->
        <div class="relative rounded-2xl overflow-hidden shadow-2xl border border-white/10">
          <img src="https://images.unsplash.com/photo-1571019613454-1cb2f99b2d8b?w=600&q=80&auto=format&fit=crop" alt="Medical students in white coats" class="w-full h-[440px] object-cover" loading="eager" />
          <div class="absolute inset-0 bg-gradient-to-t from-[#0a1628]/70 via-transparent to-transparent"></div>
          <div class="absolute bottom-6 left-6 right-6">
            <div class="bg-white/10 backdrop-blur-md border border-white/20 rounded-xl p-5">
              <div class="flex items-center gap-3 mb-3">
                <div class="flex -space-x-2">
                  <img src="https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=40&h=40&fit=crop&crop=face" alt="" class="w-8 h-8 rounded-full border-2 border-white/30 object-cover" />
                  <img src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=40&h=40&fit=crop&crop=face" alt="" class="w-8 h-8 rounded-full border-2 border-white/30 object-cover" />
                  <img src="https://images.unsplash.com/photo-1438761681033-6461ffad8d80?w=40&h=40&fit=crop&crop=face" alt="" class="w-8 h-8 rounded-full border-2 border-white/30 object-cover" />
                </div>
                <span class="text-xs text-white/70">2,000+ students placed</span>
              </div>
              <div class="flex gap-1">
                <span class="text-yellow-400 text-sm">★★★★★</span>
                <span class="text-xs text-white/60 ml-1">4.9/5 from parents</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Floating card: Verified -->
        <div class="absolute -top-5 -left-6 bg-white rounded-xl p-4 shadow-xl border border-gray-100 flex items-center gap-3 animate-fade-in delay-700">
          <div class="w-10 h-10 rounded-lg bg-[#f0fdf4] flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          </div>
          <div>
            <div class="font-semibold text-sm text-[#111827]">NMC Verified</div>
            <div class="text-xs text-[#6b7280]">All universities</div>
          </div>
        </div>

        <!-- Floating card: Countries -->
        <div class="absolute top-1/3 -right-5 bg-white rounded-xl p-4 shadow-xl border border-gray-100 flex items-center gap-3 animate-fade-in delay-800">
          <div class="w-10 h-10 rounded-lg bg-[#eff6ff] flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
          </div>
          <div>
            <div class="font-semibold text-sm text-[#111827]">15+ Countries</div>
            <div class="text-xs text-[#6b7280]">Georgia to UK</div>
          </div>
        </div>

        <!-- Floating card: Pricing -->
        <div class="absolute -bottom-4 left-12 bg-white rounded-xl p-4 shadow-xl border border-gray-100 flex items-center gap-3 animate-fade-in delay-900">
          <div class="w-10 h-10 rounded-lg bg-[#fef2f2] flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#be1e2d" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
          </div>
          <div>
            <div class="font-semibold text-sm text-[#111827]">From ₹3L/yr</div>
            <div class="text-xs text-[#6b7280]">Tuition + living</div>
          </div>
        </div>

        <!-- Decorative border -->
        <div class="absolute -z-10 top-8 left-8 right-8 bottom-8 rounded-2xl border border-white/5"></div>
      </div>
    </div>
  </div>

  <!-- Bottom gradient fade -->
  <div class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-t from-[#f5f5f7] to-transparent"></div>
</section>
<!-- WHY CHOOSE US -->
<section class="py-24 lg:py-32 bg-[#f5f5f7]">
  <div class="max-w-[1400px] mx-auto px-6 lg:px-12">
    <div class="max-w-3xl mb-16">
      <div class="text-xs tracking-[0.3em] uppercase text-[#be1e2d] mb-4">Why Choose Us</div>
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-semibold tracking-tight leading-[1.07] letter-tight" style="font-family: var(--font-display);">
        What Makes Us<br />Different
      </h2>
    </div>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      <div class="bg-white p-8 lg:p-10 group hover:shadow-[0_4px_24px_rgba(0,0,0,0.08)] transition-all duration-500">
        <div class="w-14 h-14 border border-[#e5e7eb] flex items-center justify-center mb-6 group-hover:border-[#be1e2d] group-hover:text-[#be1e2d] transition-all duration-300">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        </div>
        <h3 class="text-xl font-semibold mb-3" style="font-family: var(--font-display);">Brutally Honest</h3>
        <p class="text-sm text-[#4b5563] leading-relaxed">No sugarcoating. We tell you exactly which universities match your budget, marks, and career goals.</p>
      </div>
      <div class="bg-white p-8 lg:p-10 group hover:shadow-[0_4px_24px_rgba(0,0,0,0.08)] transition-all duration-500">
        <div class="w-14 h-14 border border-[#e5e7eb] flex items-center justify-center mb-6 group-hover:border-[#be1e2d] group-hover:text-[#be1e2d] transition-all duration-300">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        </div>
        <h3 class="text-xl font-semibold mb-3" style="font-family: var(--font-display);">Verified Only</h3>
        <p class="text-sm text-[#4b5563] leading-relaxed">Every university we recommend is MCI/NMC approved. No diploma mills, no surprises.</p>
      </div>
      <div class="bg-white p-8 lg:p-10 group hover:shadow-[0_4px_24px_rgba(0,0,0,0.08)] transition-all duration-500">
        <div class="w-14 h-14 border border-[#e5e7eb] flex items-center justify-center mb-6 group-hover:border-[#be1e2d] group-hover:text-[#be1e2d] transition-all duration-300">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
        </div>
        <h3 class="text-xl font-semibold mb-3" style="font-family: var(--font-display);">Transparent Pricing</h3>
        <p class="text-sm text-[#4b5563] leading-relaxed">Clear breakdown of tuition, living costs, and our fees. No hidden charges, ever.</p>
      </div>
      <div class="bg-white p-8 lg:p-10 group hover:shadow-[0_4px_24px_rgba(0,0,0,0.08)] transition-all duration-500">
        <div class="w-14 h-14 border border-[#e5e7eb] flex items-center justify-center mb-6 group-hover:border-[#be1e2d] group-hover:text-[#be1e2d] transition-all duration-300">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
        </div>
        <h3 class="text-xl font-semibold mb-3" style="font-family: var(--font-display);">End-to-End Support</h3>
        <p class="text-sm text-[#4b5563] leading-relaxed">From application to visa to FMGE coaching — we're with you for the entire journey.</p>
      </div>
      <div class="bg-white p-8 lg:p-10 group hover:shadow-[0_4px_24px_rgba(0,0,0,0.08)] transition-all duration-500">
        <div class="w-14 h-14 border border-[#e5e7eb] flex items-center justify-center mb-6 group-hover:border-[#be1e2d] group-hover:text-[#be1e2d] transition-all duration-300">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        </div>
        <h3 class="text-xl font-semibold mb-3" style="font-family: var(--font-display);">Parent Updates</h3>
        <p class="text-sm text-[#4b5563] leading-relaxed">Regular updates for parents, campus visits arranged, and 24/7 emergency support.</p>
      </div>
      <div class="bg-white p-8 lg:p-10 group hover:shadow-[0_4px_24px_rgba(0,0,0,0.08)] transition-all duration-500">
        <div class="w-14 h-14 border border-[#e5e7eb] flex items-center justify-center mb-6 group-hover:border-[#be1e2d] group-hover:text-[#be1e2d] transition-all duration-300">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/></svg>
        </div>
        <h3 class="text-xl font-semibold mb-3" style="font-family: var(--font-display);">FMGE Success</h3>
        <p class="text-sm text-[#4b5563] leading-relaxed">Proven coaching programs to help you clear the FMGE and practice in India.</p>
      </div>
    </div>
  </div>
</section>
<!-- COUNTRIES SECTION -->
<section class="py-24 lg:py-32 bg-[#1d1d1f] text-white">
  <div class="max-w-[1400px] mx-auto px-6 lg:px-12">
    <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-8 mb-16">
      <div class="max-w-2xl">
        <div class="text-xs tracking-[0.3em] uppercase text-[#be1e2d] mb-4">Destinations</div>
        <h2 class="text-4xl md:text-5xl lg:text-6xl font-semibold tracking-tight leading-[1.07] letter-tight text-white" style="font-family: var(--font-display);">
          Top Countries for<br />MBBS
        </h2>
      </div>
      <p class="text-white/60 max-w-md lg:text-right">
        Choose from world's best medical universities with affordable fees and global recognition.
      </p>
    </div>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      <!-- Georgia -->
      <a href="/georgia-study" class="group relative bg-white/5 backdrop-blur-sm border border-white/10 p-8 lg:p-10 hover:border-[#be1e2d] transition-all duration-500 overflow-hidden">
        <div class="absolute top-0 right-0 w-32 h-32 bg-gradient-radial from-[rgba(190,30,45,0.15)] to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        <div class="relative z-10">
          <div class="text-4xl mb-6">🇬🇪</div>
          <h3 class="text-2xl font-semibold mb-3 text-white" style="font-family: var(--font-display);">Georgia</h3>
          <p class="text-sm text-white/60 mb-6">Affordable MBBS in Tbilisi with English-medium programs and NMC-approved universities.</p>
          <div class="flex items-center gap-2 text-[#be1e2d] text-sm font-medium">
            <span>Explore</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </div>
        </div>
      </a>
      <!-- Uzbekistan -->
      <a href="/uzbekistan-study" class="group relative bg-white/5 backdrop-blur-sm border border-white/10 p-8 lg:p-10 hover:border-[#be1e2d] transition-all duration-500 overflow-hidden">
        <div class="absolute top-0 right-0 w-32 h-32 bg-gradient-radial from-[rgba(190,30,45,0.15)] to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        <div class="relative z-10">
          <div class="text-4xl mb-6">🇺🇿</div>
          <h3 class="text-2xl font-semibold mb-3 text-white" style="font-family: var(--font-display);">Uzbekistan</h3>
          <p class="text-sm text-white/60 mb-6">Low-cost MBBS with Indian student-friendly environment and WHO-recognized universities.</p>
          <div class="flex items-center gap-2 text-[#be1e2d] text-sm font-medium">
            <span>Explore</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </div>
        </div>
      </a>
      <!-- Kazakhstan -->
      <a href="/kazakhstan-study" class="group relative bg-white/5 backdrop-blur-sm border border-white/10 p-8 lg:p-10 hover:border-[#be1e2d] transition-all duration-500 overflow-hidden">
        <div class="absolute top-0 right-0 w-32 h-32 bg-gradient-radial from-[rgba(190,30,45,0.15)] to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        <div class="relative z-10">
          <div class="text-4xl mb-6">🇰🇿</div>
          <h3 class="text-2xl font-semibold mb-3 text-white" style="font-family: var(--font-display);">Kazakhstan</h3>
          <p class="text-sm text-white/60 mb-6">Quality medical education in Almaty with affordable fees and strong clinical training.</p>
          <div class="flex items-center gap-2 text-[#be1e2d] text-sm font-medium">
            <span>Explore</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </div>
        </div>
      </a>
      <!-- Russia -->
      <a href="/russia-study" class="group relative bg-white/5 backdrop-blur-sm border border-white/10 p-8 lg:p-10 hover:border-[#be1e2d] transition-all duration-500 overflow-hidden">
        <div class="absolute top-0 right-0 w-32 h-32 bg-gradient-radial from-[rgba(190,30,45,0.15)] to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        <div class="relative z-10">
          <div class="text-4xl mb-6">🇷🇺</div>
          <h3 class="text-2xl font-semibold mb-3 text-white" style="font-family: var(--font-display);">Russia</h3>
          <p class="text-sm text-white/60 mb-6">World-renowned medical universities with decades of Indian student success stories.</p>
          <div class="flex items-center gap-2 text-[#be1e2d] text-sm font-medium">
            <span>Explore</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </div>
        </div>
      </a>
      <!-- Kyrgyzstan -->
      <a href="/kyrgyzstan-study" class="group relative bg-white/5 backdrop-blur-sm border border-white/10 p-8 lg:p-10 hover:border-[#be1e2d] transition-all duration-500 overflow-hidden">
        <div class="absolute top-0 right-0 w-32 h-32 bg-gradient-radial from-[rgba(190,30,45,0.15)] to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        <div class="relative z-10">
