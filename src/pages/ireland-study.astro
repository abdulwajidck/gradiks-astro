---
import MainLayout from '../layouts/MainLayout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
const title = "Gradiks — Study in Ireland | MSc, MBA & More";
const description = "Study in Ireland with Gradiks. MSc Data Analytics, Cyber Security, Computer Science, MBA & more. 2-year stay-back visa. Honest consultancy.";
---
<MainLayout title={title} description={description}>
<Navigation />
<!-- TRUST BAR -->
<section class="bg-[#232d61] py-4 mt-20">
  <div class="max-w-[1400px] mx-auto px-6 lg:px-12">
    <div class="flex flex-wrap justify-center items-center gap-8 lg:gap-16 text-white text-sm">
      <span class="flex items-center gap-2">
        <span class="font-display font-semibold">2 Years</span>
        <span class="text-white/70">Stay Back Visa</span>
      </span>
      <span class="text-white/30 hidden sm:block">•</span>
      <span class="flex items-center gap-2">
        <span class="font-display font-semibold">€12-18K</span>
        <span class="text-white/70">Tuition/Year</span>
      </span>
      <span class="text-white/30 hidden sm:block">•</span>
      <span class="flex items-center gap-2">
        <span class="font-display font-semibold">1 Year</span>
        <span class="text-white/70">Master's Duration</span>
      </span>
    </div>
  </div>
</section>
<!-- HERO SECTION -->
<section class="lg:min-h-screen flex items-center relative overflow-hidden py-8 lg:py-32 bg-[#1d1d1f]">
  <div class="absolute inset-0 z-0">
    <div class="absolute top-1/3 right-0 w-[1000px] h-[1000px] rounded-full blur-3xl" style="background: radial-gradient(circle, rgba(190,30,45,0.06) 0%, transparent 70%);"></div>
  </div>
  <div class="max-w-[1400px] mx-auto px-6 lg:px-12 py-4 lg:py-32 relative z-10 w-full">
    <div class="max-w-4xl">
      <!-- Badge -->
      <div class="inline-flex items-center gap-3 px-4 py-2 border border-white/20 bg-white/5 backdrop-blur-sm mb-3 lg:mb-8 animate-fade-in-up">
        <span class="text-2xl">🇮🇪</span>
        <span class="text-xs font-medium tracking-[0.15em] uppercase text-white/80">Study in Ireland</span>
      </div>
      <!-- Headline -->
      <h1 class="text-4xl md:text-7xl lg:text-8xl font-semibold leading-[1.04] tracking-[-0.02em] mb-3 lg:mb-8 animate-fade-in-up delay-100 text-white" style="font-family: var(--font-display);">
        Study in
        <br />
        <span class="text-[#be1e2d]">Ireland</span>
      </h1>
      <!-- Subheadline -->
      <p class="text-base lg:text-2xl text-white/70 max-w-2xl leading-relaxed mb-4 lg:mb-12 animate-fade-in-up delay-200">
        The EU's only English-speaking tech hub. Home to Google, Apple, Meta. 2-year stay-back visa for graduates.
      </p>
      <!-- CTA Buttons -->
      <div class="hidden lg:flex flex-col sm:flex-row gap-4 animate-fade-in-up delay-300">
        <button onclick="document.getElementById('lead-form-container')?.scrollIntoView({ behavior: 'smooth', block: 'center' })" class="group relative px-8 py-4 bg-[#be1e2d] text-white font-semibold tracking-wide overflow-hidden transition-all duration-300 hover:shadow-[0_0_40px_rgba(190,30,45,0.3)]">
          <span class="relative z-10 flex items-center justify-center gap-2">
            Start Application
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-1"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </span>
        </button>
      </div>
      <div class="lg:hidden animate-fade-in-up delay-300">
        <form id="hero-lead-form" class="space-y-3">
          <input type="text" name="name" required class="w-full px-4 py-3 bg-white/10 border border-white/20 text-white placeholder-white/50 text-sm" placeholder="Full Name *">
          <input type="tel" name="phone" required class="w-full px-4 py-3 bg-white/10 border border-white/20 text-white placeholder-white/50 text-sm" placeholder="Your phone number *">
          <input type="email" name="email" required class="w-full px-4 py-3 bg-white/10 border border-white/20 text-white placeholder-white/50 text-sm" placeholder="Email *">
          <button type="submit" class="w-full py-4 bg-[#be1e2d] text-white font-semibold tracking-wide text-sm">GET FREE ASSESSMENT</button>
          <p class="text-center text-[10px] text-white/40">Free · No spam · 24hr response</p>
        </form>
      </div>
    </div>
  </div>
</section>
<!-- PROGRAMS SECTION -->
<section class="py-24 lg:py-32 bg-[#f5f5f7]">
  <div class="max-w-[1400px] mx-auto px-6 lg:px-12">
    <div class="max-w-3xl mb-16">
      <div class="text-xs tracking-[0.3em] uppercase text-[#be1e2d] mb-4">Programs</div>
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-semibold tracking-tight leading-[1.07] letter-tight" style="font-family: var(--font-display);">
        1-Year Intensive<br />Master's
      </h2>
    </div>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      <div class="group bg-white p-8 hover:shadow-[0_4px_24px_rgba(0,0,0,0.08)] transition-all duration-500">
        <div class="text-xs tracking-[0.2em] uppercase text-[#be1e2d] mb-4">Master of Science</div>
        <h3 class="text-2xl font-semibold mb-4" style="font-family: var(--font-display);">Data Analytics</h3>
        <p class="text-sm text-[#4b5563] mb-6">Big Data, Machine Learning, Business Intelligence. High demand from tech giants.</p>
        <div class="flex justify-between items-center pt-6 border-t border-[#e5e7eb]">
          <div>
            <div class="text-xs text-[#6b7280]">Duration</div>
            <div class="text-[#111827]">1 Year</div>
          </div>
          <div class="text-right">
            <div class="text-xs text-[#6b7280]">Tuition</div>
            <div class="text-[#be1e2d] font-medium">€15-20K</div>
          </div>
        </div>
      </div>
      <div class="group bg-white p-8 hover:shadow-[0_4px_24px_rgba(0,0,0,0.08)] transition-all duration-500">
        <div class="text-xs tracking-[0.2em] uppercase text-[#be1e2d] mb-4">Master of Science</div>
        <h3 class="text-2xl font-semibold mb-4" style="font-family: var(--font-display);">Cyber Security</h3>
        <p class="text-sm text-[#4b5563] mb-6">Network Security, Ethical Hacking, Digital Forensics. Critical skills shortage.</p>
        <div class="flex justify-between items-center pt-6 border-t border-[#e5e7eb]">
          <div>
            <div class="text-xs text-[#6b7280]">Duration</div>
            <div class="text-[#111827]">1 Year</div>
          </div>
          <div class="text-right">
            <div class="text-xs text-[#6b7280]">Tuition</div>
            <div class="text-[#be1e2d] font-medium">€16-22K</div>
          </div>
        </div>
      </div>
      <div class="group bg-white p-8 hover:shadow-[0_4px_24px_rgba(0,0,0,0.08)] transition-all duration-500">
        <div class="text-xs tracking-[0.2em] uppercase text-[#be1e2d] mb-4">Master of Business Administration</div>
        <h3 class="text-2xl font-semibold mb-4" style="font-family: var(--font-display);">MBA</h3>
        <p class="text-sm text-[#4b5563] mb-6">General Management, Finance, Marketing. Strong corporate connections.</p>
        <div class="flex justify-between items-center pt-6 border-t border-[#e5e7eb]">
          <div>
            <div class="text-xs text-[#6b7280]">Duration</div>
            <div class="text-[#111827]">1 Year</div>
          </div>
          <div class="text-right">
            <div class="text-xs text-[#6b7280]">Tuition</div>
            <div class="text-[#be1e2d] font-medium">€20-35K</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
<!-- WHY IRELAND -->
<section class="py-24 lg:py-32 bg-[#1d1d1f]">
  <div class="max-w-[1400px] mx-auto px-6 lg:px-12">
    <div class="max-w-3xl mb-16">
      <div class="text-xs tracking-[0.3em] uppercase text-[#be1e2d] mb-4">Why Ireland</div>
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-semibold tracking-tight leading-[1.07] letter-tight text-white" style="font-family: var(--font-display);">
        Why<br />Ireland?
      </h2>
    </div>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      <div class="bg-white/5 backdrop-blur-sm border border-white/10 p-8 lg:p-10 group hover:bg-white/10 transition-colors duration-500">
        <div class="text-5xl font-light text-white/30 mb-4 group-hover:text-[#be1e2d] transition-colors" style="font-family: var(--font-display);">01</div>
        <h3 class="text-xl font-semibold mb-3 text-white" style="font-family: var(--font-display);">2-Year Stay Back</h3>
        <p class="text-sm text-white/60">Graduate visa lets you work for 2 years post-study. Find a job, get a work permit.</p>
      </div>
      <div class="bg-white/5 backdrop-blur-sm border border-white/10 p-8 lg:p-10 group hover:bg-white/10 transition-colors duration-500">
        <div class="text-5xl font-light text-white/30 mb-4 group-hover:text-[#be1e2d] transition-colors" style="font-family: var(--font-display);">02</div>
        <h3 class="text-xl font-semibold mb-3 text-white" style="font-family: var(--font-display);">EU's Tech Hub</h3>
        <p class="text-sm text-white/60">European HQ for Google, Apple, Meta, Microsoft, LinkedIn, TikTok, and 1,000+ MNCs.</p>
      </div>
      <div class="bg-white/5 backdrop-blur-sm border border-white/10 p-8 lg:p-10 group hover:bg-white/10 transition-colors duration-500">
        <div class="text-5xl font-light text-white/30 mb-4 group-hover:text-[#be1e2d] transition-colors" style="font-family: var(--font-display);">03</div>
        <h3 class="text-xl font-semibold mb-3 text-white" style="font-family: var(--font-display);">No Language Barrier</h3>
        <p class="text-sm text-white/60">100% English-speaking country. No need to learn a new language for daily life.</p>
      </div>
      <div class="bg-white/5 backdrop-blur-sm border border-white/10 p-8 lg:p-10 group hover:bg-white/10 transition-colors duration-500">
        <div class="text-5xl font-light text-white/30 mb-4 group-hover:text-[#be1e2d] transition-colors" style="font-family: var(--font-display);">04</div>
        <h3 class="text-xl font-semibold mb-3 text-white" style="font-family: var(--font-display);">1-Year Master's</h3>
        <p class="text-sm text-white/60">Intensive 12-month programs. Lower total cost, faster ROI, quicker entry to workforce.</p>
      </div>
      <div class="bg-white/5 backdrop-blur-sm border border-white/10 p-8 lg:p-10 group hover:bg-white/10 transition-colors duration-500">
        <div class="text-5xl font-light text-white/30 mb-4 group-hover:text-[#be1e2d] transition-colors" style="font-family: var(--font-display);">05</div>
        <h3 class="text-xl font-semibold mb-3 text-white" style="font-family: var(--font-display);">€40-60K Starting Salary</h3>
        <p class="text-sm text-white/60">Tech and pharma graduates start at €40K+. Experienced roles pay €60-80K.</p>
      </div>
      <div class="bg-white/5 backdrop-blur-sm border border-white/10 p-8 lg:p-10 group hover:bg-white/10 transition-colors duration-500">
        <div class="text-5xl font-light text-white/30 mb-4 group-hover:text-[#be1e2d] transition-colors" style="font-family: var(--font-display);">06</div>
        <h3 class="text-xl font-semibold mb-3 text-white" style="font-family: var(--font-display);">EU Citizenship Pathway</h3>
        <p class="text-sm text-white/60">5 years of legal residence leads to permanent residency and EU citizenship.</p>
      </div>
    </div>
  </div>
</section>
<!-- LEAD FORM -->
<section id="lead-form-container" class="py-24 lg:py-32 bg-[#f5f5f7]">
  <div class="max-w-[1400px] mx-auto px-6 lg:px-12">
    <div class="max-w-2xl mx-auto">
      <div class="text-center mb-12">
        <div class="text-xs tracking-[0.3em] uppercase text-[#be1e2d] mb-4">Apply Now</div>
        <h2 class="text-4xl md:text-5xl font-semibold tracking-tight mb-4 leading-[1.07] letter-tight" style="font-family: var(--font-display);">
          Start Your<br />Application
        </h2>
      </div>
      <form id="lead-form" class="bg-white rounded-xl p-8 lg:p-12 shadow-[0_4px_24px_rgba(0,0,0,0.06)]">
        <div class="grid md:grid-cols-2 gap-6 mb-6">
          <div>
            <label class="form-label text-sm font-medium text-[#111827] mb-2 block">Full Name *</label>
            <input type="text" required class="w-full px-4 py-3 border border-[#e5e7eb] rounded-lg focus:outline-none focus:border-[#be1e2d] focus:ring-1 focus:ring-[#be1e2d] transition-all" placeholder="Your name">
          </div>
          <div>
            <label class="form-label text-sm font-medium text-[#111827] mb-2 block">Phone *</label>
            <input type="tel" required class="w-full px-4 py-3 border border-[#e5e7eb] rounded-lg focus:outline-none focus:border-[#be1e2d] focus:ring-1 focus:ring-[#be1e2d] transition-all" placeholder="+91...">
          </div>
        </div>
        <div class="mb-6">
          <label class="form-label text-sm font-medium text-[#111827] mb-2 block">Email *</label>
          <input type="email" required class="w-full px-4 py-3 border border-[#e5e7eb] rounded-lg focus:outline-none focus:border-[#be1e2d] focus:ring-1 focus:ring-[#be1e2d] transition-all" placeholder="email@example.com">
        </div>
        <div class="mb-8">
          <label class="form-label text-sm font-medium text-[#111827] mb-2 block">Program Interest</label>
          <select class="w-full px-4 py-3 border border-[#e5e7eb] rounded-lg focus:outline-none focus:border-[#be1e2d] focus:ring-1 focus:ring-[#be1e2d] transition-all bg-white">
            <option value="">Select program</option>
            <option value="msc-data-science">MSc Data Science</option>
            <option value="msc-cyber-security">MSc Cyber Security</option>
            <option value="msc-cs">MSc Computer Science</option>
            <option value="mba">MBA</option>
            <option value="msc-nursing">MSc Nursing</option>
            <option value="other">Other / Not Sure</option>
          </select>
        </div>
        <button type="submit" class="w-full py-5 bg-[#be1e2d] text-white font-semibold tracking-wide hover:shadow-[0_0_40px_rgba(190,30,45,0.25)] transition-all duration-300 flex items-center justify-center gap-3">
          Get Free Consultation
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </button>
      </form>
    </div>
  </div>
</section>
<!-- MOBILE STICKY CTA -->
<div class="fixed bottom-0 left-0 right-0 bg-white border-t border-[#e5e7eb] p-4 lg:hidden z-50">
  <div class="flex gap-3">
    <button onclick="document.getElementById('lead-form-container')?.scrollIntoView({ behavior: 'smooth', block: 'center' })" class="flex-1 py-3 bg-[#be1e2d] text-white font-semibold text-center">
      Start Application
    </button>
  </div>
</div>
<Footer />
<script>
document.getElementById('lead-form')?.addEventListener('submit', (e) => {
  e.preventDefault();
  const btn = e.target.querySelector('button[type="submit"]');
  btn.innerHTML = 'SUBMITTING...';
  btn.disabled = true;
  const name = e.target.querySelector('input[type="text"]').value.trim();
  const phone = e.target.querySelector('input[type="tel"]').value.trim();
  const email = e.target.querySelector('input[type="email"]').value.trim();
  const program = e.target.querySelector('select')?.value || '';
  let formattedPhone = phone.replace(/[\s\-]/g, '');
  if (!formattedPhone.startsWith('+')) { formattedPhone = '+91' + formattedPhone.replace(/^0+/, ''); }
  const payload = { fields: { name, phone: formattedPhone, email, lead_source: 'Google Ads', facebook_campaign_name: 'Ireland LP - Study Lead' } };
  const extraInfo = [];
  if (program) extraInfo.push('Program: ' + program);
  if (extraInfo.length > 0) payload.fields.notes = extraInfo.join(' | ');
  // Log to backend
  window.__sendToBackend && window.__sendToBackend({ form_type: 'ireland-study', name, phone: formattedPhone, email, program_interest: program });

  const sent = fetch('https://next-api.telecrm.in/enterprise/69a16e9a4ce16643f28061a1/autoupdatelead', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer bc0b7478-97ce-49b2-b96c-13ef444898311775379897519:0ba13bb8-04fb-4ec6-a9f8-e2ba4e6879f7' },
    body: JSON.stringify(payload),
    keepalive: true,
  }).then(res => {
    btn.innerHTML = 'REDIRECTING...';
    btn.style.backgroundColor = '#22c55e';
    setTimeout(() => { window.location.href = '/mbbs-thank-you'; }, 500);
  }).catch(() => {
    btn.disabled = false;
    btn.innerHTML = originalText;
    const err = document.createElement('p');
    err.className = 'text-red-600 text-sm text-center mt-4';
    err.textContent = 'Something went wrong. Please try again.';
    btn.parentElement.appendChild(err);
    setTimeout(() => err.remove(), 5000);
  });
});

// Hero mobile form handler
document.getElementById('hero-lead-form')?.addEventListener('submit', (e) => {
  e.preventDefault();
  const form = e.target;
  const btn = form.querySelector('button[type="submit"]');
  btn.disabled = true;
  const name = form.querySelector('[name="name"]').value.trim();
  const phone = form.querySelector('[name="phone"]').value.trim();
  const email = form.querySelector('[name="email"]').value.trim();
  let formattedPhone = phone.replace(/[\s\-]/g, '');
  if (!formattedPhone.startsWith('+')) { formattedPhone = '+91' + formattedPhone.replace(/^0+/, ''); }
  const payload = { fields: { name, phone: formattedPhone, email, lead_source: 'Google Ads', facebook_campaign_name: 'Ireland LP - Study Lead' } };
  // Log to backend
  window.__sendToBackend && window.__sendToBackend({ form_type: 'hero-ireland-study', name, phone: formattedPhone, email });
  const sent = fetch('https://next-api.telecrm.in/enterprise/69a16e9a4ce16643f28061a1/autoupdatelead', { method: 'POST', headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer bc0b7478-97ce-49b2-b96c-13ef444898311775379897519:0ba13bb8-04fb-4ec6-a9f8-e2ba4e6879f7' }, body: JSON.stringify(payload), keepalive: true }).then(res => {
    btn.innerHTML = 'REDIRECTING...';
    btn.style.backgroundColor = '#22c55e';
    setTimeout(() => { window.location.href = '/mbbs-thank-you'; }, 500);
  }).catch(() => {
    btn.disabled = false;
    btn.innerHTML = 'GET FREE ASSESSMENT';
    alert('Something went wrong. Please try again.');
  });
});
</script>
</MainLayout>