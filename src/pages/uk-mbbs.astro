---
import MainLayout from '../layouts/MainLayout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
const title = "Gradiks — MBBS in UK | GMC Registered Universities";
const description = "Study MBBS in United Kingdom with Gradiks. 5-6 year programs, GMC registered, PLAB pathway, world-class clinical training. Free consultation.";
---
<MainLayout title={title} description={description}>
<Navigation />
<!-- TRUST BAR -->
<section class="bg-[#232d61] py-4 mt-20">
  <div class="max-w-[1400px] mx-auto px-6 lg:px-12">
    <div class="flex flex-wrap justify-center items-center gap-8 lg:gap-16 text-white text-sm">
      <span class="flex items-center gap-2">
        <span class="font-display font-semibold">5–6 Years</span>
        <span class="text-white/70">Duration</span>
      </span>
      <span class="text-white/30 hidden sm:block">•</span>
      <span class="flex items-center gap-2">
        <span class="font-display font-semibold">₹25–45L</span>
        <span class="text-white/70">Tuition/Year</span>
      </span>
      <span class="text-white/30 hidden sm:block">•</span>
      <span class="flex items-center gap-2">
        <span class="font-display font-semibold">GMC</span>
        <span class="text-white/70">Registered</span>
      </span>
      <span class="text-white/30 hidden sm:block">•</span>
      <span class="flex items-center gap-2">
        <span class="font-display font-semibold">English</span>
        <span class="text-white/70">Medium</span>
      </span>
    </div>
  </div>
</section>
<!-- HERO -->
<section class="lg:min-h-screen flex items-center relative overflow-hidden py-8 lg:py-32 bg-[#1d1d1f]">
  <div class="absolute inset-0 z-0">
    <div class="absolute top-1/3 right-0 w-[1000px] h-[1000px] rounded-full blur-3xl" style="background: radial-gradient(circle, rgba(123,45,59,0.06) 0%, transparent 70%);"></div>
  </div>
  <div class="max-w-[1400px] mx-auto px-6 lg:px-12 py-4 lg:py-32 relative z-10 w-full">
    <div class="max-w-4xl">
      <div class="inline-flex items-center gap-3 px-4 py-2 border border-white/20 bg-white/5 backdrop-blur-sm mb-3 lg:mb-8 animate-fade-in-up">
        <span class="text-2xl">🇬🇧</span>
        <span class="text-xs font-medium tracking-[0.15em] uppercase text-white/80">Study MBBS in United Kingdom</span>
      </div>
      <h1 class="text-4xl md:text-7xl lg:text-8xl font-semibold leading-[1.04] tracking-[-0.02em] mb-3 lg:mb-8 animate-fade-in-up delay-100 text-white" style="font-family: var(--font-display);">
        MBBS in<br /><span class="text-[#7b2d3b]">United Kingdom</span>
      </h1>
      <p class="text-base lg:text-2xl text-white/70 max-w-2xl leading-relaxed mb-4 lg:mb-12 animate-fade-in-up delay-200">
        World-class medical education with GMC registration, NHS clinical placements, and a globally recognised degree that opens doors everywhere.
      </p>
      <div class="hidden lg:flex flex-col sm:flex-row gap-4 animate-fade-in-up delay-300">
        <button onclick="document.getElementById('lead-form-container')?.scrollIntoView({ behavior: 'smooth', block: 'center' })" class="group relative px-8 py-4 bg-[#7b2d3b] text-white font-semibold tracking-wide overflow-hidden transition-all duration-300 hover:shadow-[0_0_40px_rgba(190,30,45,0.3)]">
          <span class="relative z-10 flex items-center justify-center gap-2">
            Apply Now
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-1"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </span>
        </button>
        <a href="/#fees" class="group relative px-8 py-4 border border-white/20 text-white font-semibold tracking-wide overflow-hidden transition-all duration-300 hover:bg-white/5 text-center">
          Compare Fees
        </a>
      </div>
      <div class="lg:hidden animate-fade-in-up delay-300">
        <form id="hero-lead-form" class="space-y-3">
          <input type="text" name="name" required class="w-full px-4 py-3 bg-white/10 border border-white/20 text-white placeholder-white/50 text-sm" placeholder="Full Name *">
          <input type="tel" name="phone" required class="w-full px-4 py-3 bg-white/10 border border-white/20 text-white placeholder-white/50 text-sm" placeholder="+91 98765 43210 *">
          <input type="email" name="email" required class="w-full px-4 py-3 bg-white/10 border border-white/20 text-white placeholder-white/50 text-sm" placeholder="Email *">
          <button type="submit" class="w-full py-4 bg-[#7b2d3b] text-white font-semibold tracking-wide text-sm">GET FREE ASSESSMENT</button>
          <p class="text-center text-[10px] text-white/40">Free · No spam · 24hr response</p>
        </form>
      </div>
    </div>
  </div>
</section>
<!-- TOP UNIVERSITIES -->
<section class="py-24 lg:py-32 bg-[#f5f5f7]">
  <div class="max-w-[1400px] mx-auto px-6 lg:px-12">
    <div class="max-w-3xl mb-16">
      <div class="text-xs tracking-[0.3em] uppercase text-[#7b2d3b] mb-4">Top Universities</div>
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-semibold tracking-tight leading-[1.07] letter-tight" style="font-family: var(--font-display);">
        GMC-Registered<br />Universities in the UK
      </h2>
    </div>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="group bg-white p-8 hover:shadow-[0_4px_24px_rgba(0,0,0,0.08)] transition-all duration-500">
        <div class="text-xs tracking-[0.2em] uppercase text-[#7b2d3b] mb-4">Est. 1826</div>
        <h3 class="text-2xl font-semibold mb-4" style="font-family: var(--font-display);">University of Manchester</h3>
        <p class="text-sm text-[#4b5563] mb-6">One of the UK's largest medical schools. World-ranked research, diverse clinical placements across NHS trusts, and strong international student support.</p>
        <div class="flex justify-between items-center pt-6 border-t border-[#e5e7eb]">
          <div>
            <div class="text-xs text-[#6b7280]">Duration</div>
            <div class="text-[#111827]">5–6 Years</div>
          </div>
          <div class="text-right">
            <div class="text-xs text-[#6b7280]">Tuition/Year</div>
            <div class="text-[#7b2d3b] font-medium">₹30–40 L</div>
          </div>
        </div>
      </div>
      <div class="group bg-white p-8 hover:shadow-[0_4px_24px_rgba(0,0,0,0.08)] transition-all duration-500">
        <div class="text-xs tracking-[0.2em] uppercase text-[#7b2d3b] mb-4">Est. 1874</div>
        <h3 class="text-2xl font-semibold mb-4" style="font-family: var(--font-display);">Queen Mary University of London</h3>
        <p class="text-sm text-[#4b5563] mb-6">Barts and The London School of Medicine — one of England's oldest medical schools. Excellent hospital attachments and research output.</p>
        <div class="flex justify-between items-center pt-6 border-t border-[#e5e7eb]">
          <div>
            <div class="text-xs text-[#6b7280]">Duration</div>
            <div class="text-[#111827]">5 Years</div>
          </div>
          <div class="text-right">
            <div class="text-xs text-[#6b7280]">Tuition/Year</div>
            <div class="text-[#7b2d3b] font-medium">₹35–45 L</div>
          </div>
        </div>
      </div>
      <div class="group bg-white p-8 hover:shadow-[0_4px_24px_rgba(0,0,0,0.08)] transition-all duration-500">
        <div class="text-xs tracking-[0.2em] uppercase text-[#7b2d3b] mb-4">Est. 1831</div>
        <h3 class="text-2xl font-semibold mb-4" style="font-family: var(--font-display);">University of Birmingham</h3>
        <p class="text-sm text-[#4b5563] mb-6">Russell Group university with a highly ranked medical programme. Early clinical exposure, modern facilities, and a vibrant multicultural campus.</p>
        <div class="flex justify-between items-center pt-6 border-t border-[#e5e7eb]">
          <div>
            <div class="text-xs text-[#6b7280]">Duration</div>
            <div class="text-[#111827]">5 Years</div>
          </div>
          <div class="text-right">
            <div class="text-xs text-[#6b7280]">Tuition/Year</div>
            <div class="text-[#7b2d3b] font-medium">₹25–35 L</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
<!-- WHY UK -->
<section class="py-24 lg:py-32 bg-[#1d1d1f]">
  <div class="max-w-[1400px] mx-auto px-6 lg:px-12">
    <div class="max-w-3xl mb-16">
      <div class="text-xs tracking-[0.3em] uppercase text-[#7b2d3b] mb-4">Why United Kingdom</div>
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-semibold tracking-tight leading-[1.07] letter-tight text-white" style="font-family: var(--font-display);">
        Why Study<br />MBBS in the UK?
      </h2>
    </div>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      <div class="bg-white/5 backdrop-blur-sm border border-white/10 p-8 lg:p-10 group hover:bg-white/10 transition-colors duration-500">
        <div class="text-5xl font-light text-white/30 mb-4 group-hover:text-[#7b2d3b] transition-colors" style="font-family: var(--font-display);">01</div>
        <h3 class="text-xl font-semibold mb-3 text-white" style="font-family: var(--font-display);">GMC Registration</h3>
        <p class="text-sm text-white/60">Graduate with a degree that's immediately recognised by the General Medical Council. Straight path to PLAB and full UK medical practice.</p>
      </div>
      <div class="bg-white/5 backdrop-blur-sm border border-white/10 p-8 lg:p-10 group hover:bg-white/10 transition-colors duration-500">
        <div class="text-5xl font-light text-white/30 mb-4 group-hover:text-[#7b2d3b] transition-colors" style="font-family: var(--font-display);">02</div>
        <h3 class="text-xl font-semibold mb-3 text-white" style="font-family: var(--font-display);">NHS Clinical Training</h3>
        <p class="text-sm text-white/60">Train in some of the world's best hospitals. NHS placements give you hands-on experience with diverse patient populations from year one.</p>
      </div>
      <div class="bg-white/5 backdrop-blur-sm border border-white/10 p-8 lg:p-10 group hover:bg-white/10 transition-colors duration-500">
        <div class="text-5xl font-light text-white/30 mb-4 group-hover:text-[#7b2d3b] transition-colors" style="font-family: var(--font-display);">03</div>
        <h3 class="text-xl font-semibold mb-3 text-white" style="font-family: var(--font-display);">Global Recognition</h3>
        <p class="text-sm text-white/60">A UK medical degree is respected in over 150 countries. Direct pathways to USMLE, AMC, and other international licensing exams.</p>
      </div>
      <div class="bg-white/5 backdrop-blur-sm border border-white/10 p-8 lg:p-10 group hover:bg-white/10 transition-colors duration-500">
        <div class="text-5xl font-light text-white/30 mb-4 group-hover:text-[#7b2d3b] transition-colors" style="font-family: var(--font-display);">04</div>
        <h3 class="text-xl font-semibold mb-3 text-white" style="font-family: var(--font-display);">Research Excellence</h3>
        <p class="text-sm text-white/60">UK universities consistently rank in the global top 20 for medical research. Opportunities to participate in cutting-edge research alongside your studies.</p>
      </div>
      <div class="bg-white/5 backdrop-blur-sm border border-white/10 p-8 lg:p-10 group hover:bg-white/10 transition-colors duration-500">
        <div class="text-5xl font-light text-white/30 mb-4 group-hover:text-[#7b2d3b] transition-colors" style="font-family: var(--font-display);">05</div>
        <h3 class="text-xl font-semibold mb-3 text-white" style="font-family: var(--font-display);">Work While Studying</h3>
        <p class="text-sm text-white/60">International students can work up to 20 hours/week during term. Post-study work visa allows you to stay and work in the UK for 2 years after graduation.</p>
      </div>
      <div class="bg-white/5 backdrop-blur-sm border border-white/10 p-8 lg:p-10 group hover:bg-white/10 transition-colors duration-500">
        <div class="text-5xl font-light text-white/30 mb-4 group-hover:text-[#7b2d3b] transition-colors" style="font-family: var(--font-display);">06</div>
        <h3 class="text-xl font-semibold mb-3 text-white" style="font-family: var(--font-display);">Multicultural Campus</h3>
        <p class="text-sm text-white/60">A large Indian student community across UK cities. Safe, welcoming environment with excellent student support services and Indian food availability.</p>
      </div>
    </div>
  </div>
</section>
<!-- FEE BREAKDOWN -->
<section class="py-24 lg:py-32 bg-white">
  <div class="max-w-[1400px] mx-auto px-6 lg:px-12">
    <div class="text-center max-w-2xl mx-auto mb-16">
      <div class="text-xs tracking-[0.3em] uppercase text-[#7b2d3b] mb-4">Fee Breakdown</div>
      <h2 class="text-4xl md:text-5xl font-semibold tracking-tight mb-4 leading-[1.07] letter-tight" style="font-family: var(--font-display);">
        UK MBBS<br />Cost Breakdown
      </h2>
      <p class="text-[#4b5563]">Transparent fees. No hidden charges.</p>
    </div>
    <div class="max-w-[900px] mx-auto overflow-x-auto">
      <table class="w-full text-left" style="border-collapse: separate; border-spacing: 0;">
        <thead>
          <tr class="bg-[#232d61] text-white">
            <th class="font-display font-semibold text-sm px-6 py-4 rounded-tl-lg">University</th>
            <th class="font-display font-semibold text-sm px-6 py-4">Duration</th>
            <th class="font-display font-semibold text-sm px-6 py-4">Tuition/Year</th>
            <th class="font-display font-semibold text-sm px-6 py-4">Living/Year</th>
            <th class="font-display font-semibold text-sm px-6 py-4 rounded-tr-lg">Total (est.)</th>
          </tr>
        </thead>
        <tbody>
          <tr class="border-b border-[#e5e7eb] hover:bg-[#f8f9fb] transition-colors">
            <td class="px-6 py-4 font-medium text-[#111827] text-sm">University of Manchester</td>
            <td class="px-6 py-4 text-sm text-[#4b5563]">5–6 years</td>
            <td class="px-6 py-4 text-sm font-semibold text-[#111827]">₹30–40 L</td>
            <td class="px-6 py-4 text-sm text-[#4b5563]">₹8–12 L</td>
            <td class="px-6 py-4 text-sm font-bold text-[#059669]">₹1.5–2.5 Cr</td>
          </tr>
          <tr class="border-b border-[#e5e7eb] hover:bg-[#f8f9fb] transition-colors">
            <td class="px-6 py-4 font-medium text-[#111827] text-sm">Queen Mary, University of London</td>
            <td class="px-6 py-4 text-sm text-[#4b5563]">5 years</td>
            <td class="px-6 py-4 text-sm font-semibold text-[#111827]">₹35–45 L</td>
            <td class="px-6 py-4 text-sm text-[#4b5563]">₹10–15 L</td>
            <td class="px-6 py-4 text-sm font-bold text-[#059669]">₹2–3 Cr</td>
          </tr>
          <tr class="hover:bg-[#f8f9fb] transition-colors">
            <td class="px-6 py-4 font-medium text-[#111827] text-sm">University of Birmingham</td>
            <td class="px-6 py-4 text-sm text-[#4b5563]">5 years</td>
            <td class="px-6 py-4 text-sm font-semibold text-[#111827]">₹25–35 L</td>
            <td class="px-6 py-4 text-sm text-[#4b5563]">₹8–10 L</td>
            <td class="px-6 py-4 text-sm font-bold text-[#059669]">₹1.5–2.25 Cr</td>
          </tr>
        </tbody>
      </table>
    </div>
    <p class="text-center text-xs text-[#6b7280] mt-6">* Fees are estimates for 2025–26 intake. Actual fees may vary. Contact us for exact figures.</p>
  </div>
</section>
<!-- ADMISSION REQUIREMENTS -->
<section class="py-24 lg:py-32 bg-[#f5f5f7]">
  <div class="max-w-[1400px] mx-auto px-6 lg:px-12">
    <div class="max-w-3xl mb-16">
      <div class="text-xs tracking-[0.3em] uppercase text-[#7b2d3b] mb-4">Admission Requirements</div>
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-semibold tracking-tight leading-[1.07] letter-tight" style="font-family: var(--font-display);">
        What You Need<br />to Apply
      </h2>
    </div>
    <div class="grid md:grid-cols-2 gap-6 max-w-4xl">
      <div class="bg-white p-8 rounded-xl">
        <h3 class="text-lg font-semibold mb-4" style="font-family: var(--font-display);">Academic Requirements</h3>
        <ul class="space-y-3 text-sm text-[#4b5563]">
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-[#7b2d3b] mt-0.5 flex-shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
            <span>70–85% in 12th (PCB) from a recognised board</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-[#7b2d3b] mt-0.5 flex-shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
            <span>NEET qualification (required for Indian students)</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-[#7b2d3b] mt-0.5 flex-shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
            <span>IELTS overall 7.0 (min 7.0 in each band) or equivalent</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-[#7b2d3b] mt-0.5 flex-shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
            <span>UCAT or BMAT score (depending on university)</span>
          </li>
        </ul>
      </div>
      <div class="bg-white p-8 rounded-xl">
        <h3 class="text-lg font-semibold mb-4" style="font-family: var(--font-display);">Documents Required</h3>
        <ul class="space-y-3 text-sm text-[#4b5563]">
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-[#7b2d3b] mt-0.5 flex-shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
            <span>Valid passport (min 6 months validity)</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-[#7b2d3b] mt-0.5 flex-shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
            <span>Academic transcripts (10th & 12th mark sheets)</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-[#7b2d3b] mt-0.5 flex-shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
            <span>IELTS/TOEFL score card</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-[#7b2d3b] mt-0.5 flex-shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
            <span>Personal statement and reference letters</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-[#7b2d3b] mt-0.5 flex-shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
            <span>NEET scorecard</span>
          </li>
        </ul>
      </div>
    </div>
  </div>
</section>

<!-- STUDENT STORIES -->
<section class="py-20 lg:py-28 bg-[#f5f5f7]">
  <div class="max-w-[1400px] mx-auto px-6 lg:px-12">
    <div class="max-w-3xl mb-12">
      <div class="text-xs tracking-[0.3em] uppercase text-[#7b2d3b] mb-4">Student Stories</div>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-semibold tracking-tight leading-[1.1]" style="font-family: var(--font-display);">
        Hear From Our<br />UK Students
      </h2>
    </div>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-white p-8">
        <div class="flex items-center gap-3 mb-5">
          <div class="w-10 h-10 bg-[#7b2d3b]/10 text-[#7b2d3b] flex items-center justify-center font-display font-semibold text-sm">I</div>
          <div>
            <div class="font-semibold text-[#111827] text-sm">Ishaan B.</div>
            <div class="text-xs text-[#6b7280]">Mumbai · 3rd Year</div>
          </div>
        </div>
        <p class="text-sm text-[#4b5563] leading-relaxed mb-4">"Studying medicine in the UK was always my dream. Gradiks helped me with the UCAT prep, personal statement, and application. Got into my top choice university."</p>
        <div class="text-xs text-[#9ca3af] font-medium">University of Birmingham</div>
      </div>
      <div class="bg-white p-8">
        <div class="flex items-center gap-3 mb-5">
          <div class="w-10 h-10 bg-[#7b2d3b]/10 text-[#7b2d3b] flex items-center justify-center font-display font-semibold text-sm">S</div>
          <div>
            <div class="font-semibold text-[#111827] text-sm">Shreya G.</div>
            <div class="text-xs text-[#6b7280]">Delhi · 2nd Year</div>
          </div>
        </div>
        <p class="text-sm text-[#4b5563] leading-relaxed mb-4">"The NHS clinical placements from year one are incredible. I'm already getting hands-on experience in London hospitals. Gradiks' IELTS coaching was top-notch."</p>
        <div class="text-xs text-[#9ca3af] font-medium">Queen Mary University of London</div>
      </div>
      <div class="bg-white p-8">
        <div class="flex items-center gap-3 mb-5">
          <div class="w-10 h-10 bg-[#7b2d3b]/10 text-[#7b2d3b] flex items-center justify-center font-display font-semibold text-sm">N</div>
          <div>
            <div class="font-semibold text-[#111827] text-sm">Nikhil D.</div>
            <div class="text-xs text-[#6b7280]">Bangalore · 4th Year</div>
          </div>
        </div>
