---
import MainLayout from '../layouts/MainLayout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
const title = "Gradiks — MBBS in Kyrgyzstan | NMC Approved | Low Fees";
const description = "Study MBBS in Kyrgyzstan with Gradiks. 5-year program, NMC approved, fees from ₹2.5-4L/year. Kyrgyz State Medical University & more. Free consultation.";
---
<MainLayout title={title} description={description}>
<Navigation />
<!-- TRUST BAR -->
<section class="bg-[#232d61] py-4 mt-20">
  <div class="max-w-[1400px] mx-auto px-6 lg:px-12">
    <div class="flex flex-wrap justify-center items-center gap-8 lg:gap-16 text-white text-sm">
      <span class="flex items-center gap-2"><span class="font-display font-semibold">5 Years</span><span class="text-white/70">Duration</span></span>
      <span class="text-white/30 hidden sm:block">•</span>
      <span class="flex items-center gap-2"><span class="font-display font-semibold">₹2.5–4L</span><span class="text-white/70">Tuition/Year</span></span>
      <span class="text-white/30 hidden sm:block">•</span>
      <span class="flex items-center gap-2"><span class="font-display font-semibold">NMC</span><span class="text-white/70">Approved</span></span>
      <span class="text-white/30 hidden sm:block">•</span>
      <span class="flex items-center gap-2"><span class="font-display font-semibold">English</span><span class="text-white/70">Medium</span></span>
    </div>
  </div>
</section>
<!-- HERO -->
<section class="lg:min-h-screen flex items-center relative overflow-hidden py-8 lg:py-32 bg-[#1d1d1f]">
  <div class="absolute inset-0 z-0"><div class="absolute top-1/3 right-0 w-[1000px] h-[1000px] rounded-full blur-3xl" style="background: radial-gradient(circle, rgba(45,106,79,0.06) 0%, transparent 70%);"></div></div>
  <div class="max-w-[1400px] mx-auto px-6 lg:px-12 py-4 lg:py-32 relative z-10 w-full">
    <div class="max-w-4xl">
      <div class="inline-flex items-center gap-3 px-4 py-2 border border-white/20 bg-white/10 mb-3 lg:mb-8 ">
        <span class="text-2xl">🇰🇬</span>
        <span class="text-xs font-medium tracking-[0.15em] uppercase text-white/80">Study MBBS in Kyrgyzstan</span>
      </div>
      <h1 class="text-4xl md:text-7xl lg:text-8xl font-semibold leading-[1.04] tracking-[-0.02em] mb-3 lg:mb-8 text-white" style="font-family: var(--font-display);">MBBS in<br /><span class="text-[#2d6a4f]">Kyrgyzstan</span></h1>
      <p class="text-base lg:text-2xl text-white/70 max-w-2xl leading-relaxed mb-4 lg:mb-12">
        Affordable MBBS with NMC approval. 5-year program, English medium, and a well-established Indian student community in Bishkek.
      </p>
      <div class="hidden lg:flex flex-col sm:flex-row gap-4">
        <button onclick="document.getElementById('lead-form-container')?.scrollIntoView({ behavior: 'smooth', block: 'center' })" class="group relative px-8 py-4 bg-[#2d6a4f] text-white font-semibold tracking-wide overflow-hidden transition-all duration-300 hover:shadow-[0_0_40px_rgba(45,106,79,0.3)]">
          <span class="relative z-10 flex items-center justify-center gap-2">Apply Now<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-1"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></span>
        </button>
        <a href="/#fees" class="group relative px-8 py-4 border border-white/20 text-white font-semibold tracking-wide overflow-hidden transition-all duration-300 hover:bg-white/5 text-center">Compare Fees</a>
      </div>
      <div class="lg:hidden">
        <form id="hero-lead-form" class="space-y-3">
          <input type="text" name="name" required class="w-full px-4 py-3 bg-white/10 border border-white/20 text-white placeholder-white/50 text-sm" placeholder="Full Name *" aria-label="Full Name">
          <input type="tel" name="phone" required class="w-full px-4 py-3 bg-white/10 border border-white/20 text-white placeholder-white/50 text-sm" placeholder="+91 98765 43210 *" aria-label="Phone Number">
          <input type="email" name="email" required class="w-full px-4 py-3 bg-white/10 border border-white/20 text-white placeholder-white/50 text-sm" placeholder="Email *" aria-label="Email Address">
          <button type="submit" class="w-full py-4 bg-[#2d6a4f] text-white font-semibold tracking-wide text-sm">GET FREE ASSESSMENT</button>
          <p class="text-center text-[10px] text-white/40">Free · No spam · 24hr response</p>
        </form>
      </div>
    </div>
  </div>
</section>
<!-- TOP UNIVERSITIES -->
<section class="py-24 lg:py-32 bg-[#f5f5f7]">
  <div class="max-w-[1400px] mx-auto px-6 lg:px-12">
    <div class="max-w-3xl mb-16">
      <div class="text-xs tracking-[0.3em] uppercase text-[#2d6a4f] mb-4">Top Universities</div>
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-semibold tracking-tight leading-[1.07] letter-tight" style="font-family: var(--font-display);">NMC-Approved<br />Universities in Kyrgyzstan</h2>
    </div>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="group bg-white p-8 hover:shadow-[0_4px_24px_rgba(0,0,0,0.08)] transition-all duration-500">
        <div class="text-xs tracking-[0.2em] uppercase text-[#2d6a4f] mb-4">Est. 1939</div>
        <h3 class="text-2xl font-semibold mb-4" style="font-family: var(--font-display);">Kyrgyz State Medical University</h3>
        <p class="text-sm text-[#4b5563] mb-6">The #1 medical university in Kyrgyzstan. WHO listed, MCI screening recognized, with a long history of teaching Indian students.</p>
        <div class="flex justify-between items-center pt-6 border-t border-[#e5e7eb]">
          <div><div class="text-xs text-[#6b7280]">Duration</div><div class="text-[#111827]">5 Years</div></div>
          <div class="text-right"><div class="text-xs text-[#6b7280]">Tuition/Year</div><div class="text-[#2d6a4f] font-medium">₹3–4 Lakh</div></div>
        </div>
      </div>
      <div class="group bg-white p-8 hover:shadow-[0_4px_24px_rgba(0,0,0,0.08)] transition-all duration-500">
        <div class="text-xs tracking-[0.2em] uppercase text-[#2d6a4f] mb-4">Est. 1996</div>
        <h3 class="text-2xl font-semibold mb-4" style="font-family: var(--font-display);">International School of Medicine</h3>
        <p class="text-sm text-[#4b5563] mb-6">Located in Bishkek, fully English-medium. Modern curriculum with focus on clinical skills and international standards.</p>
        <div class="flex justify-between items-center pt-6 border-t border-[#e5e7eb]">
          <div><div class="text-xs text-[#6b7280]">Duration</div><div class="text-[#111827]">5 Years</div></div>
          <div class="text-right"><div class="text-xs text-[#6b7280]">Tuition/Year</div><div class="text-[#2d6a4f] font-medium">₹3–4.5 Lakh</div></div>
        </div>
      </div>
      <div class="group bg-white p-8 hover:shadow-[0_4px_24px_rgba(0,0,0,0.08)] transition-all duration-500">
        <div class="text-xs tracking-[0.2em] uppercase text-[#2d6a4f] mb-4">Est. 1951</div>
        <h3 class="text-2xl font-semibold mb-4" style="font-family: var(--font-display);">Osh State University Medical Faculty</h3>
        <p class="text-sm text-[#4b5563] mb-6">Most affordable NMC-approved option. Located in Kyrgyzstan's second-largest city with good clinical exposure.</p>
        <div class="flex justify-between items-center pt-6 border-t border-[#e5e7eb]">
          <div><div class="text-xs text-[#6b7280]">Duration</div><div class="text-[#111827]">5 Years</div></div>
          <div class="text-right"><div class="text-xs text-[#6b7280]">Tuition/Year</div><div class="text-[#2d6a4f] font-medium">₹2.5–3.5 Lakh</div></div>
        </div>
      </div>
    </div>
  </div>
</section>
<!-- WHY KYRGYZSTAN -->
<section class="py-24 lg:py-32 bg-[#1d1d1f]">
  <div class="max-w-[1400px] mx-auto px-6 lg:px-12">
    <div class="max-w-3xl mb-16">
      <div class="text-xs tracking-[0.3em] uppercase text-[#2d6a4f] mb-4">Why Kyrgyzstan</div>
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-semibold tracking-tight leading-[1.07] letter-tight text-white" style="font-family: var(--font-display);">Why Study<br />MBBS in Kyrgyzstan?</h2>
    </div>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      <div class="bg-white/10 border border-white/10 p-8 lg:p-10 group hover:bg-white/10 transition-colors duration-500">
        <div class="text-5xl font-light text-white/30 mb-4 group-hover:text-[#2d6a4f] transition-colors" style="font-family: var(--font-display);">01</div>
        <h3 class="text-xl font-semibold mb-3 text-white" style="font-family: var(--font-display);">Budget Friendly</h3>
        <p class="text-sm text-white/60">One of the lowest total costs for MBBS abroad. Tuition from ₹2.5L/year with living costs under ₹2L/year.</p>
      </div>
      <div class="bg-white/10 border border-white/10 p-8 lg:p-10 group hover:bg-white/10 transition-colors duration-500">
        <div class="text-5xl font-light text-white/30 mb-4 group-hover:text-[#2d6a4f] transition-colors" style="font-family: var(--font-display);">02</div>
        <h3 class="text-xl font-semibold mb-3 text-white" style="font-family: var(--font-display);">5-Year Program</h3>
        <p class="text-sm text-white/60">Complete your MBBS in 5 years — one year less than Georgia and Russia. Faster path to your medical career.</p>
      </div>
      <div class="bg-white/10 border border-white/10 p-8 lg:p-10 group hover:bg-white/10 transition-colors duration-500">
        <div class="text-5xl font-light text-white/30 mb-4 group-hover:text-[#2d6a4f] transition-colors" style="font-family: var(--font-display);">03</div>
        <h3 class="text-xl font-semibold mb-3 text-white" style="font-family: var(--font-display);">NMC Approved</h3>
        <p class="text-sm text-white/60">All universities we recommend are in NMC's approved list. Your degree is valid in India after FMGE/NExT.</p>
      </div>
      <div class="bg-white/10 border border-white/10 p-8 lg:p-10 group hover:bg-white/10 transition-colors duration-500">
        <div class="text-5xl font-light text-white/30 mb-4 group-hover:text-[#2d6a4f] transition-colors" style="font-family: var(--font-display);">04</div>
        <h3 class="text-xl font-semibold mb-3 text-white" style="font-family: var(--font-display);">English Medium</h3>
        <p class="text-sm text-white/60">Full English-medium programs. No language barrier — focus entirely on your medical studies.</p>
      </div>
      <div class="bg-white/10 border border-white/10 p-8 lg:p-10 group hover:bg-white/10 transition-colors duration-500">
        <div class="text-5xl font-light text-white/30 mb-4 group-hover:text-[#2d6a4f] transition-colors" style="font-family: var(--font-display);">05</div>
        <h3 class="text-xl font-semibold mb-3 text-white" style="font-family: var(--font-display);">Indian Student Hub</h3>
        <p class="text-sm text-white/60">Bishkek has a large, well-organized Indian student community. Indian food, festivals, and support networks.</p>
      </div>
      <div class="bg-white/10 border border-white/10 p-8 lg:p-10 group hover:bg-white/10 transition-colors duration-500">
        <div class="text-5xl font-light text-white/30 mb-4 group-hover:text-[#2d6a4f] transition-colors" style="font-family: var(--font-display);">06</div>
        <h3 class="text-xl font-semibold mb-3 text-white" style="font-family: var(--font-display);">Easy Admission</h3>
        <p class="text-sm text-white/60">No entrance exam beyond NEET qualification. Even low NEET scores are accepted. Simple admission process.</p>
      </div>
    </div>
  </div>
</section>
<!-- FEE BREAKDOWN -->
<section class="py-24 lg:py-32 bg-white">
  <div class="max-w-[1400px] mx-auto px-6 lg:px-12">
    <div class="text-center max-w-2xl mx-auto mb-16">
      <div class="text-xs tracking-[0.3em] uppercase text-[#2d6a4f] mb-4">Fee Breakdown</div>
      <h2 class="text-4xl md:text-5xl font-semibold tracking-tight mb-4 leading-[1.07] letter-tight" style="font-family: var(--font-display);">Kyrgyzstan MBBS<br />Cost Breakdown</h2>
      <p class="text-[#4b5563]">Transparent fees. No hidden charges.</p>
    </div>
    <div class="max-w-[900px] mx-auto overflow-x-auto">
      <table class="w-full text-left" style="border-collapse: separate; border-spacing: 0;">
        <thead><tr class="bg-[#232d61] text-white"><th class="font-display font-semibold text-sm px-6 py-4 rounded-tl-lg">University</th><th class="font-display font-semibold text-sm px-6 py-4">Duration</th><th class="font-display font-semibold text-sm px-6 py-4">Tuition/Year</th><th class="font-display font-semibold text-sm px-6 py-4">Living/Year</th><th class="font-display font-semibold text-sm px-6 py-4 rounded-tr-lg">Total (est.)</th></tr></thead>
        <tbody>
          <tr class="border-b border-[#e5e7eb] hover:bg-[#f8f9fb] transition-colors"><td class="px-6 py-4 font-medium text-[#111827] text-sm">Kyrgyz State Medical University</td><td class="px-6 py-4 text-sm text-[#4b5563]">5 years</td><td class="px-6 py-4 text-sm font-semibold text-[#111827]">₹3–4 L</td><td class="px-6 py-4 text-sm text-[#4b5563]">₹1.5–2 L</td><td class="px-6 py-4 text-sm font-bold text-[#059669]">₹22.5–30 L</td></tr>
          <tr class="border-b border-[#e5e7eb] hover:bg-[#f8f9fb] transition-colors"><td class="px-6 py-4 font-medium text-[#111827] text-sm">International School of Medicine</td><td class="px-6 py-4 text-sm text-[#4b5563]">5 years</td><td class="px-6 py-4 text-sm font-semibold text-[#111827]">₹3–4.5 L</td><td class="px-6 py-4 text-sm text-[#4b5563]">₹1.5–2 L</td><td class="px-6 py-4 text-sm font-bold text-[#059669]">₹22.5–32.5 L</td></tr>
          <tr class="hover:bg-[#f8f9fb] transition-colors"><td class="px-6 py-4 font-medium text-[#111827] text-sm">Osh State University Medical Faculty</td><td class="px-6 py-4 text-sm text-[#4b5563]">5 years</td><td class="px-6 py-4 text-sm font-semibold text-[#111827]">₹2.5–3.5 L</td><td class="px-6 py-4 text-sm text-[#4b5563]">₹1.5–2 L</td><td class="px-6 py-4 text-sm font-bold text-[#059669]">₹20–27.5 L</td></tr>
        </tbody>
      </table>
    </div>
    <p class="text-center text-xs text-[#6b7280] mt-6">* Fees are estimates for 2025–26 intake. Actual fees may vary. Contact us for exact figures.</p>
  </div>
</section>

<!-- STUDENT STORIES -->
<section class="py-20 lg:py-28 bg-[#f5f5f7]">
  <div class="max-w-[1400px] mx-auto px-6 lg:px-12">
    <div class="max-w-3xl mb-12">
      <div class="text-xs tracking-[0.3em] uppercase text-[#2d6a4f] mb-4">Student Stories</div>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-semibold tracking-tight leading-[1.1]" style="font-family: var(--font-display);">
        Hear From Our<br />KYRGYZSTAN Students
      </h2>
    </div>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-white p-8">
        <div class="flex items-center gap-3 mb-5">
          <div class="w-10 h-10 bg-[#2d6a4f]/10 text-[#2d6a4f] flex items-center justify-center font-display font-semibold text-sm">D</div>
          <div>
            <div class="font-semibold text-[#111827] text-sm">Deepa N.</div>
            <div class="text-xs text-[#6b7280]">Hyderabad · 3rd Year</div>
          </div>
        </div>
        <p class="text-sm text-[#4b5563] leading-relaxed mb-4">"Most affordable option we found. Bishkek has a huge Indian student community — felt like home from day one. Gradiks' local contact in Bishkek is always available."</p>
        <div class="text-xs text-[#9ca3af] font-medium">Kyrgyz State Medical University</div>
      </div>
      <div class="bg-white p-8">
        <div class="flex items-center gap-3 mb-5">
          <div class="w-10 h-10 bg-[#2d6a4f]/10 text-[#2d6a4f] flex items-center justify-center font-display font-semibold text-sm">K</div>
          <div>
            <div class="font-semibold text-[#111827] text-sm">Karthik S.</div>
            <div class="text-xs text-[#6b7280]">Coimbatore · 2nd Year</div>
          </div>
        </div>
        <p class="text-sm text-[#4b5563] leading-relaxed mb-4">"I scored low in NEET and thought my medical dream was over. Gradiks showed me options I didn't know existed. Now I'm studying medicine and loving it."</p>
        <div class="text-xs text-[#9ca3af] font-medium">International School of Medicine</div>
      </div>
      <div class="bg-white p-8">
        <div class="flex items-center gap-3 mb-5">
          <div class="w-10 h-10 bg-[#2d6a4f]/10 text-[#2d6a4f] flex items-center justify-center font-display font-semibold text-sm">M</div>
          <div>
            <div class="font-semibold text-[#111827] text-sm">Meera J.</div>
            <div class="text-xs text-[#6b7280]">Jaipur · 5th Year</div>
          </div>
        </div>
        <p class="text-sm text-[#4b5563] leading-relaxed mb-4">"The 5-year program means I'll start earning a year earlier. Gradiks' FMGE prep from 3rd year onwards was incredibly helpful. Cleared FMGE on first attempt."</p>
        <div class="text-xs text-[#9ca3af] font-medium">Kyrgyz State Medical University</div>
      </div>
    </div>
  </div>
</section>
<!-- LEAD FORM -->
<section id="lead-form-container" class="py-24 lg:py-32 bg-[#f5f5f7]">
  <div class="max-w-[1400px] mx-auto px-6 lg:px-12">
    <div class="max-w-2xl mx-auto">
      <div class="text-center mb-12">
        <div class="text-xs tracking-[0.3em] uppercase text-[#2d6a4f] mb-4">Get Started</div>
        <h2 class="text-4xl md:text-5xl font-semibold tracking-tight mb-4 leading-[1.07] letter-tight" style="font-family: var(--font-display);">Get Your Free<br />Kyrgyzstan Assessment</h2>
        <p class="text-[#4b5563]">Fill in your details and our experts will contact you within 24 hours.</p>
      </div>
      <form id="lead-form" class="bg-white rounded-xl p-8 lg:p-12 shadow-[0_4px_24px_rgba(0,0,0,0.06)]">
        <div class="grid md:grid-cols-2 gap-6 mb-6">
          <div><label class="form-label text-sm font-medium text-[#111827] mb-2 block">Student Name *</label><input type="text" required class="w-full px-4 py-3 border border-[#e5e7eb] rounded-lg focus:outline-none focus:border-[#2d6a4f] focus:ring-1 focus:ring-[#2d6a4f] transition-all" placeholder="Full name"></div>
          <div><label class="form-label text-sm font-medium text-[#111827] mb-2 block">Phone Number *</label><input type="tel" required class="w-full px-4 py-3 border border-[#e5e7eb] rounded-lg focus:outline-none focus:border-[#2d6a4f] focus:ring-1 focus:ring-[#2d6a4f] transition-all" placeholder="+91 98765 43210"></div>
        </div>
        <div class="mb-6"><label class="form-label text-sm font-medium text-[#111827] mb-2 block">Email Address *</label><input type="email" required class="w-full px-4 py-3 border border-[#e5e7eb] rounded-lg focus:outline-none focus:border-[#2d6a4f] focus:ring-1 focus:ring-[#2d6a4f] transition-all" placeholder="email@example.com"></div>
        <div class="grid md:grid-cols-2 gap-6 mb-6">
          <div><label class="form-label text-sm font-medium text-[#111827] mb-2 block">NEET Score (if known)</label><input type="number" class="w-full px-4 py-3 border border-[#e5e7eb] rounded-lg focus:outline-none focus:border-[#2d6a4f] focus:ring-1 focus:ring-[#2d6a4f] transition-all" placeholder="Enter score"></div>
        </div>
        <div class="mb-6"><label class="form-label text-sm font-medium text-[#111827] mb-2 block">Preferred Country</label><select class="w-full px-4 py-3 border border-[#e5e7eb] rounded-lg focus:outline-none focus:border-[#2d6a4f] focus:ring-1 focus:ring-[#2d6a4f] transition-all bg-white"><option value="">Select country</option><option value="georgia">Georgia</option><option value="uzbekistan">Uzbekistan</option><option value="kazakhstan">Kazakhstan</option><option value="russia">Russia</option><option value="kyrgyzstan" selected>Kyrgyzstan</option><option value="uk">United Kingdom</option><option value="other">Other / Not Sure</option></select></div>
        </div>
        <div class="mb-8"><label class="form-label text-sm font-medium text-[#111827] mb-2 block">Message (Optional)</label><textarea class="w-full px-4 py-3 border border-[#e5e7eb] rounded-lg focus:outline-none focus:border-[#2d6a4f] focus:ring-1 focus:ring-[#2d6a4f] transition-all resize-none" rows="4" placeholder="Tell us about your requirements..."></textarea></div>
        <button type="submit" class="w-full py-5 bg-[#2d6a4f] text-white font-semibold tracking-wide hover:shadow-[0_0_40px_rgba(45,106,79,0.25)] transition-all duration-300 flex items-center justify-center gap-3">Submit Application<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></button>
        <p class="text-xs text-center text-[#6b7280] mt-6">By submitting, you agree to our privacy policy. We never share your data.</p>
      </form>
    </div>
  </div>
</section>
<div class="fixed bottom-0 left-0 right-0 bg-white border-t border-[#e5e7eb] p-4 lg:hidden z-50"><div class="flex gap-3"><button onclick="document.getElementById('lead-form-container')?.scrollIntoView({ behavior: 'smooth', block: 'center' })" class="flex-1 py-3 bg-[#2d6a4f] text-white font-semibold text-center">Apply for Kyrgyzstan MBBS</button></div></div>
<Footer />
<script>
document.getElementById('lead-form')?.addEventListener('submit', async (e) => {
  e.preventDefault();
  const btn = e.target.querySelector('button[type="submit"]');
  btn.innerHTML = `<svg class="animate-spin" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12a9 9 0 11-6.219-8.56"/></svg> SUBMITTING...`;
  btn.disabled = true;
  const name = e.target.querySelector('input[type="text"]').value.trim();
