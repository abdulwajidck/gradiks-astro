---
import MainLayout from '../layouts/MainLayout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
const title = "Gradiks — Thank You | MBBS Enquiry Received";
const description = "Your MBBS enquiry has been received. Gradiks will contact you within 24 hours.";
---

<MainLayout title={title} description={description}>
<Navigation />

<!-- Thank You Hero -->
<section class="min-h-screen flex items-center relative overflow-hidden pt-24">
  <div class="absolute inset-0 z-0">
    <div class="absolute top-1/3 right-0 w-[1000px] h-[1000px] bg-gradient-radial from-[rgba(16,185,129,0.08)] via-transparent to-transparent rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 left-0 w-[600px] h-[600px] bg-gradient-radial from-[rgba(139,92,246,0.05)] via-transparent to-transparent rounded-full blur-3xl"></div>
  </div>
  <div class="max-w-[1400px] mx-auto px-6 lg:px-12 py-20 lg:py-32 relative z-10 w-full">
    <div class="max-w-2xl mx-auto text-center space-y-8">
      <!-- Success icon -->
      <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-[rgba(34,197,94,0.1)] mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
      </div>

      <!-- Badge -->
      <div class="inline-flex items-center gap-3 px-4 py-2 border border-[#d1d5db] bg-[#f9fafb]">
        <span class="w-2 h-2 bg-[#22c55e] rounded-full animate-pulse"></span>
        <span class="text-xs font-medium tracking-[0.15em] uppercase text-[#4b5563]">Enquiry Received</span>
      </div>

      <!-- Headline -->
      <h1 class="text-5xl md:text-6xl lg:text-7xl font-medium leading-[0.95] tracking-tight" style="font-family: var(--font-display);">
        THANK YOU
        <br />
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#be1e2d] to-[#dc2626]">WE'LL BE IN TOUCH</span>
      </h1>

      <!-- Subheadline -->
      <p class="text-lg md:text-xl text-[#4b5563] max-w-xl mx-auto leading-relaxed">
        We've received your MBBS enquiry. Our counsellor will review your profile and call you within <strong>24 hours</strong> with personalized options.
      </p>

      <!-- What happens next -->
      <div class="bg-[#f9fafb] border border-[#e5e7eb] p-8 lg:p-10 text-left max-w-xl mx-auto">
        <h2 class="text-xl font-medium mb-6" style="font-family: var(--font-display);">What happens next?</h2>
        <ol class="space-y-4">
          <li class="flex gap-4">
            <span class="flex-shrink-0 w-7 h-7 bg-[#be1e2d] text-white text-sm flex items-center justify-center font-medium rounded-full">1</span>
            <div>
              <div class="font-medium text-[#111827] mb-0.5">Profile review</div>
              <p class="text-sm text-[#4b5563]">We check your NEET score and match you to the best-fit college and program.</p>
            </div>
          </li>
          <li class="flex gap-4">
            <span class="flex-shrink-0 w-7 h-7 bg-[#be1e2d] text-white text-sm flex items-center justify-center font-medium rounded-full">2</span>
            <div>
              <div class="font-medium text-[#111827] mb-0.5">Personalized cost plan</div>
              <p class="text-sm text-[#4b5563]">You'll receive a detailed breakdown of tuition, hostel fees, and total budget.</p>
            </div>
          </li>
          <li class="flex gap-4">
            <span class="flex-shrink-0 w-7 h-7 bg-[#be1e2d] text-white text-sm flex items-center justify-center font-medium rounded-full">3</span>
            <div>
              <div class="font-medium text-[#111827] mb-0.5">Free 30-min counselling call</div>
              <p class="text-sm text-[#4b5563]">Our expert will answer all your questions and guide you on the next steps.</p>
            </div>
          </li>
        </ol>
      </div>

      <!-- Contact -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center pt-4">
        <a href="mailto:hello@gradiks.com" class="group px-8 py-4 bg-[#be1e2d] text-white font-semibold tracking-wide flex items-center justify-center gap-3 hover:bg-[#a81826] transition-all duration-300">
          EMAIL US
        </a>
      </div>
    </div>
  </div>
</section>

<Footer />

<!-- Google Ads Conversion Tag — MBBS Lead -->
<script>
  gtag('config', 'AW-17991836279');
  gtag('event', 'conversion', {'send_to': 'AW-17991836279/MiMqCKqor5UcEPfEloND'});
</script>
</MainLayout>
